---
/**
 * CarteTimeline — "Du sillage au réseau"
 * Carte marine animée du parcours de Colomban
 * Adapté depuis prototypes/proto3-carte/index.html
 */
---

<div class="carte-wrapper">
  <div id="carte-container">
    <canvas id="carte-canvas"></canvas>

    <div class="carte-title">
      <h3>Du sillage au réseau</h3>
      <p>Le parcours maritime de Colomban</p>
    </div>

    <div class="carte-phase-dots" id="carte-phases">
      <div class="carte-phase active" data-phase="enfance"><span class="carte-phase-dot"></span><span class="carte-phase-label">Enfance</span></div>
      <div class="carte-phase" data-phase="navigation"><span class="carte-phase-dot"></span><span class="carte-phase-label">Navigation</span></div>
      <div class="carte-phase" data-phase="fondateur"><span class="carte-phase-dot"></span><span class="carte-phase-label">Fondateur</span></div>
      <div class="carte-phase" data-phase="choix"><span class="carte-phase-dot"></span><span class="carte-phase-label">Choix</span></div>
      <div class="carte-phase" data-phase="reseau"><span class="carte-phase-dot"></span><span class="carte-phase-label">Réseau</span></div>
    </div>

    <div class="carte-year" id="carte-year">2000</div>

    <div class="carte-legend" id="carte-legend">
      <div class="carte-legend-item"><div class="carte-legend-line" style="background:#e8dcc8;"></div>Sillage</div>
      <div class="carte-legend-item"><div class="carte-legend-line" style="background:#2a55b3;"></div>Techno</div>
      <div class="carte-legend-item"><div class="carte-legend-line" style="background:#00bf63;"></div>Enviro</div>
      <div class="carte-legend-item"><div class="carte-legend-line" style="background:#b32a55;"></div>Socio</div>
    </div>

    <div class="carte-controls">
      <input type="range" id="carte-slider" min="0" max="100" value="0" class="carte-slider" />
    </div>

    <div class="carte-tooltip" id="carte-tooltip">
      <div class="carte-tooltip-name" id="carte-tooltip-name"></div>
      <div class="carte-tooltip-date" id="carte-tooltip-date"></div>
      <div class="carte-tooltip-desc" id="carte-tooltip-desc"></div>
    </div>
  </div>
</div>

<style>
  .carte-wrapper { position: relative; width: 100%; height: 100%; }

  #carte-container {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    background: #0d1117;
    border-radius: 24px;
    cursor: default;
  }

  #carte-canvas { display: block; width: 100%; height: 100%; }

  .carte-title {
    position: absolute;
    top: 20px;
    left: 24px;
    z-index: 10;
    pointer-events: none;
  }

  .carte-title h3 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(14px, 2vw, 20px);
    color: #e8dcc8;
    text-shadow: 0 2px 12px rgba(13,17,23,0.8);
  }

  .carte-title p {
    font-size: 11px;
    font-style: italic;
    color: rgba(232,220,200,0.4);
    margin-top: 2px;
  }

  .carte-phase-dots {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-end;
  }

  .carte-phase {
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0.3;
    transition: opacity 0.4s;
  }

  .carte-phase.active { opacity: 1; }

  .carte-phase-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #e8dcc8;
    transition: all 0.3s;
  }

  .carte-phase.active .carte-phase-dot {
    width: 10px;
    height: 10px;
    box-shadow: 0 0 8px rgba(232,220,200,0.5);
  }

  .carte-phase-label {
    font-family: var(--font-heading);
    font-size: 9px;
    color: rgba(232,220,200,0.7);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .carte-year {
    position: absolute;
    bottom: 50px;
    left: 24px;
    z-index: 10;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(32px, 6vw, 56px);
    color: rgba(232,220,200,0.08);
    pointer-events: none;
  }

  .carte-legend {
    position: absolute;
    bottom: 50px;
    right: 20px;
    z-index: 10;
    display: flex;
    gap: 12px;
    opacity: 0;
    transition: opacity 0.5s;
  }

  .carte-legend.visible { opacity: 1; }

  .carte-legend-item {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-heading);
    font-size: 9px;
    color: rgba(232,220,200,0.5);
  }

  .carte-legend-line { width: 16px; height: 2px; border-radius: 1px; }

  .carte-controls {
    position: absolute;
    bottom: 16px;
    left: 24px;
    right: 24px;
    z-index: 10;
  }

  .carte-slider {
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    height: 3px;
    background: rgba(232,220,200,0.15);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  .carte-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #e8dcc8;
    cursor: pointer;
    box-shadow: 0 0 8px rgba(232,220,200,0.4);
  }

  .carte-tooltip {
    position: absolute;
    z-index: 200;
    background: rgba(13,17,23,0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(232,220,200,0.2);
    border-radius: 10px;
    padding: 12px 16px;
    max-width: 250px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }

  .carte-tooltip.visible { opacity: 1; }

  .carte-tooltip-name { font-family: var(--font-heading); font-weight: 600; font-size: 13px; color: #e8dcc8; }
  .carte-tooltip-date { font-size: 11px; color: rgba(232,220,200,0.5); margin: 2px 0 6px; }
  .carte-tooltip-desc { font-size: 11px; line-height: 1.5; color: rgba(232,220,200,0.7); }

  @media (max-width: 768px) {
    .carte-phase-dots { gap: 5px; }
    .carte-phase-label { font-size: 8px; }
    .carte-legend { gap: 8px; bottom: 45px; }
  }
</style>

<script is:inline>
(function() {
  const COLORS = { sillage: '#e8dcc8', techno: '#2a55b3', enviro: '#00bf63', socio: '#b32a55', bg: '#0d1117', grid: 'rgba(232,220,200,0.04)', coast: 'rgba(232,220,200,0.12)' };

  const sillageWP = [
    { year:2000, name:'Bretagne & Irlande', label:'Enfance', lon:-4.5, lat:48.4, detail:'Traversées en bateau. Naissance de la vocation.', phase:'enfance' },
    { year:2010, name:'ENSM Marseille', label:'Formation', lon:5.37, lat:43.30, detail:'Entrée à l\'ENSM. Nul en maths mais accroché.', phase:'navigation' },
    { year:2011, name:'Croatie', label:'M/Y Queen Aida', lon:15.97, lat:43.51, detail:'Yachting en Méditerranée.', phase:'navigation' },
    { year:2012, name:'Bretagne', label:'Bourbon Ailette', lon:-3, lat:47.7, detail:'Navire de service Bourbon.', phase:'navigation' },
    { year:2013, name:'Manche', label:'Brittany Ferries', lon:-2, lat:49.8, detail:'Navire à passagers.', phase:'navigation' },
    { year:2013, name:'Marseille — Bourbon HQ', label:'MOMENT FONDATEUR', lon:5.37, lat:43.30, detail:'Données catastrophiques → naissance Opsealog.', phase:'fondateur', isFounder:true },
    { year:2014, name:'Angola', label:'Bourbon Ungundja', lon:12.3, lat:-8.8, detail:'Retour en mer avec humilité.', phase:'navigation' },
    { year:2015, name:'Chine → Namibie', label:'Bourbon Evolution', lon:40, lat:5, detail:'Construction neuve, FMEA, JDPO.', phase:'navigation' },
    { year:2015, name:'Brest / Fromveur', label:'Bourbon Argonaute', lon:-4.49, lat:48.39, detail:'Pose câble hydrolienne Sabella.', phase:'navigation' },
    { year:2016, name:'Angola', label:'Bourbon Vissolela', lon:12.3, lat:-8.8, detail:'2nd Mate / Safety Officer.', phase:'navigation' },
    { year:2017, name:'La Réunion', label:'CHOIX DÉCISIF', lon:55.53, lat:-21.11, detail:'Barge NRL. Dernier embarquement.', phase:'choix', isDecisive:true }
  ];

  const annecyHub = { lon:6.13, lat:45.90 };
  const reseauThreads = [
    { color:COLORS.techno, dest:{lon:5.37,lat:43.30}, label:'Opsealog', role:'Innovation' },
    { color:COLORS.enviro, dest:{lon:0.10,lat:49.49}, label:'ENSM', role:'Enseignant DD' },
    { color:COLORS.socio, dest:{lon:-1.55,lat:47.22}, label:'GASPE', role:'DG' },
    { color:COLORS.socio, dest:{lon:2.35,lat:48.86}, label:'HYDROS / Presse', role:'Auteur' },
  ];

  const coastlines = [
    [[-10,36],[-9,38],[-9,40],[-8,42],[-4,43],[-2,43.5],[0,43],[3,43],[5,43.5],[7,43.7],[9,44],[11,44],[13,44],[14,42],[15,41],[16,40],[18,40],[20,39],[23,38],[26,39],[28,41],[30,41],[32,36],[35,33],[30,31],[25,31],[10,35],[0,35],[-6,35],[-10,36]],
    [[-6,50],[-5,51],[-4,52],[-4,54],[-3,55],[-5,57],[-3,58],[-2,57],[0,53],[1,52],[0,51],[-1,50.5],[-4,50],[-6,50]],
    [[-10,51.5],[-10,53],[-9,54],[-7,55],[-6,54],[-6,52.5],[-8,51.5],[-10,51.5]],
    [[-17,15],[-16,13],[-15,11],[-8,5],[0,5],[5,4],[10,4],[10,2],[9,-1],[9,-4],[12,-6],[12,-10],[13,-13],[12,-17],[15,-22],[17,-25],[18,-29],[20,-33],[25,-34],[28,-33],[30,-30],[32,-28],[33,-25],[35,-22],[40,-15],[42,-12],[44,-12],[48,-10],[50,-6],[50,0],[48,5],[44,10],[43,12],[42,15],[35,20],[33,30],[32,33],[35,33]]
  ];

  const container = document.getElementById('carte-container');
  const canvas = document.getElementById('carte-canvas');
  const ctx = canvas.getContext('2d');
  const slider = document.getElementById('carte-slider');
  const tooltip = document.getElementById('carte-tooltip');

  let W, H, mapCenter = {lon:15, lat:25}, mapZoom = 1;

  function resize() {
    W = container.clientWidth; H = container.clientHeight;
    canvas.width = W * Math.min(devicePixelRatio, 2);
    canvas.height = H * Math.min(devicePixelRatio, 2);
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.setTransform(1,0,0,1,0,0);
    ctx.scale(Math.min(devicePixelRatio,2), Math.min(devicePixelRatio,2));
  }
  resize();
  new ResizeObserver(resize).observe(container);

  function project(lon, lat) {
    const x = W/2 + (lon - mapCenter.lon) * (W/120) * mapZoom;
    const lr = lat * Math.PI/180, cr = mapCenter.lat * Math.PI/180;
    const y = H/2 - (Math.log(Math.tan(Math.PI/4+lr/2)) - Math.log(Math.tan(Math.PI/4+cr/2))) * (W/120) * mapZoom * (180/Math.PI);
    return {x, y};
  }

  function drawGrid() {
    ctx.strokeStyle = COLORS.grid; ctx.lineWidth = 0.5;
    for (let lon = -30; lon <= 130; lon += 10) { ctx.beginPath(); const a=project(lon,-40),b=project(lon,65); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y); ctx.stroke(); }
    for (let lat = -40; lat <= 65; lat += 10) { ctx.beginPath(); const a=project(-30,lat),b=project(130,lat); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y); ctx.stroke(); }
  }

  function drawCoast() {
    coastlines.forEach(c => {
      ctx.beginPath(); ctx.strokeStyle = COLORS.coast; ctx.lineWidth = 1;
      c.forEach((p,i) => { const pt = project(p[0],p[1]); i===0 ? ctx.moveTo(pt.x,pt.y) : ctx.lineTo(pt.x,pt.y); });
      ctx.stroke();
      ctx.fillStyle = 'rgba(232,220,200,0.02)'; ctx.fill();
    });
  }

  function drawSillage(prog) {
    const total = sillageWP.length, drawn = Math.floor(prog * total), partial = prog * total - drawn;
    if (drawn < 1) return;
    ctx.beginPath(); ctx.strokeStyle = COLORS.sillage; ctx.lineWidth = 2; ctx.globalAlpha = 0.7;
    for (let i = 0; i <= Math.min(drawn, total-1); i++) {
      const p = project(sillageWP[i].lon, sillageWP[i].lat);
      if (i===0) { ctx.moveTo(p.x,p.y); continue; }
      const prev = project(sillageWP[i-1].lon, sillageWP[i-1].lat);
      const cpX = (prev.x+p.x)/2, cpY = Math.min(prev.y,p.y) - Math.abs(p.x-prev.x)*0.15;
      if (i === drawn && partial < 1) { const t=partial; ctx.quadraticCurveTo(cpX,cpY,(1-t)*(1-t)*prev.x+2*(1-t)*t*cpX+t*t*p.x,(1-t)*(1-t)*prev.y+2*(1-t)*t*cpY+t*t*p.y); }
      else ctx.quadraticCurveTo(cpX,cpY,p.x,p.y);
    }
    ctx.stroke(); ctx.globalAlpha = 1;

    for (let i = 0; i < Math.min(drawn+1, total); i++) {
      const wp = sillageWP[i], p = project(wp.lon, wp.lat);
      let sz = 3, col = COLORS.sillage;
      if (wp.isFounder) { sz = 5; col = COLORS.enviro; }
      if (wp.isDecisive) { sz = 6; col = '#ff6b6b'; }
      if (sz > 3) { const g = ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,15); g.addColorStop(0,col+'40'); g.addColorStop(1,'transparent'); ctx.fillStyle=g; ctx.beginPath(); ctx.arc(p.x,p.y,15,0,Math.PI*2); ctx.fill(); }
      ctx.fillStyle = col; ctx.beginPath(); ctx.arc(p.x,p.y,sz,0,Math.PI*2); ctx.fill();
      ctx.fillStyle = 'rgba(232,220,200,0.6)'; ctx.font = '9px Poppins,sans-serif'; ctx.textAlign = 'center'; ctx.fillText(wp.label, p.x, p.y-sz-8);
    }
  }

  function drawReseau(prog, time) {
    if (prog <= 0) return;
    const hub = project(annecyHub.lon, annecyHub.lat);
    const g = ctx.createRadialGradient(hub.x,hub.y,0,hub.x,hub.y,20); g.addColorStop(0,'rgba(232,220,200,0.3)'); g.addColorStop(1,'transparent');
    ctx.fillStyle = g; ctx.beginPath(); ctx.arc(hub.x,hub.y,20,0,Math.PI*2); ctx.fill();
    ctx.fillStyle = '#e8dcc8'; ctx.beginPath(); ctx.arc(hub.x,hub.y,4,0,Math.PI*2); ctx.fill();
    ctx.fillStyle = 'rgba(232,220,200,0.7)'; ctx.font = '600 10px Poppins,sans-serif'; ctx.textAlign = 'center'; ctx.fillText('ANNECY',hub.x,hub.y-12);

    const show = Math.ceil(prog * reseauThreads.length);
    for (let i = 0; i < show; i++) {
      const t = reseauThreads[i], tp = Math.min(1, prog * reseauThreads.length - i);
      if (tp <= 0) continue;
      const d = project(t.dest.lon, t.dest.lat);
      const cpX = (hub.x+d.x)/2, cpY = (hub.y+d.y)/2 - 20;
      ctx.beginPath(); ctx.strokeStyle = t.color; ctx.lineWidth = 1.5; ctx.globalAlpha = 0.5*tp; ctx.setLineDash([5,3]);
      const steps = 40, max = Math.floor(steps*tp);
      for (let s = 0; s <= max; s++) { const u=s/steps; const x=(1-u)*(1-u)*hub.x+2*(1-u)*u*cpX+u*u*d.x; const y=(1-u)*(1-u)*hub.y+2*(1-u)*u*cpY+u*u*d.y; s===0?ctx.moveTo(x,y):ctx.lineTo(x,y); }
      ctx.stroke(); ctx.setLineDash([]); ctx.globalAlpha = 1;

      const pt = ((time*0.3+i*0.7)%2)/2;
      if (pt<=tp) { const px=(1-pt)*(1-pt)*hub.x+2*(1-pt)*pt*cpX+pt*pt*d.x, py=(1-pt)*(1-pt)*hub.y+2*(1-pt)*pt*cpY+pt*pt*d.y; ctx.fillStyle=t.color; ctx.globalAlpha=0.7; ctx.beginPath(); ctx.arc(px,py,2,0,Math.PI*2); ctx.fill(); ctx.globalAlpha=1; }

      if (tp > 0.5) {
        ctx.globalAlpha = (tp-0.5)*2;
        ctx.fillStyle = t.color; ctx.beginPath(); ctx.arc(d.x,d.y,3,0,Math.PI*2); ctx.fill();
        ctx.font = '600 9px Poppins,sans-serif'; ctx.textAlign = 'left'; ctx.fillText(t.label, d.x+8, d.y+3);
        ctx.globalAlpha = 1;
      }
    }
  }

  let progress = 0;
  slider.addEventListener('input', () => { progress = slider.value / 100; });

  // Hover
  const mousePos = {x:-999,y:-999};
  container.addEventListener('pointermove', e => {
    const r = container.getBoundingClientRect();
    mousePos.x = e.clientX - r.left;
    mousePos.y = e.clientY - r.top;
  });
  container.addEventListener('pointerleave', () => { mousePos.x=-999; tooltip.classList.remove('visible'); });

  const startTime = Date.now();
  function render() {
    requestAnimationFrame(render);
    const time = (Date.now()-startTime)/1000;
    ctx.fillStyle = COLORS.bg; ctx.fillRect(0,0,W,H);

    if (progress < 0.6) { mapCenter.lon = 15+progress*20; mapCenter.lat = 25; mapZoom = 1+progress*0.3; }
    else { const t=(progress-0.6)/0.4; mapCenter.lon = 27-t*20; mapCenter.lat = 25+t*20; mapZoom = 1.3+t*1.5; }

    drawGrid(); drawCoast();
    drawSillage(Math.min(1, progress/0.6));
    drawReseau(progress > 0.6 ? (progress-0.6)/0.4 : 0, time);

    // Phase indicator
    let phase = 'enfance';
    if (progress > 0.08) phase = 'navigation';
    if (progress > 0.35) phase = 'fondateur';
    if (progress > 0.55) phase = 'choix';
    if (progress > 0.65) phase = 'reseau';
    document.querySelectorAll('#carte-phases .carte-phase').forEach(el => el.classList.toggle('active', el.dataset.phase === phase));

    let year;
    if (progress < 0.08) year = Math.floor(1991 + progress/0.08*19);
    else if (progress < 0.65) year = Math.floor(2010 + (progress-0.08)/0.57*7);
    else year = Math.floor(2017 + (progress-0.65)/0.35*9);
    document.getElementById('carte-year').textContent = year;

    document.getElementById('carte-legend').classList.toggle('visible', progress > 0.65);

    // Tooltip on waypoints
    let found = false;
    const sp = Math.min(1, progress/0.6);
    const vis = Math.floor(sp * sillageWP.length);
    for (let i = 0; i < vis; i++) {
      const wp = sillageWP[i], p = project(wp.lon, wp.lat);
      if (Math.hypot(mousePos.x-p.x, mousePos.y-p.y) < 15) {
        tooltip.classList.add('visible');
        tooltip.style.left = (p.x+16)+'px'; tooltip.style.top = (p.y-10)+'px';
        document.getElementById('carte-tooltip-name').textContent = wp.name;
        document.getElementById('carte-tooltip-date').textContent = wp.year;
        document.getElementById('carte-tooltip-desc').textContent = wp.detail;
        found = true; break;
      }
    }
    if (!found) tooltip.classList.remove('visible');
  }
  render();
})();
</script>
