---
/**
 * Noeud SVG vectoriel leger — Design System
 * Noeud entrelace bleu/vert avec accent diamant
 * 3 variantes : inline (composant), watermark (background), divider (separateur)
 *
 * Props:
 *   size: number (px, default 40)
 *   variant: 'default' | 'watermark' | 'mono' (default: 'default')
 *   animate: boolean (tressage animation on scroll, default: false)
 */
interface Props {
  size?: number;
  variant?: 'default' | 'watermark' | 'mono';
  animate?: boolean;
  class?: string;
}

const {
  size = 40,
  variant = 'default',
  animate = false,
  class: className = '',
} = Astro.props;

const isWatermark = variant === 'watermark';
const isMono = variant === 'mono';
const bleu = isMono ? 'currentColor' : '#2A55B3';
const vert = isMono ? 'currentColor' : '#00BF63';
const opacity = isWatermark ? '0.04' : '1';
---

<svg
  class:list={['noeud', { 'noeud--animate': animate, 'noeud--watermark': isWatermark }, className]}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  opacity={opacity}
>
  <!-- Ruban bleu complet (layer 1) -->
  <path
    class="noeud__ribbon-blue"
    d="M50 10 C25 10, 10 30, 10 50 C10 70, 25 90, 50 90 C75 90, 90 70, 90 50 C90 30, 75 10, 50 10 Z M50 25 C65 25, 75 35, 75 50 C75 65, 65 75, 50 75 C35 75, 25 65, 25 50 C25 35, 35 25, 50 25 Z"
    fill="none"
    stroke={bleu}
    stroke-width="6"
    stroke-linecap="round"
  />
  <!-- Boucle superieure du noeud (figure 8 haut) -->
  <path
    class="noeud__loop-top"
    d="M38 50 C38 30, 30 18, 50 18 C70 18, 62 30, 62 50"
    fill="none"
    stroke={bleu}
    stroke-width="7"
    stroke-linecap="round"
  />
  <!-- Boucle inferieure du noeud (figure 8 bas) -->
  <path
    class="noeud__loop-bottom"
    d="M62 50 C62 70, 70 82, 50 82 C30 82, 38 70, 38 50"
    fill="none"
    stroke={bleu}
    stroke-width="7"
    stroke-linecap="round"
  />
  <!-- Ruban vert par-dessus au croisement bas (layer 2) -->
  <path
    class="noeud__ribbon-green"
    d="M44 44 C48 52, 52 58, 56 56"
    fill="none"
    stroke={vert}
    stroke-width="7"
    stroke-linecap="round"
  />
  <!-- Arc bleu par-dessus au croisement haut (layer 3) -->
  <path
    class="noeud__cross-top"
    d="M56 44 C52 48, 48 52, 44 56"
    fill="none"
    stroke={bleu}
    stroke-width="7"
    stroke-linecap="round"
  />
  <!-- Accent diamant vert -->
  <rect
    class="noeud__diamond"
    x="72" y="14"
    width="6" height="6"
    rx="1"
    fill={vert}
    transform="rotate(45, 75, 17)"
  />
</svg>

<style>
  /* ── Tressage animation (stroke draw) ── */
  .noeud--animate .noeud__loop-top,
  .noeud--animate .noeud__loop-bottom {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    animation: noeud-draw 1.8s var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) forwards;
  }

  .noeud--animate .noeud__loop-bottom {
    animation-delay: 0.3s;
  }

  .noeud--animate .noeud__ribbon-green {
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: noeud-draw 0.6s var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 0.8s forwards;
  }

  .noeud--animate .noeud__cross-top {
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: noeud-draw 0.6s var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)) 1.1s forwards;
  }

  .noeud--animate .noeud__diamond {
    opacity: 0;
    animation: noeud-diamond 0.4s ease 1.4s forwards;
  }

  @keyframes noeud-draw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes noeud-diamond {
    from { opacity: 0; transform: rotate(45deg) scale(0); }
    to { opacity: 1; transform: rotate(45deg) scale(1); }
  }

  /* ── Watermark variant ── */
  .noeud--watermark {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }
</style>
