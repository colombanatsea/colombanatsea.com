---
/**
 * MediaViz — Constellation médiatique interactive
 * Adapté depuis prototypes/proto4-mediaviz/index.html
 */
---

<div class="mediaviz-wrapper">
  <div id="mediaviz-container">
    <canvas id="mediaviz-canvas"></canvas>

    <div class="mv-axis-filter" id="mv-axis-filter">
      <button class="mv-filter-btn active" data-axis="all">Tous</button>
      <button class="mv-filter-btn" data-axis="techno">Techno</button>
      <button class="mv-filter-btn" data-axis="enviro">Enviro</button>
      <button class="mv-filter-btn" data-axis="socio">Socio</button>
    </div>

    <div class="mv-stats" id="mv-stats">
      <div class="mv-stat">
        <span class="mv-stat-number" id="mv-stat-total">0</span>
        <span class="mv-stat-label">Publications</span>
      </div>
      <div class="mv-stat">
        <span class="mv-stat-number" id="mv-stat-reach">0</span>
        <span class="mv-stat-label">Portée</span>
      </div>
    </div>

    <div class="mv-timeline" id="mv-timeline"></div>

    <div class="mv-tooltip" id="mv-tooltip"></div>
  </div>
</div>

<style>
  .mediaviz-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  #mediaviz-container {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    background: #0a0e1a;
    border-radius: 24px;
  }

  #mediaviz-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  .mv-axis-filter {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 10;
    display: flex;
    gap: 6px;
  }

  .mv-filter-btn {
    padding: 5px 12px;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.6);
    border-radius: 20px;
    cursor: pointer;
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: 600;
    transition: all 0.3s;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .mv-filter-btn.active { color: #fff; background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.3); }
  .mv-filter-btn[data-axis="techno"].active { background: rgba(42,85,179,0.3); border-color: #2a55b3; color: #6b9fff; }
  .mv-filter-btn[data-axis="enviro"].active { background: rgba(0,191,99,0.2); border-color: #00bf63; color: #4dff99; }
  .mv-filter-btn[data-axis="socio"].active { background: rgba(179,42,85,0.3); border-color: #b32a55; color: #ff6b99; }

  .mv-stats {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 10;
    display: flex;
    gap: 24px;
  }

  .mv-stat { text-align: center; }

  .mv-stat-number {
    display: block;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.3rem;
    color: #fff;
  }

  .mv-stat-label {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .mv-timeline {
    position: absolute;
    bottom: 16px;
    left: 20px;
    right: 20px;
    height: 30px;
    z-index: 10;
    pointer-events: none;
  }

  .mv-tooltip {
    position: fixed;
    padding: 6px 14px;
    background: rgba(10,14,26,0.92);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    font-size: 0.7rem;
    font-family: var(--font-heading);
    color: rgba(255,255,255,0.85);
    pointer-events: none;
    z-index: 300;
    opacity: 0;
    transition: opacity 0.15s;
    white-space: nowrap;
    max-width: 280px;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mv-tooltip.show { opacity: 1; }

  @media (max-width: 768px) {
    .mv-axis-filter { top: 12px; right: 12px; gap: 4px; }
    .mv-filter-btn { padding: 4px 8px; font-size: 9px; }
    .mv-stats { top: 12px; left: 12px; gap: 16px; }
    .mv-stat-number { font-size: 1rem; }
  }
</style>

<script is:inline type="module">
  const COLORS = { techno: '#2a55b3', enviro: '#00bf63', socio: '#b32a55' };

  const subjects = [
    { title: 'Décarbonation du shipping : où en est-on vraiment ?', axis: 'enviro' },
    { title: "L'IA dans le maritime : hype ou révolution ?", axis: 'techno' },
    { title: 'Archipel France : 11 millions de km² oubliés', axis: 'socio' },
    { title: 'CII, EEXI, EU MRV : le marin face à la réglementation', axis: 'enviro' },
    { title: 'Les câbles sous-marins, artères du monde digital', axis: 'techno' },
    { title: 'Hissez Mots : vocabulaire maritime', axis: 'socio' },
    { title: 'Le maritime dans la culture française', axis: 'socio' },
    { title: 'Comment devenir officier de marine marchande', axis: 'socio' },
    { title: 'La ZEE française, un empire invisible', axis: 'socio' },
    { title: 'Cyberdéfense maritime : le prochain front', axis: 'techno' },
    { title: 'EMR : les hydroliennes ont-elles un avenir ?', axis: 'enviro' },
    { title: 'La transition technologique du maritime', axis: 'techno' },
    { title: 'Géopolitique des mers', axis: 'socio' },
    { title: 'Le sauvetage en mer à l\'ère du digital', axis: 'techno' },
    { title: 'Limites planétaires : au-delà du climat', axis: 'enviro' },
    { title: 'Les grandes découvertes : premières startups', axis: 'socio' },
    { title: 'Data maritime : une catastrophe révélée', axis: 'techno' },
    { title: 'GASPE : le service public maritime', axis: 'socio' },
    { title: 'La propulsion vélique, un vent nouveau', axis: 'enviro' },
    { title: 'NRL La Réunion : construire l\'impossible', axis: 'techno' }
  ];

  function generatePubs() {
    const pubs = [];
    for (let year = 2013; year <= 2026; year++) {
      let count;
      if (year <= 2017) count = Math.floor(Math.random() * 3) + 1;
      else if (year <= 2020) count = Math.floor(Math.random() * 5) + 3;
      else if (year <= 2023) count = Math.floor(Math.random() * 10) + 8;
      else count = Math.floor(Math.random() * 15) + 12;
      for (let i = 0; i < count; i++) {
        const t = subjects[Math.floor(Math.random() * subjects.length)];
        const reach = year <= 2020 ? Math.floor(Math.random() * 5000) + 500 : Math.floor(Math.random() * 50000) + 2000;
        pubs.push({ title: t.title, axis: t.axis, year, reach, date: new Date(year, Math.floor(Math.random()*12), Math.floor(Math.random()*28)+1) });
      }
    }
    return pubs.sort((a,b) => a.date - b.date);
  }

  const pubs = generatePubs();
  const container = document.getElementById('mediaviz-container');
  const canvas = document.getElementById('mediaviz-canvas');
  const ctx = canvas.getContext('2d');
  const tooltip = document.getElementById('mv-tooltip');

  let W, H, positions = [], activeAxis = 'all', hoveredPub = null;
  const mousePos = { x: -999, y: -999 };
  const startTime = Date.now();

  function resize() {
    const rect = container.getBoundingClientRect();
    W = rect.width; H = rect.height;
    canvas.width = W * Math.min(devicePixelRatio, 2);
    canvas.height = H * Math.min(devicePixelRatio, 2);
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.setTransform(1,0,0,1,0,0);
    ctx.scale(Math.min(devicePixelRatio,2), Math.min(devicePixelRatio,2));
    layout();
  }

  function layout() {
    const tStart = new Date(2013,0,1).getTime(), tEnd = new Date(2027,0,1).getTime(), tRange = tEnd - tStart;
    const mL = 30, mR = 30, mT = 60, mB = 50;
    const uW = W - mL - mR, uH = H - mT - mB;
    positions = pubs.map(p => {
      const x = mL + ((p.date.getTime() - tStart) / tRange) * uW;
      let yBase;
      if (p.axis === 'techno') yBase = mT + uH * 0.2;
      else if (p.axis === 'enviro') yBase = mT + uH * 0.5;
      else yBase = mT + uH * 0.8;
      const y = yBase + (Math.random() - 0.5) * uH * 0.25;
      const size = Math.max(2.5, Math.min(10, Math.sqrt(p.reach) / 35));
      return { pub: p, x, y, size, opacity: 1, targetOpacity: 1 };
    });
  }

  resize();
  const ro = new ResizeObserver(resize);
  ro.observe(container);

  // Filters
  document.querySelectorAll('#mv-axis-filter .mv-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#mv-axis-filter .mv-filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeAxis = btn.dataset.axis;
      positions.forEach(ap => { ap.targetOpacity = (activeAxis === 'all' || ap.pub.axis === activeAxis) ? 1 : 0.05; });
      updateStats();
    });
  });

  function updateStats() {
    const vis = positions.filter(a => a.targetOpacity > 0.5);
    document.getElementById('mv-stat-total').textContent = vis.length;
    const reach = vis.reduce((s,a) => s + a.pub.reach, 0);
    document.getElementById('mv-stat-reach').textContent = reach > 1e6 ? (reach/1e6).toFixed(1)+'M' : reach > 1e3 ? Math.floor(reach/1e3)+'K' : reach;
  }
  updateStats();

  // Mouse
  container.addEventListener('pointermove', e => {
    const r = container.getBoundingClientRect();
    mousePos.x = e.clientX - r.left;
    mousePos.y = e.clientY - r.top;
    tooltip.style.left = (e.clientX + 14) + 'px';
    tooltip.style.top = (e.clientY - 10) + 'px';
  });
  container.addEventListener('pointerleave', () => { mousePos.x = -999; mousePos.y = -999; });

  function render() {
    requestAnimationFrame(render);
    const time = (Date.now() - startTime) / 1000;
    ctx.fillStyle = '#0a0e1a';
    ctx.fillRect(0, 0, W, H);

    hoveredPub = null;

    // Connections
    ctx.globalAlpha = 0.06;
    for (let i = 0; i < positions.length; i++) {
      const a = positions[i];
      if (a.opacity < 0.3) continue;
      for (let j = i+1; j < Math.min(i+4, positions.length); j++) {
        const b = positions[j];
        if (b.opacity < 0.3 || a.pub.axis !== b.pub.axis) continue;
        const d = Math.hypot(a.x-b.x, a.y-b.y);
        if (d < 60) {
          ctx.strokeStyle = COLORS[a.pub.axis];
          ctx.lineWidth = 0.5;
          ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
        }
      }
    }
    ctx.globalAlpha = 1;

    // Dots
    positions.forEach((ap, i) => {
      ap.opacity += (ap.targetOpacity - ap.opacity) * 0.08;
      if (ap.opacity < 0.02) return;
      const d = Math.hypot(mousePos.x - ap.x, mousePos.y - ap.y);
      const isH = d < ap.size + 6 && ap.opacity > 0.5;
      if (isH) hoveredPub = ap;
      const sz = ap.size * (1 + Math.sin(time*0.8+i*0.3)*0.08) * (isH ? 1.4 : 1);
      ctx.globalAlpha = ap.opacity;
      if (sz > 4 || isH) {
        const g = ctx.createRadialGradient(ap.x,ap.y,0,ap.x,ap.y,sz*3);
        g.addColorStop(0, COLORS[ap.pub.axis]+'30');
        g.addColorStop(1, 'transparent');
        ctx.fillStyle = g;
        ctx.beginPath(); ctx.arc(ap.x,ap.y,sz*3,0,Math.PI*2); ctx.fill();
      }
      ctx.fillStyle = COLORS[ap.pub.axis];
      ctx.beginPath(); ctx.arc(ap.x,ap.y,sz,0,Math.PI*2); ctx.fill();
      ctx.globalAlpha = 1;
    });

    // Tooltip
    if (hoveredPub) {
      tooltip.textContent = hoveredPub.pub.title + ' — ' + hoveredPub.pub.year;
      tooltip.classList.add('show');
      container.style.cursor = 'pointer';
    } else {
      tooltip.classList.remove('show');
      container.style.cursor = 'default';
    }

    // Timeline
    ctx.globalAlpha = 0.3;
    ctx.strokeStyle = 'rgba(255,255,255,0.15)';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(30, H-35); ctx.lineTo(W-30, H-35); ctx.stroke();
    for (let y = 2013; y <= 2026; y++) {
      const x = 30 + ((y-2013)/(2027-2013)) * (W-60);
      ctx.fillStyle = 'rgba(255,255,255,0.35)';
      ctx.font = '9px Poppins, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(y, x, H-20);
    }

    // Axis labels
    ctx.font = '600 9px Poppins, sans-serif';
    ctx.textAlign = 'left';
    const mT = 60, uH = H - mT - 50;
    ctx.fillStyle = COLORS.techno; ctx.fillText('TECHNO', 6, mT + uH*0.2);
    ctx.fillStyle = COLORS.enviro; ctx.fillText('ENVIRO', 6, mT + uH*0.5);
    ctx.fillStyle = COLORS.socio; ctx.fillText('SOCIO', 6, mT + uH*0.8);
    ctx.globalAlpha = 1;
  }

  render();
</script>
