            {title: 'Les opportunit\u00e9s d\'impact dans l\'engagement associatif maritime', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2025, 6, 15), reach: 15000, excerpt: 'Jeune Marine'},
            {title: 'Ukraine, la marine de commerce \u00e0 l\'\u00e9preuve de la guerre', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2025, 6, 1), reach: 18000, excerpt: 'Marine & Oc\u00e9ans N287'},
            {title: 'La France, terrienne appel\u00e9e par le large', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2025, 5, 14), reach: 15000, excerpt: 'Jeune Marine'},
            {title: 'Pour une gouvernance de l\'oc\u00e9an paritaire et inclusive', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2025, 5, 5), reach: 20000, excerpt: 'Vert'},
            {title: 'Les Ap\u00e9ritifs de la mer rassemblent les marins et remettent l\'humain au centre', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2025, 4, 6), reach: 20000, excerpt: 'Le Marin'},
            {title: 'Drones marins: la nouvelle donne', axis: 'techno', channel: 'presse', type: 'Article presse', date: new Date(2025, 4, 3), reach: 18000, excerpt: 'Conflits'},
            {title: 'La mer, une chance pour la France!', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2025, 3, 1), reach: 18000, excerpt: 'Marine & Oc\u00e9ans N286'},
            {title: 'Ce d\u00e9versement d\'eaux us\u00e9es par un navire de croisi\u00e8re est-il r\u00e9el?', axis: 'enviro', channel: 'presse', type: 'Article presse', date: new Date(2025, 2, 27), reach: 150000, excerpt: 'TF1'},
            {title: 'Oc\u00e9ans: autoroutes digitales strat\u00e9giques', axis: 'techno', channel: 'presse', type: 'Article presse', date: new Date(2025, 2, 5), reach: 18000, excerpt: 'Conflits'},
            {title: 'Les \u00e9quipages promotionnels ENSM', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2024, 11, 23), reach: 15000, excerpt: 'Jeune Marine'},
            {title: 'La vague sc\u00e9l\u00e9rate du num\u00e9rique dans le maritime', axis: 'techno', channel: 'presse', type: 'Article presse', date: new Date(2024, 9, 22), reach: 15000, excerpt: 'Jeune Marine'},
            {title: 'De la conqu\u00eate \u00e0 la connaissance de l\'Oc\u00e9an', axis: 'enviro', channel: 'presse', type: 'Article presse', date: new Date(2024, 8, 1), reach: 18000, excerpt: 'Marine & Oc\u00e9ans N284'},
            {title: 'Les Ap\u00e9ritifs de la Mer ouvrent leur site Internet', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2024, 4, 30), reach: 12000, excerpt: 'Jeune Marine'},
            {title: 'EU ETS vs FuelEU', axis: 'enviro', channel: 'presse', type: 'Article presse', date: new Date(2024, 4, 15), reach: 15000, excerpt: 'Jeune Marine'},
            {title: 'La Fondation ENSM r\u00e9v\u00e8le sa m\u00e9thode', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2024, 3, 10), reach: 25000, excerpt: 'Mer & Marine'},
            {title: 'L\'ENSM: nouvelle vague', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2024, 2, 22), reach: 15000, excerpt: 'Jeune Marine'},
            {title: 'L\'intelligence artificielle & le maritime', axis: 'techno', channel: 'presse', type: 'Article presse', date: new Date(2023, 11, 14), reach: 15000, excerpt: 'Jeune Marine'},
            {title: 'Colomban Monnier \u00e9lu pr\u00e9sident de la Fondation ENSM', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2023, 8, 19), reach: 20000, excerpt: 'Le Marin'},
            {title: 'Un oc\u00e9an de bienveillance', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2023, 8, 11), reach: 15000, excerpt: 'Jeune Marine'},
            {title: 'Appel aux Jeunes du Maritime', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2023, 3, 12), reach: 15000, excerpt: 'Jeune Marine'},
            {title: 'Ocean degradation stripes', axis: 'enviro', channel: 'presse', type: 'Article presse', date: new Date(2023, 1, 24), reach: 15000, excerpt: 'Jeune Marine'},
        ];

        // Add real conferences and press
        conferences.forEach(function(c) {
            pubs.push({
                id: pubs.length,
                title: c.title, axis: c.axis, channel: c.channel, type: c.type,
                tier: getPubTier(c.channel),
                date: c.date, year: c.date.getFullYear(),
                reach: c.reach, excerpt: c.excerpt
            });
        });
        press.forEach(function(p) {
            pubs.push({
                id: pubs.length,
                title: p.title, axis: p.axis, channel: p.channel, type: p.type,
                tier: getPubTier(p.channel),
                date: p.date, year: p.date.getFullYear(),
                reach: p.reach, excerpt: p.excerpt
            });
        });

        // -- GENERATED: Social media posts (LinkedIn, Instagram, YouTube) --
        var socialSubjects = [
            { title: "L'IA dans le maritime : hype ou revolution ?", axis: 'techno', channel: 'linkedin', type: 'Analyse' },
            { title: 'Les cables sous-marins, arteres du monde digital', axis: 'techno', channel: 'linkedin', type: 'Carte' },
            { title: 'Data maritime : 600 navires analyses', axis: 'techno', channel: 'linkedin', type: 'Analyse' },
            { title: 'Logbooks electroniques : la fin du papier a bord', axis: 'techno', channel: 'linkedin', type: 'Analyse' },
            { title: 'Navires autonomes : fantasme ou realite 2030 ?', axis: 'techno', channel: 'linkedin', type: 'Analyse' },
            { title: 'IoT maritime : chaque capteur raconte une histoire', axis: 'techno', channel: 'linkedin', type: 'Education' },
            { title: 'Decarbonation du shipping : ou en est-on ?', axis: 'enviro', channel: 'linkedin', type: 'Analyse' },
            { title: 'CII, EEXI, EU MRV : le marin face a la reglementation', axis: 'enviro', channel: 'linkedin', type: 'Education' },
            { title: 'EMR : les hydroliennes ont-elles un avenir ?', axis: 'enviro', channel: 'linkedin', type: 'Analyse' },
            { title: 'Limites planetaires : au-dela du climat', axis: 'enviro', channel: 'linkedin', type: 'Education' },
            { title: 'Propulsion velique : retour vers le futur', axis: 'enviro', channel: 'linkedin', type: 'Analyse' },
            { title: 'Scrubbers vs. LNG : faux debat ?', axis: 'enviro', channel: 'linkedin', type: 'Analyse' },
            { title: 'Archipel France : 11M de km2 oublies', axis: 'socio', channel: 'linkedin', type: 'Appel' },
            { title: 'Les grandes decouvertes : premieres startups', axis: 'socio', channel: 'linkedin', type: 'Inspiration' },
            { title: 'GASPE : le service public maritime en France', axis: 'socio', channel: 'linkedin', type: 'Education' },
            { title: 'Oceans : 3e employeur mondial ignore', axis: 'socio', channel: 'linkedin', type: 'Analyse' },
            { title: 'La mer nourrit, transporte, connecte : qui le sait ?', axis: 'socio', channel: 'linkedin', type: 'Appel' },
            { title: 'Le maritime dans la culture francaise', axis: 'socio', channel: 'instagram', type: 'Inspiration' },
            { title: 'Petit Bateau, JPG et le marin', axis: 'socio', channel: 'instagram', type: 'Inspiration' },
            { title: 'NRL La Reunion : construire l\'impossible', axis: 'techno', channel: 'instagram', type: 'Inspiration' },
            { title: 'Infographie : 1 objet sur 2 a pris la mer', axis: 'socio', channel: 'instagram', type: 'Education' },
            { title: 'Biodiversite abyssale : l\'inconnu sous nos pieds', axis: 'enviro', channel: 'instagram', type: 'Inspiration' },
            { title: 'Hissez Mots : "Amarrer"', axis: 'socio', channel: 'youtube', type: 'Video' },
            { title: 'Comment devenir officier de marine marchande', axis: 'socio', channel: 'youtube', type: 'Education' },
            { title: 'Visite du CMA CGM Jacques Saade', axis: 'techno', channel: 'youtube', type: 'Video' },
            { title: 'Hissez Mots : "Tribord"', axis: 'socio', channel: 'youtube', type: 'Video' },
            { title: '24h a bord d\'un porte-conteneurs', axis: 'socio', channel: 'youtube', type: 'Video' },
        ];

        // Seeded pseudo-random for reproducibility
        var seed = 42;
        function rand() { seed = (seed * 16807 + 0) % 2147483647; return (seed - 1) / 2147483646; }

        for (var year = YEAR_MIN; year <= YEAR_MAX; year++) {
            var count;
            if (year <= 2015) count = Math.floor(rand() * 2) + 1;
            else if (year <= 2018) count = Math.floor(rand() * 4) + 2;
            else if (year <= 2020) count = Math.floor(rand() * 6) + 4;
            else if (year <= 2023) count = Math.floor(rand() * 10) + 7;
            else count = Math.floor(rand() * 14) + 10;

            for (var i = 0; i < count; i++) {
                var template = socialSubjects[Math.floor(rand() * socialSubjects.length)];
                var month = Math.floor(rand() * 12);
                var day = Math.floor(rand() * 28) + 1;
                var reach = year <= 2019
                    ? Math.floor(rand() * 5000) + 300
                    : Math.floor(rand() * 50000) + 2000;

                pubs.push({
                    id: pubs.length,
                    title: template.title,
                    axis: template.axis,
                    channel: template.channel,
                    type: template.type,
                    tier: getPubTier(template.channel),
                    date: new Date(year, month, day),
                    year: year,
                    reach: reach,
                    excerpt: 'Analyse et reflexion sur les enjeux maritimes contemporains.'
                });
            }
        }

        return pubs.sort(function(a, b) { return a.date - b.date; });
    }

    var publications = generatePublications();

    // =============================================
    // SCALE REACH TO HIT PER-YEAR TARGETS
    // =============================================
    (function scaleReachValues() {
        var viewsPerPosition = {
            2022: 2000,
            2023: 4000,
            2024: 6800,
            2025: 8000,
            2026: 8000,
        };
        publications.forEach(function(p) {
            p.reach = viewsPerPosition[p.year] || 0;
        });
    })();

    // =============================================
    // CANVAS SETUP
    // =============================================
    var wrapper = document.getElementById('mediaviz-wrapper');
    var canvas = document.getElementById('mediaviz-canvas');
    var ctx = canvas.getContext('2d');
    var W, H;

    function resize() {
        var rect = wrapper.getBoundingClientRect();
        W = rect.width;
        H = rect.height;
        var dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = W * dpr;
        canvas.height = H * dpr;
        canvas.style.width = W + 'px';
        canvas.style.height = H + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        layoutPublications();
        updateVisibility();
    }

    // =============================================
    // STATE
    // =============================================
    var activeAxis = 'all';
    var activeChannels = new Set(['linkedin', 'instagram', 'youtube', 'presse', 'conference']);
    var hoveredPub = null;
    var hoveredPubIdx = -1;
    var animatedPositions = [];
    var startTime = Date.now();
    var mousePos = { x: -9999, y: -9999 };

    // =============================================
    // LAYOUT
    // =============================================
    function layoutPublications() {
        var marginLeft = 60;
        var marginRight = 30;
        var marginTop = 58;
        var marginBottom = 50;

        var usableW = W - marginLeft - marginRight;
        var usableH = H - marginTop - marginBottom;

        var timelineStart = new Date(YEAR_MIN, 0, 1).getTime();
        var timelineEnd = new Date(YEAR_MAX + 1, 0, 1).getTime();
        var timeRange = timelineEnd - timelineStart;

        // Seeded random for consistent positions
        var seed = 7;
        function rand() { seed = (seed * 16807 + 0) % 2147483647; return (seed - 1) / 2147483646; }

        animatedPositions = publications.map(function(pub, i) {
            var tNorm = (pub.date.getTime() - timelineStart) / timeRange;
            var x = marginLeft + tNorm * usableW;

            // Vertical position grouped by axis (like prototype)
            var yBase;
            if (pub.axis === 'techno') yBase = marginTop + usableH * 0.2;
            else if (pub.axis === 'enviro') yBase = marginTop + usableH * 0.5;
            else yBase = marginTop + usableH * 0.8;

            var yJitter = (rand() - 0.5) * usableH * 0.25;
            var y = yBase + yJitter;

            var size;
            if (pub.tier === 'media') {
                size = Math.max(4, Math.min(8, Math.sqrt(pub.reach) / 35));
            } else if (pub.tier === 'conference') {
                size = Math.max(3.5, Math.min(7, Math.sqrt(pub.reach) / 40));
            } else {
                size = Math.max(2, Math.min(4.5, Math.sqrt(pub.reach) / 55));
            }

            return {
                pub: pub, x: x, y: y,
                baseX: x, baseY: y,
                size: size,
                opacity: 1,
                targetOpacity: 1,
                _highlight: false
            };
        });
    }

    // =============================================
    // FILTER LOGIC (no scroll — all visible by default)
    // =============================================
    function isVisible(ap) {
        var axisMatch = activeAxis === 'all' || ap.pub.axis === activeAxis;
        var channelMatch = activeChannels.has(ap.pub.channel);
        return axisMatch && channelMatch;
    }

    function updateVisibility() {
        animatedPositions.forEach(function(ap) {
            ap.targetOpacity = isVisible(ap) ? 1 : 0.03;
        });
        updateStats();
    }

    function updateStats() {
        var visible = animatedPositions.filter(function(ap) { return ap.targetOpacity > 0.5; });
        var totalEl = document.getElementById('mv-stat-total');
        if (totalEl) totalEl.textContent = visible.length;

        var mediaCount = visible.filter(function(ap) { return ap.pub.tier === 'media'; }).length;
        var mediaEl = document.getElementById('mv-stat-media');
        if (mediaEl) mediaEl.textContent = mediaCount;

        var cumulativeReach = 0;
        visible.forEach(function(ap) { cumulativeReach += ap.pub.reach; });
        var reachEl = document.getElementById('mv-stat-reach');
        if (reachEl) {
            reachEl.textContent = cumulativeReach > 1000000
                ? (cumulativeReach / 1000000).toFixed(1) + 'M'
                : cumulativeReach > 1000
                    ? Math.floor(cumulativeReach / 1000) + 'K'
                    : cumulativeReach;
        }
    }

    // =============================================
    // AXIS FILTER BUTTONS
    // =============================================
    document.querySelectorAll('#mediaviz-wrapper .mv-filter-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('#mediaviz-wrapper .mv-filter-btn').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            activeAxis = btn.dataset.axis;
            updateVisibility();
        });
    });

    // =============================================
    // CHANNEL FILTER BUTTONS
    // =============================================
    var ALL_CHANNELS = ['linkedin', 'instagram', 'youtube', 'presse', 'conference'];

    document.querySelectorAll('#mediaviz-wrapper .mv-channel-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var channel = btn.dataset.channel;
            if (channel === 'all') {
                var allActive = activeChannels.size === ALL_CHANNELS.length;
                if (allActive) {
                    activeChannels.clear();
                    document.querySelectorAll('#mediaviz-wrapper .mv-channel-btn').forEach(function(b) { b.classList.remove('active'); });
                } else {
                    activeChannels = new Set(ALL_CHANNELS);
                    document.querySelectorAll('#mediaviz-wrapper .mv-channel-btn').forEach(function(b) { b.classList.add('active'); });
                }
            } else {
                if (activeChannels.has(channel)) {
                    activeChannels.delete(channel);
                    btn.classList.remove('active');
                } else {
                    activeChannels.add(channel);
                    btn.classList.add('active');
                }
                var allBtn = document.querySelector('#mediaviz-wrapper .mv-channel-btn[data-channel="all"]');
                if (activeChannels.size === ALL_CHANNELS.length) {
                    allBtn.classList.add('active');
                } else {
                    allBtn.classList.remove('active');
                }
            }
            updateVisibility();
        });
    });

    // =============================================
    // YEAR LABELS
    // =============================================
    function buildYearLabels() {
        var container = document.getElementById('mv-year-labels');
        if (!container) return;
        container.innerHTML = '';
        for (var y = YEAR_MIN; y <= YEAR_MAX; y++) {
            var lbl = document.createElement('div');
            lbl.className = 'mv-year-label';
            lbl.textContent = y;
            lbl.dataset.year = y;
            container.appendChild(lbl);
        }
    }
    buildYearLabels();

    // =============================================
    // DENSITY BAR (like prototype)
    // =============================================
    function buildDensityBar() {
        var bar = document.getElementById('mv-density-bar');
        if (!bar) return;
        bar.innerHTML = '';
        var years = YEAR_MAX + 1 - YEAR_MIN;
        var segments = years * 4; // quarterly
        for (var i = 0; i < segments; i++) {
            var startDate = new Date(YEAR_MIN + Math.floor(i / 4), (i % 4) * 3, 1);
            var endDate = new Date(YEAR_MIN + Math.floor((i + 1) / 4), ((i + 1) % 4) * 3, 1);
            var count = publications.filter(function(p) {
                return p.date >= startDate && p.date < endDate;
            }).length;
            var seg = document.createElement('div');
            seg.className = 'mv-density-seg';
            var intensity = Math.min(1, count / 8);
            seg.style.background = 'rgba(255, 255, 255, ' + (intensity * 0.4) + ')';
            bar.appendChild(seg);
        }
    }
    buildDensityBar();

    // =============================================
    // MOUSE ON CANVAS
    // =============================================
    canvas.addEventListener('mousemove', function(e) {
        mousePos.x = e.clientX;
        mousePos.y = e.clientY;
    });

    canvas.addEventListener('mouseleave', function() {
        mousePos.x = -9999;
        mousePos.y = -9999;
    });

    canvas.addEventListener('click', function() {
        if (hoveredPub) {
            var popup = document.getElementById('mv-detail-popup');
            var wrapperRect = wrapper.getBoundingClientRect();
            var popupX = Math.min(mousePos.x - wrapperRect.left + 16, W - 300);
            var popupY = Math.min(mousePos.y - wrapperRect.top - 16, H - 200);
            popup.style.display = 'block';
            popup.style.left = popupX + 'px';
            popup.style.top = popupY + 'px';

            var typeEl = document.getElementById('mv-popup-type');
            typeEl.textContent = hoveredPub.type;
            typeEl.style.color = COLORS[hoveredPub.axis];

            var tierEl = document.getElementById('mv-popup-tier');
            tierEl.textContent = hoveredPub.tier === 'media' ? 'PRESSE' : hoveredPub.tier === 'conference' ? 'CONF' : 'SOCIAL';
            tierEl.className = 'mv-pub-tier ' + hoveredPub.tier;

            document.getElementById('mv-popup-title').textContent = hoveredPub.title;
            document.getElementById('mv-popup-channel').textContent = CHANNELS[hoveredPub.channel].label + ' \u00B7 ' + hoveredPub.date.toLocaleDateString('fr-FR');
            document.getElementById('mv-popup-excerpt').textContent = hoveredPub.excerpt;
            document.getElementById('mv-popup-date').textContent = hoveredPub.date.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' });
        } else {
            document.getElementById('mv-detail-popup').style.display = 'none';
        }
    });

    document.addEventListener('click', function(e) {
        if (!e.target.closest('.mv-detail-popup') && !e.target.closest('#mediaviz-canvas')) {
            var popup = document.getElementById('mv-detail-popup');
            if (popup) popup.style.display = 'none';
        }
    });

    // =============================================
    // RENDER
    // =============================================
    function render() {
        requestAnimationFrame(render);
        var time = (Date.now() - startTime) / 1000;

        ctx.fillStyle = '#0a0e1a';
        ctx.fillRect(0, 0, W, H);

        var marginTop = 58;
        var marginBottom = 50;
        var marginLeft = 60;
        var marginRight = 30;
        var usableH = H - marginTop - marginBottom;
        var usableW = W - marginLeft - marginRight;

        // Background gradient zones for axes (like prototype)
        if (activeAxis === 'all') {
            var grad1 = ctx.createLinearGradient(0, marginTop, 0, marginTop + usableH);
            grad1.addColorStop(0, 'rgba(42, 85, 179, 0.04)');
            grad1.addColorStop(0.4, 'rgba(0, 191, 99, 0.03)');
            grad1.addColorStop(0.8, 'rgba(179, 42, 85, 0.04)');
            grad1.addColorStop(1, 'transparent');
            ctx.fillStyle = grad1;
            ctx.fillRect(0, 0, W, H);
        }

        // Draw year grid lines
        var timelineStart = new Date(YEAR_MIN, 0, 1).getTime();
        var timelineEnd = new Date(YEAR_MAX + 1, 0, 1).getTime();
        var timeRange = timelineEnd - timelineStart;
        ctx.globalAlpha = 0.1;
        ctx.strokeStyle = 'rgba(255,255,255,0.5)';
        ctx.lineWidth = 0.5;
        for (var y = YEAR_MIN; y <= YEAR_MAX; y++) {
            var tNorm = (new Date(y, 0, 1).getTime() - timelineStart) / timeRange;
            var gx = marginLeft + tNorm * usableW;
            ctx.beginPath();
            ctx.moveTo(gx, marginTop);
            ctx.lineTo(gx, marginTop + usableH);
            ctx.stroke();
        }
        ctx.globalAlpha = 1;

        // Hovered pub detection
        hoveredPub = null;
        hoveredPubIdx = -1;

        // Convert mouse coords to canvas-local coords
        var wrapperRect = wrapper.getBoundingClientRect();
        var localMouseX = mousePos.x - wrapperRect.left;
        var localMouseY = mousePos.y - wrapperRect.top;

        for (var idx = animatedPositions.length - 1; idx >= 0; idx--) {
            var ap = animatedPositions[idx];
            if (ap.opacity < 0.3) continue;
            var dist = Math.hypot(localMouseX - ap.x, localMouseY - ap.y);
            var hitRadius = ap.size + (ap.pub.tier === 'media' ? 8 : 5);
            if (dist < hitRadius) {
                hoveredPub = ap.pub;
                hoveredPubIdx = idx;
                break;
            }
        }

        // Draw connections between nearby same-axis publications
        ctx.globalAlpha = 0.05;
        for (var ci = 0; ci < animatedPositions.length; ci++) {
            var a = animatedPositions[ci];
            if (a.opacity < 0.3) continue;
            for (var cj = ci + 1; cj < Math.min(ci + 8, animatedPositions.length); cj++) {
                var b = animatedPositions[cj];
                if (b.opacity < 0.3 || a.pub.axis !== b.pub.axis) continue;
                var cdist = Math.hypot(a.x - b.x, a.y - b.y);
                if (cdist < 50) {
                    ctx.strokeStyle = COLORS[a.pub.axis];
                    ctx.lineWidth = 0.4;
                    ctx.beginPath();
                    ctx.moveTo(a.x, a.y);
                    ctx.lineTo(b.x, b.y);
                    ctx.stroke();
                }
            }
        }
        ctx.globalAlpha = 1;

        // Highlight connections for hovered pub
        if (hoveredPubIdx >= 0) {
            var hp = animatedPositions[hoveredPubIdx];
            ctx.globalAlpha = 0.2;
            animatedPositions.forEach(function(ap, i) {
                if (i === hoveredPubIdx || ap.opacity < 0.3) return;
                if (ap.pub.axis !== hp.pub.axis) return;
                var hdist = Math.hypot(hp.x - ap.x, hp.y - ap.y);
                if (hdist < 120) {
                    ctx.strokeStyle = COLORS[hp.pub.axis + 'Light'] || COLORS[hp.pub.axis];
                    ctx.lineWidth = 1;
                    ctx.beginPath();
                    ctx.moveTo(hp.x, hp.y);
                    ctx.lineTo(ap.x, ap.y);
                    ctx.stroke();
                    ap._highlight = true;
                }
            });
            ctx.globalAlpha = 1;
        }

        // Draw publications
        animatedPositions.forEach(function(ap, i) {
            // Smooth opacity transition
            ap.opacity += (ap.targetOpacity - ap.opacity) * 0.12;
            if (ap.opacity < 0.02) { ap._highlight = false; return; }

            var color = COLORS[ap.pub.axis];
            var lightColor = COLORS[ap.pub.axis + 'Light'];

            var isHovered = (i === hoveredPubIdx);
            var isHighlighted = ap._highlight;
            ap._highlight = false;

            var isMedia = ap.pub.tier === 'media';
            var isConf = ap.pub.tier === 'conference';

            // Breathing animation (like prototype)
            var breathe = Math.sin(time * 0.8 + i * 0.3) * 0.3;
            var scaleFactor = (1 + breathe * 0.1) * (isHovered ? 1.4 : isHighlighted ? 1.15 : 1);
            var displaySize = ap.size * scaleFactor;

            ctx.globalAlpha = ap.opacity;

            // Glow effect for larger dots or hovered (like prototype)
            if ((ap.size > 4 || isHovered) && (isMedia || isConf || isHovered)) {
                var glowRadius = displaySize * 3;
                var glow = ctx.createRadialGradient(ap.x, ap.y, 0, ap.x, ap.y, glowRadius);
                glow.addColorStop(0, color + '40');
                glow.addColorStop(1, 'transparent');
                ctx.fillStyle = glow;
                ctx.beginPath();
                ctx.arc(ap.x, ap.y, glowRadius, 0, Math.PI * 2);
                ctx.fill();
            }

            if (isMedia) {
                var r = displaySize * 0.9;
                ctx.fillStyle = isHovered ? lightColor : color;
                ctx.beginPath();
                ctx.arc(ap.x, ap.y, r, 0, Math.PI * 2);
                ctx.fill();
                ctx.strokeStyle = isHovered ? '#ffffff' : 'rgba(255,255,255,0.6)';
                ctx.lineWidth = 1;
                ctx.stroke();
            } else if (isConf) {
                var rc = displaySize * 0.9;
                ctx.fillStyle = isHovered ? lightColor : color;
                ctx.beginPath();
                ctx.arc(ap.x, ap.y, rc, 0, Math.PI * 2);
                ctx.fill();
            } else {
                var rs = Math.max(1.5, displaySize * 0.55);
                ctx.fillStyle = isHovered ? lightColor : color;
                ctx.globalAlpha = ap.opacity * (isHovered ? 0.9 : 0.5);
                ctx.beginPath();
                ctx.arc(ap.x, ap.y, rs, 0, Math.PI * 2);
                ctx.fill();
                ctx.globalAlpha = ap.opacity;
            }

            // Label on hover
            if (isHovered && ap.opacity > 0.5) {
                ctx.globalAlpha = 1;
                ctx.fillStyle = '#ffffff';
                ctx.font = '600 10px Poppins, sans-serif';
                ctx.textAlign = 'center';
                var labelText = ap.pub.title.length > 45 ? ap.pub.title.substring(0, 45) + '...' : ap.pub.title;
                ctx.fillText(labelText, ap.x, ap.y - displaySize - 14);

                ctx.fillStyle = 'rgba(255,255,255,0.4)';
                ctx.font = '9px Poppins, sans-serif';
                var tierLabel = isMedia ? ' PRESSE' : isConf ? ' CONF' : '';
                ctx.fillText(CHANNELS[ap.pub.channel].label + ' \u00B7 ' + ap.pub.year + tierLabel, ap.x, ap.y - displaySize - 4);

                canvas.style.cursor = 'pointer';
            }

            ctx.globalAlpha = 1;
        });

        if (!hoveredPub) canvas.style.cursor = 'default';

        // Draw axis labels on left (like prototype)
        ctx.globalAlpha = 0.3;
        ctx.font = '600 9px Poppins, sans-serif';
        ctx.textAlign = 'left';
        ctx.fillStyle = COLORS.techno;
        ctx.fillText('TECHNOLOGIQUE', 8, marginTop + usableH * 0.2);
        ctx.fillStyle = COLORS.enviro;
        ctx.fillText('ENVIRONNEMENTALE', 8, marginTop + usableH * 0.5);
        ctx.fillStyle = COLORS.socio;
        ctx.fillText('SOCIOCULTURELLE', 8, marginTop + usableH * 0.8);
        ctx.globalAlpha = 1;
    }

    // =============================================
    // INIT
    // =============================================
    resize();
    updateStats();

    var ro = new ResizeObserver(function() {
        resize();
        buildYearLabels();
    });
    ro.observe(wrapper);

    render();

    // Keyboard shortcut: Escape to close popup
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            var popup = document.getElementById('mv-detail-popup');
            if (popup) popup.style.display = 'none';
        }
    });
})();
</script>
