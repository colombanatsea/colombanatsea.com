---
/**
 * MediaViz — Constellation mediatique interactive
 * Adapte depuis prototypes/proto4-mediaviz/index.html
 * Fonctionne dans un conteneur (pas pleine page) — toutes les pubs visibles, filtrage par axe/canal
 */
---

<div class="mediaviz-wrapper" id="mediaviz-wrapper">
  <canvas id="mediaviz-canvas"></canvas>

  <!-- Top bar: title + filters + stats -->
  <div class="mv-top-bar">
    <div class="mv-title">Prises de position<span>2013 -- 2026</span></div>
    <div class="mv-filters" id="mv-filters">
      <button class="mv-filter-btn active" data-axis="all">Tous</button>
      <button class="mv-filter-btn" data-axis="techno">Techno</button>
      <button class="mv-filter-btn" data-axis="enviro">Enviro</button>
      <button class="mv-filter-btn" data-axis="socio">Socio</button>
      <div class="mv-filter-sep"></div>
      <button class="mv-channel-btn active" data-channel="all">Tous</button>
      <button class="mv-channel-btn active" data-channel="linkedin">LinkedIn</button>
      <button class="mv-channel-btn active" data-channel="instagram">Instagram</button>
      <button class="mv-channel-btn active" data-channel="youtube">YouTube</button>
      <button class="mv-channel-btn active" data-channel="presse">Presse</button>
      <button class="mv-channel-btn active" data-channel="conference">Conference</button>
    </div>
    <div class="mv-stats">
      <div class="mv-stat">
        <div class="mv-stat-number" id="mv-stat-total">0</div>
        <div class="mv-stat-label">publications visibles</div>
      </div>
      <div class="mv-stat">
        <div class="mv-stat-number" id="mv-stat-media">0</div>
        <div class="mv-stat-label">articles presse</div>
      </div>
      <div class="mv-stat">
        <div class="mv-stat-number" id="mv-stat-reach">0</div>
        <div class="mv-stat-label">audience cumulee</div>
      </div>
    </div>
  </div>

  <!-- Density bar -->
  <div class="mv-density-bar" id="mv-density-bar"></div>

  <!-- Bottom timeline -->
  <div class="mv-timeline-bar">
    <div class="mv-year-labels" id="mv-year-labels"></div>
  </div>

  <!-- Legend -->
  <div class="mv-legend">
    <div class="mv-legend-item"><div class="mv-legend-dot" style="width:8px;height:8px;background:#2a55b3;"></div> <span style="color:rgba(255,255,255,0.7)">Technologique</span></div>
    <div class="mv-legend-item"><div class="mv-legend-dot" style="width:8px;height:8px;background:#00bf63;"></div> <span style="color:rgba(255,255,255,0.7)">Environnementale</span></div>
    <div class="mv-legend-item"><div class="mv-legend-dot" style="width:8px;height:8px;background:#b32a55;"></div> <span style="color:rgba(255,255,255,0.7)">Socioculturelle</span></div>
    <div style="width:1px;height:14px;background:rgba(255,255,255,0.15);margin:0 4px;"></div>
    <div class="mv-legend-item"><div class="mv-legend-dot" style="width:10px;height:10px;background:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.6);border-radius:50%;"></div> Presse</div>
    <div class="mv-legend-item"><div class="mv-legend-dot" style="width:7px;height:7px;background:rgba(255,255,255,0.45);"></div> Conf</div>
    <div class="mv-legend-item"><div class="mv-legend-dot" style="width:4px;height:4px;background:rgba(255,255,255,0.3);"></div> Social</div>
  </div>

  <!-- Detail popup -->
  <div class="mv-detail-popup" id="mv-detail-popup">
    <div style="display:flex;align-items:center;">
      <div class="mv-pub-type" id="mv-popup-type"></div>
      <div class="mv-pub-tier" id="mv-popup-tier"></div>
    </div>
    <h3 id="mv-popup-title"></h3>
    <div class="mv-popup-channel" id="mv-popup-channel"></div>
    <div class="mv-popup-excerpt" id="mv-popup-excerpt"></div>
    <div class="mv-popup-metrics">
      <span><strong id="mv-popup-date">--</strong></span>
    </div>
  </div>
</div>

<style>
  .mediaviz-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #0a0e1a;
    border-radius: 16px;
    user-select: none;
  }

  #mediaviz-canvas {
    display: block;
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  /* ── Top bar ── */
  .mv-top-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    background: rgba(13,17,23,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    gap: 12px;
    flex-wrap: wrap;
  }
  .mv-title {
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
    letter-spacing: -0.3px;
    color: #fff;
  }
  .mv-title span {
    font-family: var(--font-body), 'Inter', serif;
    font-size: 11px;
    font-style: italic;
    color: rgba(255,255,255,0.35);
    margin-left: 8px;
    font-weight: 400;
  }

  /* ── Filters ── */
  .mv-filters {
    display: flex;
    align-items: center;
    gap: 5px;
    flex-wrap: wrap;
  }
  .mv-filter-sep {
    width: 1px;
    height: 16px;
    background: rgba(255,255,255,0.12);
    margin: 0 4px;
  }
  .mv-filter-btn {
    padding: 3px 10px;
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent;
    color: rgba(255,255,255,0.4);
    border-radius: 12px;
    cursor: pointer;
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 10px;
    font-weight: 600;
    transition: all 0.25s;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    white-space: nowrap;
  }
  .mv-filter-btn:hover { color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.2); }
  .mv-filter-btn.active { color: #fff; }
  .mv-filter-btn[data-axis="all"].active { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.25); }
  .mv-filter-btn[data-axis="techno"].active { background: rgba(42,85,179,0.25); border-color: #2a55b3; color: #6b9fff; }
  .mv-filter-btn[data-axis="enviro"].active { background: rgba(0,191,99,0.15); border-color: #00bf63; color: #4dff99; }
  .mv-filter-btn[data-axis="socio"].active { background: rgba(179,42,85,0.25); border-color: #b32a55; color: #ff6b99; }

  .mv-channel-btn {
    padding: 3px 8px;
    border: 1px solid rgba(255,255,255,0.06);
    background: transparent;
    color: rgba(255,255,255,0.3);
    border-radius: 10px;
    cursor: pointer;
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 9px;
    font-weight: 500;
    transition: all 0.25s;
    white-space: nowrap;
  }
  .mv-channel-btn:hover { color: rgba(255,255,255,0.6); }
  .mv-channel-btn.active { color: rgba(255,255,255,0.8); border-color: rgba(255,255,255,0.2); background: rgba(255,255,255,0.06); }

  /* ── Stats ── */
  .mv-stats {
    display: flex;
    gap: 14px;
    align-items: center;
    white-space: nowrap;
  }
  .mv-stat {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }
  .mv-stat-number {
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    font-variant-numeric: tabular-nums;
  }
  .mv-stat-label {
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 8px;
    color: rgba(255,255,255,0.85);
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  /* ── Density bar ── */
  .mv-density-bar {
    position: absolute;
    bottom: 30px; left: 16px; right: 16px;
    z-index: 100;
    height: 4px;
    display: flex;
    gap: 1px;
  }
  .mv-density-bar :global(.mv-density-seg) {
    flex: 1;
    border-radius: 2px;
  }

  /* ── Bottom timeline ── */
  .mv-timeline-bar {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(13,17,23,0.9);
    backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 6px 16px 10px;
  }
  .mv-year-labels {
    display: flex;
    justify-content: space-between;
    padding: 0 2px;
  }
  .mv-year-labels :global(.mv-year-label) {
    font-family: var(--font-mono), 'JetBrains Mono', monospace;
    font-size: 9px;
    color: rgba(255,255,255,0.85);
    text-align: center;
    min-width: 28px;
  }

  /* ── Legend ── */
  .mv-legend {
    position: absolute;
    bottom: 32px;
    right: 16px;
    z-index: 101;
    display: flex;
    gap: 12px;
    align-items: center;
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 8px;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }
  .mv-legend-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .mv-legend-dot {
    border-radius: 50%;
    display: inline-block;
  }

  /* ── Detail popup ── */
  .mv-detail-popup {
    position: absolute;
    z-index: 200;
    background: rgba(13, 17, 23, 0.95);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    padding: 14px;
    max-width: 280px;
    display: none;
    pointer-events: auto;
    transition: opacity 0.2s;
    color: #fff;
  }
  .mv-pub-type {
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 4px;
  }
  .mv-pub-tier {
    display: inline-block;
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 1px 6px;
    border-radius: 6px;
    margin-left: 6px;
    font-weight: 600;
  }
  .mv-pub-tier.media { background: rgba(212,168,87,0.25); color: #d4a857; }
  .mv-pub-tier.conference { background: rgba(155,89,182,0.2); color: #b97fd4; }
  .mv-pub-tier.social { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.4); }

  .mv-detail-popup h3 {
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 3px;
    line-height: 1.35;
    color: #fff;
  }
  .mv-popup-channel {
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 10px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 6px;
  }
  .mv-popup-excerpt {
    font-family: var(--font-body), 'Inter', serif;
    font-size: 11px;
    line-height: 1.5;
    color: rgba(255,255,255,0.6);
    margin-bottom: 8px;
  }
  .mv-popup-metrics {
    display: flex;
    gap: 12px;
    font-family: var(--font-heading), 'Poppins', sans-serif;
    font-size: 10px;
    color: rgba(255,255,255,0.35);
  }
  .mv-popup-metrics strong { color: rgba(255,255,255,0.7); }

  @media (max-width: 768px) {
    .mv-top-bar { padding: 6px 10px; gap: 8px; }
    .mv-title { font-size: 11px; }
    .mv-filters { gap: 3px; }
    .mv-filter-btn { padding: 2px 7px; font-size: 9px; }
    .mv-channel-btn { padding: 2px 6px; font-size: 8px; }
    .mv-stats { gap: 8px; }
    .mv-stat-number { font-size: 12px; }
    .mv-stat-label { font-size: 7px; }
    .mv-legend { display: none; }
  }
</style>

<script is:inline>
(function() {
    // =============================================
    // COLORS & CHANNELS
    // =============================================
    const COLORS = {
        techno: '#2a55b3',
        enviro: '#00bf63',
        socio:  '#b32a55',
        technoLight: '#6b9fff',
        enviroLight: '#4dff99',
        socioLight:  '#ff6b99'
    };

    const CHANNELS = {
        linkedin:   { label: 'LinkedIn', color: '#0077b5' },
        instagram:  { label: 'Instagram', color: '#e4405f' },
        youtube:    { label: 'YouTube', color: '#ff0000' },
        presse:     { label: 'Presse', color: '#d4a857' },
        conference: { label: 'Conference', color: '#9b59b6' }
    };

    function getPubTier(channel) {
        if (channel === 'presse') return 'media';
        if (channel === 'conference') return 'conference';
        return 'social';
    }

    const YEAR_MIN = 2013;
    const YEAR_MAX = 2026;

    // =============================================
    // DATA GENERATION
    // =============================================
    function generatePublications() {
        const pubs = [];

        // -- REAL DATA: Conferences/Interventions (9 entries) --
        const conferences = [
            {title: 'Euromaritime 2026 \u2014 Avenir du mod\u00e8le \u00e9conomique des compagnies de service public maritime', axis: 'socio', channel: 'conference', type: 'Conference', date: new Date(2026, 1, 3), reach: 5000, excerpt: 'Intervention sur l\'avenir du mod\u00e8le \u00e9conomique des compagnies de service public maritime.'},
            {title: 'Acad\u00e9mie de Marine \u2014 Potentiel strat\u00e9gique du maritime de proximit\u00e9', axis: 'socio', channel: 'conference', type: 'Conference', date: new Date(2026, 1, 18), reach: 8000, excerpt: 'Pr\u00e9sentation du potentiel strat\u00e9gique du maritime de proximit\u00e9.'},
            {title: 'Propeller Club International \u2014 Introduction to digitalization & decarbonation', axis: 'techno', channel: 'conference', type: 'Conference', date: new Date(2025, 9, 14), reach: 6000, excerpt: '2 keynotes sur la digitalisation et la d\u00e9carbonation.'},
            {title: 'Emission Shipping Conference (NABU + Sciences Po)', axis: 'enviro', channel: 'conference', type: 'Conference', date: new Date(2025, 8, 30), reach: 4000, excerpt: 'Participation \u00e0 la conf\u00e9rence sur les \u00e9missions du shipping.'},
            {title: 'Conf\u00e9rence Race for Water \u2014 Propulsion v\u00e9lique et d\u00e9carbonation', axis: 'enviro', channel: 'conference', type: 'Conference', date: new Date(2025, 4, 13), reach: 5000, excerpt: 'La propulsion v\u00e9lique : un vent nouveau pour d\u00e9carboner le transport maritime.'},
            {title: 'AG F\u00e9d\u00e9ration Nationale du M\u00e9rite Maritime \u2014 Avenir du maritime', axis: 'socio', channel: 'conference', type: 'Conference', date: new Date(2025, 4, 16), reach: 3000, excerpt: 'Intervention sur l\'avenir du maritime.'},
            {title: 'Euromaritime 2024 \u2014 Comment relever les d\u00e9fis des exigences IMO 2030/2050', axis: 'enviro', channel: 'conference', type: 'Conference', date: new Date(2024, 0, 31), reach: 8000, excerpt: 'Panel sur les d\u00e9fis r\u00e9glementaires IMO.'},
            {title: 'Universit\u00e9 de Rennes 1 \u2014 D\u00e9carbonation du maritime', axis: 'enviro', channel: 'conference', type: 'Conference', date: new Date(2024, 4, 24), reach: 4000, excerpt: 'Conf\u00e9rence sur la d\u00e9carbonation du transport maritime.'},
            {title: 'Webinaire Digital Ship \u2014 Using Electronic Logbooks to Improve Efficiency', axis: 'techno', channel: 'conference', type: 'Conference', date: new Date(2023, 5, 22), reach: 6000, excerpt: 'Webinaire sur les logbooks \u00e9lectroniques et l\'efficacit\u00e9 op\u00e9rationnelle.'},
        ];

        // -- REAL DATA: Press articles (32 entries) --
        const press = [
            {title: 'Maritime: la grande mise \u00e0 jour des comp\u00e9tences', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2026, 2, 2), reach: 15000, excerpt: 'HydroContest by ENSM'},
            {title: 'La donn\u00e9e maritime comme boussole environnementale', axis: 'enviro', channel: 'presse', type: 'Article presse', date: new Date(2026, 2, 2), reach: 15000, excerpt: 'HydroContest by ENSM'},
            {title: 'Propulsion v\u00e9lique: quand l\'art de la navigation est r\u00e9invent\u00e9', axis: 'enviro', channel: 'presse', type: 'Article presse', date: new Date(2026, 0, 13), reach: 15000, excerpt: 'HydroContest by ENSM'},
            {title: 'M\u00e9diterran\u00e9e centrale: quand le d\u00e9litement du droit international transforme le sauvetage maritime', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2025, 11, 20), reach: 80000, excerpt: 'Le Monde'},
            {title: 'E-carburants: l\'Europe face au d\u00e9fi de la souverainet\u00e9 \u00e9nerg\u00e9tique', axis: 'enviro', channel: 'presse', type: 'Article presse', date: new Date(2025, 11, 8), reach: 15000, excerpt: 'HydroContest by ENSM'},
            {title: 'Le GASPE nomme Colomban Monnier d\u00e9l\u00e9gu\u00e9 g\u00e9n\u00e9ral', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2025, 9, 31), reach: 25000, excerpt: 'Mer & Marine'},
            {title: 'Le GASPE nomme Colomban Monnier D\u00e9l\u00e9gu\u00e9 G\u00e9n\u00e9ral et affirme son engagement', axis: 'socio', channel: 'presse', type: 'Article presse', date: new Date(2025, 9, 25), reach: 20000, excerpt: 'Jeune Marine'},
