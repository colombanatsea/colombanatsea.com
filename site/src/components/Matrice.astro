---
/**
 * Matrice Triple Transition — Réseau 3D organique
 * Three.js bundled via npm (no CDN dependency)
 */
---

<div class="matrice-wrapper">
  <div class="matrice-fallback" id="matrice-fallback">
    <div class="matrice-fallback__axis matrice-fallback__axis--tech">
      <h4>Technologique</h4>
      <ul>
        <li>VAIATA Dynamics</li>
        <li>Opsealog</li>
        <li>Advisory boards</li>
      </ul>
    </div>
    <div class="matrice-fallback__axis matrice-fallback__axis--enviro">
      <h4>Environnementale</h4>
      <ul>
        <li>Fondation ENSM</li>
        <li>Enseignant DD</li>
      </ul>
    </div>
    <div class="matrice-fallback__axis matrice-fallback__axis--socio">
      <h4>Socioculturelle</h4>
      <ul>
        <li>GASPE</li>
        <li>HYDROS Alumni</li>
        <li>Propeller Club</li>
        <li>Ap&eacute;ritifs de la Mer</li>
      </ul>
    </div>
  </div>
  <div id="matrice-canvas-container">
    <div id="matrice-labels"></div>

    <div class="matrice-legend">
      <div class="matrice-legend-item"><div class="matrice-dot" style="background:#2a55b3"></div>Technologique</div>
      <div class="matrice-legend-item"><div class="matrice-dot" style="background:#00bf63"></div>Environnementale</div>
      <div class="matrice-legend-item"><div class="matrice-dot" style="background:#b32a55"></div>Socioculturelle</div>
    </div>

    <div class="matrice-detail" id="matrice-detail">
      <button class="matrice-close" id="matrice-close">&times;</button>
      <h3 id="matrice-panel-name"></h3>
      <div class="matrice-role" id="matrice-panel-role"></div>
      <div class="matrice-axes" id="matrice-panel-axes"></div>
      <div class="matrice-desc" id="matrice-panel-desc"></div>
    </div>

    <div class="matrice-tooltip" id="matrice-tooltip"></div>

    <div class="matrice-grab-hint" id="matrice-grab-hint">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 11V6a2 2 0 0 0-4 0v1M14 10V4a2 2 0 0 0-4 0v6M10 10.5V5a2 2 0 0 0-4 0v9"/>
        <path d="M18 11a2 2 0 0 1 4 0v5a8 8 0 0 1-8 8h-2c-2.5 0-4.5-1-6.2-2.8L2 17"/>
      </svg>
      <span>Cliquer-glisser pour explorer</span>
    </div>
  </div>
</div>

<style>
  .matrice-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  #matrice-canvas-container {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    cursor: grab;
  }

  #matrice-canvas-container:active {
    cursor: grabbing;
  }

  #matrice-canvas-container canvas { display: block; }

  #matrice-labels {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 5;
    pointer-events: none;
    overflow: hidden;
  }

  #matrice-labels :global(.m-label) {
    position: absolute;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.6);
    white-space: nowrap;
    pointer-events: none;
    text-shadow: 0 0 6px rgba(10,14,26,1), 0 0 12px rgba(10,14,26,1);
    transform: translate(0, -50%);
    font-weight: 400;
    letter-spacing: 0.02em;
    font-family: var(--font-heading);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .matrice-legend {
    position: absolute;
    bottom: 24px; left: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: rgba(10,14,26,0.7);
    backdrop-filter: blur(8px);
    padding: 14px 18px;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.08);
    font-size: 0.75rem;
    font-family: var(--font-heading);
    color: rgba(255,255,255,0.7);
    z-index: 10;
  }

  .matrice-legend-item { display: flex; align-items: center; gap: 8px; }
  .matrice-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  .matrice-detail {
    position: absolute;
    right: -420px;
    top: 50%;
    transform: translateY(-50%);
    width: 340px;
    max-height: 80%;
    overflow-y: auto;
    background: rgba(10,14,26,0.95);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 28px;
    z-index: 200;
    transition: right 0.45s cubic-bezier(0.22,1,0.36,1);
    color: white;
    font-family: var(--font-body);
  }

  .matrice-detail.open { right: 24px; }

  .matrice-close {
    position: absolute; top: 12px; right: 14px;
    background: none; border: none; color: rgba(255,255,255,0.5);
    font-size: 1.3rem; cursor: pointer;
  }

  .matrice-close:hover { color: white; }

  .matrice-detail h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    margin-bottom: 4px;
    color: white;
  }

  .matrice-role {
    font-family: var(--font-body);
    font-style: italic;
    color: rgba(255,255,255,0.6);
    font-size: 0.85rem;
    margin-bottom: 12px;
  }

  .matrice-axes {
    display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px;
  }

  .matrice-axes span {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    padding: 3px 10px;
    border-radius: 20px;
    border: 1px solid;
  }

  .matrice-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.75);
  }

  .matrice-tooltip {
    position: fixed;
    padding: 6px 14px;
    background: rgba(10,14,26,0.9);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    font-size: 0.75rem;
    font-family: var(--font-heading);
    color: rgba(255,255,255,0.8);
    pointer-events: none;
    z-index: 300;
    opacity: 0;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .matrice-tooltip.show { opacity: 1; }

  /* Mobile fallback */
  .matrice-fallback {
    display: none;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.5rem;
    height: 100%;
    overflow-y: auto;
  }

  .matrice-fallback__axis {
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.03);
  }

  .matrice-fallback__axis h4 {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .matrice-fallback__axis--tech h4 { color: #2a55b3; }
  .matrice-fallback__axis--enviro h4 { color: #00bf63; }
  .matrice-fallback__axis--socio h4 { color: #b32a55; }

  .matrice-fallback__axis ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .matrice-fallback__axis li {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.03);
  }

  .matrice-grab-hint {
    position: absolute;
    bottom: 24px; right: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,0.4);
    font-size: 0.7rem;
    font-family: var(--font-heading);
    letter-spacing: 0.03em;
    pointer-events: none;
    animation: grab-hint-pulse 3s ease-in-out infinite;
    transition: opacity 0.6s ease;
  }

  .matrice-grab-hint.hidden { opacity: 0; }

  .matrice-grab-hint svg {
    opacity: 0.5;
    animation: grab-hint-sway 2.5s ease-in-out infinite;
  }

  @keyframes grab-hint-pulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  @keyframes grab-hint-sway {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(6px); }
  }

  @media (max-width: 768px) {
    .matrice-fallback { display: flex; }
    #matrice-canvas-container { display: none; }
    .matrice-detail { width: calc(100vw - 48px); max-width: 340px; }
  }
</style>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  const BG = 0x1a1a2e;
  const COLORS = { techno: 0x2a55b3, enviro: 0x00bf63, socio: 0xb32a55, purple: 0x8b2fc6 };
  const AXIS_HEX: Record<string, string> = { Technologique: '#2a55b3', Environnementale: '#00bf63', Socioculturelle: '#b32a55' };

  const engagements = [
    { id:0, name:'Opsealog', role:'Conception initiale, maritime data analytics', axes:['Technologique','Environnementale'], size:1.1, pos:[3,2.5,1.5], desc:'Plateforme de data analytics pour optimiser la performance et la consommation énergétique des navires.' },
    { id:1, name:'Fondation ENSM', role:'Président du conseil, rayonnement de l\'ENSM', axes:['Socioculturelle','Environnementale'], size:0.9, pos:[-2,-2.5,2], desc:'Présidence de la Fondation de l\'Ecole Nationale Supérieure Maritime.' },
    { id:2, name:'ENSM', role:'Enseignant développement durable', axes:['Environnementale'], size:0.8, pos:[1,3,2.5], desc:'Enseignement du développement durable et de la transition écologique.' },
    { id:3, name:'Propeller Club', role:'Membre actif, networking maritime', axes:['Socioculturelle'], size:0.7, pos:[-3,-1,-2], desc:'Réseau international de professionnels du secteur maritime et portuaire.' },
    { id:4, name:'HYDROS Alumni', role:'Membre du bureau', axes:['Socioculturelle'], size:0.65, pos:[-1.5,-3,1], desc:'Animation du réseau des anciens élèves de l\'ENSM.' },
    { id:5, name:'VAIATA Dynamics', role:'Cofondateur, Intelligence artificielle', axes:['Technologique'], size:1.0, pos:[4,-1,1.5], desc:'IA au service des grandes causes du maritime.' },
    { id:6, name:'GASPE', role:'Délégué général, service public maritime', axes:['Socioculturelle'], size:0.85, pos:[-2.5,1.5,-2.5], desc:'Groupement des Armateurs de Service Public Maritime et de Passages d\'Eau.' },
    { id:7, name:'Apéritifs de la Mer', role:'Ambassadeur', axes:['Socioculturelle'], size:0.75, pos:[-1,-1,-3.5], desc:'Evénements de networking réunissant les acteurs de l\'économie maritime.' },
    { id:8, name:'Académie de Marine', role:'Auditeur', axes:['Socioculturelle'], size:0.8, pos:[-4,2,0.5], desc:'Institution séculaire de réflexion et de prospective maritime.' },
    { id:9, name:'Conférences', role:'Intervenant, sensibilisation maritime', axes:['Environnementale'], size:0.7, pos:[2,3.5,-1], desc:'Interventions sur les transitions du monde maritime.' },
    { id:10, name:'Féd. Mérite Maritime', role:'Membre', axes:['Socioculturelle'], size:0.75, pos:[-3.5,-2.5,-1], desc:'Fédération valorisant les contributions au monde maritime.' },
    { id:11, name:'Aventure entrepreneuriale', role:'Cofondateur', axes:['Technologique'], size:0.55, ghosted:true, pos:[1.5,-0.5,-2], desc:'Création d\'entreprises dans le secteur maritime.' },
    { id:12, name:'Aventure entrepreneuriale', role:'Cofondateur', axes:['Technologique'], size:0.55, ghosted:true, pos:[-0.5,-2.5,-2.5], desc:'Création d\'entreprises dans le secteur maritime.' },
    { id:13, name:'Aventure entrepreneuriale', role:'Cofondateur', axes:['Technologique'], size:0.55, ghosted:true, pos:[-1,-3.5,-3.5], desc:'Création d\'entreprises dans le secteur maritime.' },
  ];

  const connections = [
    [6,8],[9,2],[9,3],[9,0],[9,5],[7,4],[7,2],[7,0],[5,6],[5,8],
    [10,4],[10,1],[10,6],[10,7],[11,7],[11,0],[12,4],[12,7],[13,12]
  ];

  function primaryColor(eng: typeof engagements[0]) {
    const a = eng.axes;
    if (a.includes('Socioculturelle') && a.includes('Environnementale')) return COLORS.purple;
    if (a.includes('Technologique') && a.includes('Environnementale')) return 0x1590a0;
    if (a.includes('Technologique')) return COLORS.techno;
    if (a.includes('Environnementale')) return COLORS.enviro;
    return COLORS.socio;
  }

  // ── EARLY EXIT IF HIDDEN (mobile CSS fallback) ──
  const container = document.getElementById('matrice-canvas-container');
  if (!container || !container.offsetWidth) {
    // Mobile fallback is active — skip Three.js init entirely
  } else {

  // ── LAZY INIT: wait until visible (skip if already in viewport) ──
  await new Promise<void>(resolve => {
    const rect = container.getBoundingClientRect();
    if (rect.top < window.innerHeight + 200) { resolve(); return; }
    const io = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) { io.disconnect(); resolve(); }
    }, { rootMargin: '200px' });
    io.observe(container);
  });

  // ── QUALITY SETTINGS ──
  const isMobile = window.innerWidth <= 1024;
  const PX_RATIO = isMobile ? 1 : Math.min(window.devicePixelRatio, 1.5);

  const tooltip = document.getElementById('matrice-tooltip')!;
  const panel = document.getElementById('matrice-detail')!;

  const renderer = new THREE.WebGLRenderer({ antialias: !isMobile, alpha: false, powerPreference: 'high-performance' });
  renderer.setSize(container.clientWidth, container.clientHeight);
  renderer.setPixelRatio(PX_RATIO);
  renderer.setClearColor(BG, 1);
  renderer.outputColorSpace = THREE.SRGBColorSpace;
  container.appendChild(renderer.domElement);

  // ── WEBGL CONTEXT LOSS HANDLING ──
  renderer.domElement.addEventListener('webglcontextlost', (e) => {
    e.preventDefault();
    const fallback = document.querySelector('.matrice-fallback') as HTMLElement;
    if (fallback) fallback.style.display = 'flex';
    container.style.display = 'none';
  });

  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(BG, 0.025);

  const camera = new THREE.PerspectiveCamera(50, container.clientWidth / container.clientHeight, 0.1, 100);
  camera.position.set(8, 6, 10);
  camera.lookAt(0, 0, 0);

  const controls = new OrbitControls(camera, renderer.domElement);
  controls.enableDamping = true;
  controls.dampingFactor = 0.06;
  controls.autoRotate = true;
  controls.autoRotateSpeed = 0.4;
  controls.minDistance = 5;
  controls.maxDistance = 25;
  controls.enablePan = false;
  controls.enableZoom = false;

  let interTimer: ReturnType<typeof setTimeout> | null = null;
  const grabHint = document.getElementById('matrice-grab-hint');
  function pauseRotate() {
    controls.autoRotate = false;
    if (interTimer) clearTimeout(interTimer);
    interTimer = setTimeout(() => { controls.autoRotate = true; }, 3000);
    if (grabHint) grabHint.classList.add('hidden');
  }
  controls.addEventListener('start', pauseRotate);

  scene.add(new THREE.AmbientLight(0xffffff, 0.6));
  const dL = new THREE.DirectionalLight(0xffffff, 0.8);
  dL.position.set(5, 5, 5);
  scene.add(dL);

  // Axis planes
  ([[COLORS.techno,[0,0,0]], [COLORS.enviro,[Math.PI/2,0,0]], [COLORS.socio,[0,Math.PI/2,0]]] as [number, number[]][]).forEach(([c,r]) => {
    const m = new THREE.Mesh(new THREE.PlaneGeometry(14,14), new THREE.MeshBasicMaterial({ color:c, transparent:true, opacity:0.06, side:THREE.DoubleSide, depthWrite:false }));
    m.rotation.set(r[0], r[1], r[2]);
    scene.add(m);
  });

  const sphereGroup = new THREE.Group();
  scene.add(sphereGroup);
  const sphereMeshes: THREE.Mesh[] = [];
  const labelEls: HTMLElement[] = [];
  const labelContainer = document.getElementById('matrice-labels')!;

  engagements.forEach(eng => {
    const r = eng.size * 0.42;
    const c = primaryColor(eng);
    const ghosted = eng.ghosted === true;
    const baseOp = ghosted ? 0.15 : 0.55;

    const mesh = new THREE.Mesh(
      new THREE.SphereGeometry(r, 24, 24),
      new THREE.MeshPhongMaterial({ color:c, transparent:true, opacity:baseOp, shininess:140, specular:0x666666, depthWrite:false })
    );

    const core = new THREE.Mesh(
      new THREE.SphereGeometry(r*0.45, 12, 12),
      new THREE.MeshPhongMaterial({ color:c, emissive:c, emissiveIntensity:ghosted?0.15:0.5, transparent:true, opacity:ghosted?0.3:0.9 })
    );
    mesh.add(core);

    const ring = new THREE.Mesh(
      new THREE.RingGeometry(r*1.1, r*1.35, 24),
      new THREE.MeshBasicMaterial({ color:c, transparent:true, opacity:0, side:THREE.DoubleSide, depthWrite:false })
    );
    ring.lookAt(camera.position);
    mesh.add(ring);

    const target = new THREE.Vector3(...(eng.pos as [number, number, number]));
    mesh.position.set((Math.random()-0.5)*40, (Math.random()-0.5)*40, (Math.random()-0.5)*40);
    mesh.userData = { target, eng, radius:r, ring, core, originalOpacity:baseOp };

    sphereGroup.add(mesh);
    sphereMeshes.push(mesh);

    const lbl = document.createElement('div');
    lbl.className = 'm-label';
    lbl.textContent = eng.name;
    if (ghosted) lbl.style.opacity = '0.35';
    labelContainer.appendChild(lbl);
    labelEls.push(lbl);
  });

  // Connection lines + traveling particles
  const lineMeshes: THREE.Line[] = [];
  connections.forEach(([a,b]) => {
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(6), 3));
    const ghosted = engagements[a].ghosted || engagements[b].ghosted;
    const line = new THREE.Line(geo, new THREE.LineBasicMaterial({ color:0xffffff, transparent:true, opacity:ghosted?0.06:0.12, depthWrite:false }));
    line.userData = { idA:a, idB:b };
    sphereGroup.add(line);
    lineMeshes.push(line);
  });

  const travelParticles: THREE.Mesh[] = [];
  const tpGeo = new THREE.SphereGeometry(0.04, 6, 6);
  connections.forEach(([a,b]) => {
    const ghosted = engagements[a].ghosted || engagements[b].ghosted;
    for (let p = 0; p < 2; p++) {
      const m = new THREE.Mesh(tpGeo, new THREE.MeshBasicMaterial({ color:0xffffff, transparent:true, opacity:ghosted?0.15:0.5, depthWrite:false }));
      m.userData = { idA:a, idB:b, t:p/2, speed:0.15+Math.random()*0.1, baseOpacity:ghosted?0.15:0.5 };
      sphereGroup.add(m);
      travelParticles.push(m);
    }
  });

  // Dust
  const dustPos = new Float32Array(300*3);
  for (let i = 0; i < 300; i++) { dustPos[i*3]=(Math.random()-0.5)*30; dustPos[i*3+1]=(Math.random()-0.5)*30; dustPos[i*3+2]=(Math.random()-0.5)*30; }
  const dGeo = new THREE.BufferGeometry();
  dGeo.setAttribute('position', new THREE.Float32BufferAttribute(dustPos, 3));
  scene.add(new THREE.Points(dGeo, new THREE.PointsMaterial({ color:0xffffff, size:0.03, transparent:true, opacity:0.2, sizeAttenuation:true, depthWrite:false })));

  // Raycaster
  const raycaster = new THREE.Raycaster();
  const pointer = new THREE.Vector2(-999, -999);
  let hovered: THREE.Mesh | null = null;

  renderer.domElement.addEventListener('pointermove', e => {
    const rect = container.getBoundingClientRect();
    pointer.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
    pointer.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
    tooltip.style.left = (e.clientX + 14) + 'px';
    tooltip.style.top = (e.clientY - 10) + 'px';
  });

  renderer.domElement.addEventListener('click', () => {
    if (!hovered && panel.classList.contains('open')) panel.classList.remove('open');
  });

  document.getElementById('matrice-close')!.addEventListener('click', () => panel.classList.remove('open'));

  function openPanel(eng: typeof engagements[0]) {
    document.getElementById('matrice-panel-name')!.textContent = eng.name;
    document.getElementById('matrice-panel-role')!.textContent = eng.role;
    const ac = document.getElementById('matrice-panel-axes')!;
    ac.innerHTML = '';
    eng.axes.forEach(a => {
      const s = document.createElement('span');
      s.textContent = a;
      s.style.borderColor = AXIS_HEX[a];
      s.style.color = AXIS_HEX[a];
      ac.appendChild(s);
    });
    document.getElementById('matrice-panel-desc')!.textContent = eng.desc;
    panel.classList.add('open');
  }

  // Scroll-driven rotation
  let scrollRotation = 0;
  container.addEventListener('wheel', (e) => {
    scrollRotation += e.deltaY * 0.002;
  }, { passive: true });

  // Animation
  const clock = new THREE.Clock();
  const startTime = performance.now();
  let introComplete = false;

  function animate() {
    requestAnimationFrame(animate);
    const dt = clock.getDelta();
    const elapsed = clock.getElapsedTime();

    // Intro animation
    if (!introComplete) {
      const progress = Math.min((performance.now() - startTime) / 2000, 1);
      const ease = 1 - Math.pow(1 - progress, 3);
      sphereMeshes.forEach(m => m.position.lerpVectors(m.position, m.userData.target, ease * 0.08 + 0.02));
      if (progress >= 1) {
        introComplete = true;
        sphereMeshes.forEach(m => m.position.copy(m.userData.target));
      }
    }

    // Scroll rotation
    sphereGroup.rotation.y += (scrollRotation - sphereGroup.rotation.y) * 0.1;

    // Breathing
    sphereMeshes.forEach((m, i) => {
      m.scale.setScalar(1 + Math.sin(elapsed * 1.2 + i * 0.7) * 0.04);
      m.userData.ring.quaternion.copy(camera.quaternion);
    });

    // Lines
    lineMeshes.forEach(l => {
      const pA = sphereMeshes[l.userData.idA].position;
      const pB = sphereMeshes[l.userData.idB].position;
      const a = l.geometry.attributes.position as THREE.BufferAttribute;
      (a.array as Float32Array)[0]=pA.x; (a.array as Float32Array)[1]=pA.y; (a.array as Float32Array)[2]=pA.z;
      (a.array as Float32Array)[3]=pB.x; (a.array as Float32Array)[4]=pB.y; (a.array as Float32Array)[5]=pB.z;
      a.needsUpdate = true;
    });

    // Particles
    travelParticles.forEach(p => {
      const u = p.userData;
      u.t = (u.t + dt * u.speed) % 1;
      p.position.lerpVectors(sphereMeshes[u.idA].position, sphereMeshes[u.idB].position, u.t);
      (p.material as THREE.MeshBasicMaterial).opacity = u.baseOpacity * (0.5 + (1 - Math.abs(u.t - 0.5) * 2) * 0.5);
    });

    // Hover
    raycaster.setFromCamera(pointer, camera);
    const hits = raycaster.intersectObjects(sphereMeshes, false);
    if (hovered) {
      (hovered.material as THREE.MeshPhongMaterial).opacity = hovered.userData.originalOpacity;
      hovered.userData.ring.material.opacity = 0;
      hovered = null;
      tooltip.classList.remove('show');
      document.body.style.cursor = 'default';
    }
    if (hits.length > 0) {
      hovered = hits[0].object as THREE.Mesh;
      (hovered.material as THREE.MeshPhongMaterial).opacity = Math.min(hovered.userData.originalOpacity + 0.25, 0.6);
      hovered.userData.ring.material.opacity = 0.15;
      tooltip.textContent = hovered.userData.eng.name;
      tooltip.classList.add('show');
      document.body.style.cursor = 'pointer';
      // Auto-open detail panel on hover
      openPanel(hovered.userData.eng);
      pauseRotate();
    }

    // Labels — only show after intro completes, positioned near each sphere
    if (introComplete) {
      const rect = container.getBoundingClientRect();
      const fov = camera.fov * Math.PI / 180;
      const _wp = new THREE.Vector3();
      sphereMeshes.forEach((m, i) => {
        m.getWorldPosition(_wp);
        const v = _wp.project(camera);
        const lbl = labelEls[i];
        if (v.z > 1) { lbl.style.opacity = '0'; return; }
        const sx = (v.x * 0.5 + 0.5) * rect.width;
        const sy = (-v.y * 0.5 + 0.5) * rect.height;
        const r = m.userData.radius;
        m.getWorldPosition(_wp);
        const dist = camera.position.distanceTo(_wp);
        const screenR = (r / (2 * dist * Math.tan(fov / 2))) * rect.height;
        // Position label to the right of the sphere, offset by its screen radius
        lbl.style.left = (sx + screenR + 6) + 'px';
        lbl.style.top = sy + 'px';
        // Hide labels that are off-screen
        if (sx < -50 || sx > rect.width + 50 || sy < -20 || sy > rect.height + 20) {
          lbl.style.opacity = '0';
        } else {
          lbl.style.opacity = engagements[i].ghosted ? '0.35' : '0.7';
        }
      });
    }

    controls.update();
    renderer.render(scene, camera);
  }

  const ro = new ResizeObserver(() => {
    const w = container.clientWidth, h = container.clientHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  });
  ro.observe(container);

  animate();
  } // end of else (container visible)
</script>
