---
/**
 * Globe 3D interactif — ZEE (GeoJSON), câbles sous-marins, routes maritimes
 * Fidèle au prototype prototypes/proto1-globe/index-satellite-cables.html
 * Three.js + earcut bundled via npm (no CDN dependency)
 */
---

<div class="globe-wrapper">
  <div id="globe-fallback" class="globe-fallback">
    <div class="globe-fallback__circle"></div>
    <p class="globe-fallback__hint">Ouvrez sur un &eacute;cran plus grand pour explorer le globe interactif</p>
  </div>
  <div id="globe-container">
    <div id="total-counter">
      <div class="stat-item" data-stat="zee">
        <div class="label">ZEE fran&ccedil;aise</div>
        <div class="value">11 691 000</div>
        <div class="unit">km&sup2;</div>
      </div>
      <div class="stat-item" data-stat="cables" style="margin-top:10px;">
        <div class="label">C&acirc;bles sous-marins</div>
        <div class="value" style="color:#00b4b4;">708</div>
        <div class="unit">c&acirc;bles actifs (Telegeography)</div>
      </div>
      <div class="stat-item" data-stat="traffic" style="margin-top:10px;">
        <div class="label">Navires de commerce</div>
        <div class="value" style="color:#ff8c50;">105 000</div>
        <div class="unit">navires dans le monde (CNUCED 2024)</div>
      </div>
    </div>

    <div id="legend">
      <div class="legend-item" data-layer="zee">
        <div class="swatch zee"></div>
        <span class="legend-label">Zone &Eacute;conomique Exclusive fran&ccedil;aise</span>
      </div>
      <div class="legend-item" data-layer="cables">
        <div class="swatch cables"></div>
        <span class="legend-label">C&acirc;bles sous-marins (Telegeography)</span>
      </div>
      <div class="legend-item" data-layer="traffic">
        <div class="swatch traffic"></div>
        <span class="legend-label">Principales routes maritimes</span>
      </div>
    </div>

    <div id="globe-tooltip">
      <div class="zone-name"></div>
      <div class="zone-area"></div>
      <div class="zone-detail"></div>
    </div>
  </div>

  <div id="globe-loading">
    <div class="spinner"></div>
    <div class="load-text">Chargement du globe...</div>
  </div>

  <div class="globe-download-wrap" id="globe-download-wrap">
    <button id="globe-download-btn" class="globe-download-btn" aria-label="Télécharger la visualisation">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      <span class="mono">Télécharger</span>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="globe-download-menu" id="globe-download-menu">
      <button class="globe-download-option" id="dl-png"><span class="mono">PNG</span> — image fixe</button>
      <button class="globe-download-option" id="dl-gif"><span class="mono">GIF</span> — rotation animée</button>
    </div>
  </div>
</div>

<style>
  .globe-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  #globe-container {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    cursor: grab;
  }

  #globe-container:active { cursor: grabbing; }

  #globe-container canvas { display: block; }

  #total-counter {
    position: absolute;
    bottom: 24px;
    right: 28px;
    z-index: 10;
    pointer-events: none;
    text-align: right;
  }

  #total-counter .label {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  #total-counter .value {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    color: #00d4d4;
    text-shadow: 0 0 30px rgba(0, 212, 212, 0.4);
    line-height: 1.1;
  }

  #total-counter .unit {
    font-family: var(--font-body);
    font-weight: 400;
    font-style: italic;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
    margin-top: 2px;
  }

  #total-counter .stat-item {
    transition: opacity 0.35s ease, max-height 0.35s ease;
    overflow: hidden;
    max-height: 80px;
    opacity: 1;
  }

  #total-counter .stat-item.hidden {
    opacity: 0;
    max-height: 0;
    margin-top: 0 !important;
  }

  #globe-tooltip {
    position: absolute;
    z-index: 100;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
    background: rgba(10, 14, 30, 0.92);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(0, 200, 200, 0.35);
    border-radius: 10px;
    padding: 14px 20px;
    min-width: 180px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  }

  #globe-tooltip.visible { opacity: 1; }

  #globe-tooltip .zone-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
    margin-bottom: 4px;
  }

  #globe-tooltip .zone-area {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.85rem;
    color: #00d4d4;
  }

  #globe-tooltip .zone-detail {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.5);
    margin-top: 4px;
  }

  #legend {
    position: absolute;
    bottom: 24px;
    left: 28px;
    z-index: 10;
    pointer-events: auto;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
    cursor: pointer;
    user-select: none;
    transition: opacity 0.25s ease;
  }

  .legend-item:hover { opacity: 0.85; }
  .legend-item.disabled { opacity: 0.35; }
  .legend-item.disabled .legend-label { text-decoration: line-through; }

  .swatch {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .swatch.zee { border: 1px solid rgba(0,200,200,0.5); background: rgba(0,180,180,0.35); }
  .swatch.cables { border: 1px solid rgba(0,180,180,0.5); background: rgba(0,180,180,0.30); }
  .swatch.traffic { border: 1px solid rgba(255,100,50,0.5); background: rgba(255,100,50,0.30); }

  .legend-label {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.5);
  }

  #globe-loading {
    position: absolute;
    inset: 0;
    z-index: 999;
    background: radial-gradient(ellipse at center, #0d1220 0%, #080b14 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 16px;
    transition: opacity 0.8s ease;
    border-radius: inherit;
  }

  #globe-loading.fade-out { opacity: 0; pointer-events: none; }

  .spinner {
    width: 40px;
    height: 40px;
    border: 2px solid rgba(0,212,212,0.15);
    border-top-color: #00d4d4;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  .load-text {
    font-family: var(--font-heading);
    font-weight: 300;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* Mobile fallback */
  .globe-fallback {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    width: 100%;
    gap: 2rem;
  }

  .globe-fallback__circle {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #1a3a6e 0%, #0a1628 70%);
    border: 2px solid rgba(42, 85, 179, 0.3);
    box-shadow: 0 0 40px rgba(42, 85, 179, 0.15), inset 0 0 30px rgba(0, 180, 180, 0.05);
    animation: globe-pulse 4s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes globe-pulse {
    0%, 100% { box-shadow: 0 0 40px rgba(42, 85, 179, 0.15); }
    50% { box-shadow: 0 0 60px rgba(42, 85, 179, 0.3); }
  }

  .globe-fallback__hint {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: rgba(255,255,255,0.4);
    text-align: center;
    max-width: 220px;
    line-height: 1.5;
    letter-spacing: 0.02em;
  }

  .globe-download-wrap {
    display: none;
    position: absolute;
    top: calc(var(--nav-height, 64px) + 4.5rem);
    right: 2rem;
    z-index: 15;
  }

  .globe-download-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 20px;
    padding: 0.4rem 0.9rem;
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    transition: all 0.25s ease;
    backdrop-filter: blur(8px);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
  }

  .globe-download-btn:hover {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.4);
    color: #fff;
  }

  .globe-download-menu {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: rgba(15,15,30,0.92);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    backdrop-filter: blur(12px);
    overflow: hidden;
    min-width: 180px;
  }

  .globe-download-wrap.open .globe-download-menu {
    display: block;
  }

  .globe-download-option {
    display: block;
    width: 100%;
    padding: 0.55rem 0.9rem;
    background: none;
    border: none;
    color: rgba(255,255,255,0.7);
    font-size: 0.7rem;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
    font-family: inherit;
  }

  .globe-download-option:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
  }

  .globe-download-option + .globe-download-option {
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  @media (max-width: 768px) {
    #total-counter { bottom: 16px; right: 16px; }
    #legend { bottom: 16px; left: 16px; }
    .globe-fallback { display: flex; }
    #globe-container { display: none; }
  }
</style>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';
  import earcut from 'earcut';
  import EEZ_GEOJSON from '../data/eez.json';
  import CABLE_GEOJSON from '../data/cables.json';
  import SHIPPING_LANES from '../data/shipping-lanes.json';

  // ── EARLY EXIT IF HIDDEN (mobile CSS fallback) ──
  const container = document.getElementById('globe-container');
  if (!container || !container.offsetWidth) {
    // Mobile fallback is active — skip Three.js init entirely
    // This prevents texture downloads and GPU allocation on mobile
  } else {
  // ── QUALITY SETTINGS ──
  const isMobile = window.innerWidth <= 1024;
  const SPHERE_SEG = isMobile ? 48 : 96;
  const PX_RATIO = isMobile ? 1 : Math.min(window.devicePixelRatio, 2);
  const USE_AA = !isMobile;

  // ── CONFIG ──
  const GLOBE_RADIUS = 1.0;
  const ZEE_HEIGHT = 1.003;
  const CABLE_RADIUS = GLOBE_RADIUS + 0.005;
  const LANE_RADIUS = GLOBE_RADIUS + 0.003;
  const AUTO_ROTATE_SPEED = 0.08;

  // ── SCENE ──
  const tooltip = document.getElementById('globe-tooltip')!;
  const tooltipName = tooltip.querySelector('.zone-name')!;
  const tooltipArea = tooltip.querySelector('.zone-area')!;
  const tooltipDetail = tooltip.querySelector('.zone-detail')!;

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.01, 100);
  camera.position.set(0, 0.4, 2.8);

  const renderer = new THREE.WebGLRenderer({ antialias: USE_AA, alpha: false, powerPreference: 'high-performance', preserveDrawingBuffer: true });
  renderer.setSize(container.clientWidth, container.clientHeight);
  renderer.setPixelRatio(PX_RATIO);
  renderer.setClearColor(0x080b14, 1);
  renderer.outputColorSpace = THREE.SRGBColorSpace;
  container.appendChild(renderer.domElement);

  // ── WEBGL CONTEXT LOSS HANDLING ──
  renderer.domElement.addEventListener('webglcontextlost', (e) => {
    e.preventDefault();
    const fallback = document.getElementById('globe-fallback');
    if (fallback) fallback.style.display = 'flex';
    container.style.display = 'none';
  });

  // ── CONTROLS ──
  const controls = new OrbitControls(camera, renderer.domElement);
  controls.enableDamping = true;
  controls.dampingFactor = 0.06;
  controls.rotateSpeed = 0.5;
  controls.enableZoom = true;
  controls.zoomSpeed = 0.8;
  controls.minDistance = 1.3;
  controls.maxDistance = 5;
  controls.enablePan = false;
  controls.autoRotate = true;
  controls.autoRotateSpeed = AUTO_ROTATE_SPEED;

  // ── LIGHTING ──
  scene.add(new THREE.AmbientLight(0x666666, 1.5));
  const dirLight = new THREE.DirectionalLight(0xffffff, 1.0);
  dirLight.position.set(5, 3, 5);
  scene.add(dirLight);
  const backLight = new THREE.DirectionalLight(0x334455, 0.4);
  backLight.position.set(-3, -2, -5);
  scene.add(backLight);

  // ── GLOBE (satellite texture) ──
  const textureLoader = new THREE.TextureLoader();
  const globeGeo = new THREE.SphereGeometry(GLOBE_RADIUS, SPHERE_SEG, SPHERE_SEG);
  const globeMat = new THREE.MeshPhongMaterial({ color: 0xffffff, shininess: 25, bumpScale: 0.015 });
  const globe = new THREE.Mesh(globeGeo, globeMat);
  scene.add(globe);

  let loadedCount = 0;
  function checkLoaded() {
    loadedCount++;
    if (loadedCount >= 2) {
      const el = document.getElementById('globe-loading');
      if (el) { el.classList.add('fade-out'); setTimeout(() => el.remove(), 900); }
    }
  }

  // Dismiss loading after 6s regardless
  setTimeout(() => {
    const el = document.getElementById('globe-loading');
    if (el) { el.classList.add('fade-out'); setTimeout(() => el.remove(), 900); }
  }, 6000);

  textureLoader.load(import.meta.env.BASE_URL + 'assets/textures/earth-blue-marble.jpg', (t) => {
    t.colorSpace = THREE.SRGBColorSpace;
    globeMat.map = t;
    globeMat.needsUpdate = true;
    checkLoaded();
  }, undefined, () => {
    globeMat.color.set(0x0f1d30);
    globeMat.emissive = new THREE.Color(0x050a14);
    globeMat.emissiveIntensity = 0.3;
    globeMat.needsUpdate = true;
    checkLoaded();
  });

  if (!isMobile) {
    textureLoader.load(import.meta.env.BASE_URL + 'assets/textures/earth-topology.png', (t) => {
      globeMat.bumpMap = t;
      globeMat.needsUpdate = true;
      checkLoaded();
    }, undefined, () => checkLoaded());
  } else {
    checkLoaded(); // Skip bump map on mobile/tablet
  }

  // ── ATMOSPHERE ──
  const atmoVS = `varying vec3 vNormal; void main() { vNormal = normalize(normalMatrix * normal); gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0); }`;
  const atmoFS = `varying vec3 vNormal; void main() { float i = pow(0.65 - dot(vNormal, vec3(0,0,1)), 3.0); gl_FragColor = vec4(0.15,0.55,0.7,1) * i * 0.7; }`;
  scene.add(new THREE.Mesh(
    new THREE.SphereGeometry(GLOBE_RADIUS * 1.12, isMobile ? 32 : 64, isMobile ? 32 : 64),
    new THREE.ShaderMaterial({ vertexShader: atmoVS, fragmentShader: atmoFS, blending: THREE.AdditiveBlending, side: THREE.BackSide, transparent: true, depthWrite: false })
  ));

  // ── UTILITY ──
  function latLonToVec3(lat: number, lon: number, r: number) {
    const phi = (90 - lat) * Math.PI / 180;
    const theta = -lon * Math.PI / 180;
    return new THREE.Vector3(r * Math.sin(phi) * Math.cos(theta), r * Math.cos(phi), r * Math.sin(phi) * Math.sin(theta));
  }

  // ── ZEE ZONES (real GeoJSON polygons with earcut) ──
  const zoneMeshes: THREE.Mesh[] = [];
  const zoneGroup = new THREE.Group();
  scene.add(zoneGroup);
  const zoneObjects: { mesh: THREE.Mesh; borderLine: THREE.Line | null }[] = [];

  function normalizeLon(ring: number[][]) {
    let maxJump = 0;
    for (let i = 1; i < ring.length; i++) {
      maxJump = Math.max(maxJump, Math.abs(ring[i][0] - ring[i - 1][0]));
    }
    if (maxJump <= 180) return ring;
    return ring.map(p => [p[0] < 0 ? p[0] + 360 : p[0], p[1]]);
  }

  function createZeeMesh(outerPts: number[][], holePtsArray: number[][][] | null, properties: any) {
    const flat: number[] = [];
    for (const pt of outerPts) flat.push(pt[0], pt[1]);

    const holeIndices: number[] = [];
    if (holePtsArray) {
      for (const hole of holePtsArray) {
        if (hole.length < 3) continue;
        holeIndices.push(flat.length / 2);
        for (const pt of hole) flat.push(pt[0], pt[1]);
      }
    }

    let triIndices: number[];
    try {
      triIndices = earcut(flat, holeIndices.length > 0 ? holeIndices : undefined, 2);
    } catch (e) { return null; }
    if (!triIndices || triIndices.length === 0) return null;

    // Subdivide large triangles so they follow the globe curvature
    // instead of cutting through the sphere interior
    const MAX_ARC_DEG = 3; // max degrees between vertices
    function subdivideTriangles(indices: number[], flatCoords: number[]): { positions: Float32Array; indices: number[] } {
      const outVerts: number[] = [];
      const outIdx: number[] = [];
      const vertMap = new Map<string, number>();

      function addVert(lo: number, la: number): number {
        const key = lo.toFixed(4) + ',' + la.toFixed(4);
        if (vertMap.has(key)) return vertMap.get(key)!;
        let lon2 = lo; if (lon2 > 180) lon2 -= 360;
        const v = latLonToVec3(la, lon2, ZEE_HEIGHT);
        const idx = outVerts.length / 3;
        outVerts.push(v.x, v.y, v.z);
        vertMap.set(key, idx);
        return idx;
      }

      function subdivideTri(a: [number, number], b: [number, number], c: [number, number], depth: number) {
        const dAB = Math.sqrt((a[0]-b[0])**2 + (a[1]-b[1])**2);
        const dBC = Math.sqrt((b[0]-c[0])**2 + (b[1]-c[1])**2);
        const dCA = Math.sqrt((c[0]-a[0])**2 + (c[1]-a[1])**2);
        const maxEdge = Math.max(dAB, dBC, dCA);
        if (maxEdge <= MAX_ARC_DEG || depth > 5) {
          outIdx.push(addVert(a[0], a[1]), addVert(b[0], b[1]), addVert(c[0], c[1]));
          return;
        }
        const mAB: [number, number] = [(a[0]+b[0])/2, (a[1]+b[1])/2];
        const mBC: [number, number] = [(b[0]+c[0])/2, (b[1]+c[1])/2];
        const mCA: [number, number] = [(c[0]+a[0])/2, (c[1]+a[1])/2];
        subdivideTri(a, mAB, mCA, depth+1);
        subdivideTri(mAB, b, mBC, depth+1);
        subdivideTri(mCA, mBC, c, depth+1);
        subdivideTri(mAB, mBC, mCA, depth+1);
      }

      for (let i = 0; i < indices.length; i += 3) {
        const iA = indices[i], iB = indices[i+1], iC = indices[i+2];
        const a: [number, number] = [flatCoords[iA*2], flatCoords[iA*2+1]];
        const b: [number, number] = [flatCoords[iB*2], flatCoords[iB*2+1]];
        const c: [number, number] = [flatCoords[iC*2], flatCoords[iC*2+1]];
        subdivideTri(a, b, c, 0);
      }
      return { positions: new Float32Array(outVerts), indices: outIdx };
    }

    const subdiv = subdivideTriangles(triIndices, flat);
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(subdiv.positions, 3));
    geo.setIndex(subdiv.indices);
    geo.computeVertexNormals();

    const mesh = new THREE.Mesh(geo, new THREE.MeshBasicMaterial({
      color: 0x00b4b4, transparent: true, opacity: 0.22, side: THREE.DoubleSide, depthWrite: false
    }));
    mesh.userData = {
      isZEE: true,
      zone: {
        name: properties.geoname || properties.territory1 || 'ZEE France',
        detail: properties.detail || properties.sovereign1 || 'France',
        area: properties.area_km2 || 0
      }
    };
    mesh.renderOrder = 1;
    zoneGroup.add(mesh);
    zoneMeshes.push(mesh);

    // Border
    const borderPts: THREE.Vector3[] = [];
    for (const pt of outerPts) {
      let lon = pt[0]; if (lon > 180) lon -= 360;
      borderPts.push(latLonToVec3(pt[1], lon, ZEE_HEIGHT * 1.0005));
    }
    if (borderPts.length > 2) borderPts.push(borderPts[0].clone());

    let borderLine: THREE.Line | null = null;
    if (borderPts.length >= 2) {
      borderLine = new THREE.Line(
        new THREE.BufferGeometry().setFromPoints(borderPts),
        new THREE.LineBasicMaterial({ color: 0x00e0e0, transparent: true, opacity: 0.55 })
      );
      borderLine.renderOrder = 2;
      zoneGroup.add(borderLine);
    }

    return { mesh, borderLine };
  }

  function processEEZ(geojson: any) {
    if (!geojson || !geojson.features) return;
    for (const feature of geojson.features) {
      const geom = feature.geometry;
      const props = feature.properties || {};
      if (!geom) continue;

      const coordsList: number[][][] = [];
      if (geom.type === 'Polygon') coordsList.push(geom.coordinates);
      else if (geom.type === 'MultiPolygon') {
        for (const poly of geom.coordinates) coordsList.push(poly);
      }

      for (const coords of coordsList) {
        const outer = coords[0];
        if (!outer || outer.length < 3) continue;
        const normOuter = normalizeLon(outer);
        const holes: number[][][] = [];
        for (let h = 1; h < coords.length; h++) {
          if (coords[h] && coords[h].length >= 3) holes.push(normalizeLon(coords[h]));
        }
        const result = createZeeMesh(normOuter, holes, props);
        if (result) zoneObjects.push(result);
      }
    }
  }

  processEEZ(EEZ_GEOJSON);

  // ── STARFIELD ──
  const starPos = new Float32Array(2000 * 3);
  for (let i = 0; i < 2000; i++) {
    const r = 15 + Math.random() * 35;
    const t = Math.random() * Math.PI * 2;
    const p = Math.acos(2 * Math.random() - 1);
    starPos[i*3] = r * Math.sin(p) * Math.cos(t);
    starPos[i*3+1] = r * Math.sin(p) * Math.sin(t);
    starPos[i*3+2] = r * Math.cos(p);
  }
  const starGeo = new THREE.BufferGeometry();
  starGeo.setAttribute('position', new THREE.Float32BufferAttribute(starPos, 3));
  scene.add(new THREE.Points(starGeo, new THREE.PointsMaterial({ color: 0xaabbdd, size: 0.04, transparent: true, opacity: 0.6, sizeAttenuation: true, depthWrite: false })));

  // ── SUBMARINE CABLES ──
  const cableGroup = new THREE.Group();
  scene.add(cableGroup);

  function splitCableCoords(coords: number[][]) {
    const segments: number[][][] = [];
    let current: number[][] = [];
    for (let i = 0; i < coords.length; i++) {
      const lon = coords[i][0], lat = coords[i][1];
      if (isNaN(lat) || isNaN(lon)) continue;
      if (current.length > 0) {
        const prevLon = current[current.length - 1][0];
        if (Math.abs(lon - prevLon) > 90) {
          const lon1 = current[current.length - 1][0], lat1 = current[current.length - 1][1];
          let lon2 = lon;
          if (lon2 - lon1 > 180) lon2 -= 360;
          else if (lon1 - lon2 > 180) lon2 += 360;
          const crossLon = lon1 > 0 ? 180 : -180;
          const t = (lon2 - lon1) !== 0 ? (crossLon - lon1) / (lon2 - lon1) : 0.5;
          const crossLat = lat1 + t * (lat - lat1);
          current.push([crossLon, crossLat]);
          if (current.length >= 2) segments.push(current);
          current = [[-crossLon, crossLat], [lon, lat]];
          continue;
        }
      }
      current.push([lon, lat]);
    }
    if (current.length >= 2) segments.push(current);
    return segments;
  }

  function processCables(geojson: any) {
    if (!geojson || !geojson.features) return;
    for (const feature of geojson.features) {
      const geom = feature.geometry;
      if (!geom) continue;
      const colorVal = feature.properties && feature.properties.c;
      let cableColor: THREE.Color;
      try { cableColor = new THREE.Color(colorVal || '#00b4b4'); }
      catch { cableColor = new THREE.Color(0x00b4b4); }

      const coordSets: number[][][] = [];
      if (geom.type === 'MultiLineString') coordSets.push(...geom.coordinates);
      else if (geom.type === 'LineString') coordSets.push(geom.coordinates);

      for (const coords of coordSets) {
        for (const seg of splitCableCoords(coords)) {
          const pts: THREE.Vector3[] = [];
          for (let i = 0; i < seg.length; i++) {
            const lon = seg[i][0], lat = seg[i][1];
            if (pts.length === 0) {
              pts.push(latLonToVec3(lat, lon, CABLE_RADIUS));
            } else {
              const prevLon = seg[i - 1][0], prevLat = seg[i - 1][1];
              const interp = interpolateGreatCircle(prevLat, prevLon, lat, lon, CABLE_RADIUS, 5);
              pts.push(...interp);
            }
          }
          if (pts.length < 2) continue;
          const line = new THREE.Line(
            new THREE.BufferGeometry().setFromPoints(pts),
            new THREE.LineBasicMaterial({ color: cableColor, transparent: true, opacity: 0.35, depthWrite: false })
          );
          line.renderOrder = 3;
          cableGroup.add(line);
        }
      }
    }
  }

  processCables(CABLE_GEOJSON);

  // ── SHIPPING LANES ──
  const trafficGroup = new THREE.Group();
  scene.add(trafficGroup);

  const LANE_STYLES: Record<number, { color: number; opacity: number }> = {
    1: { color: 0xff8c50, opacity: 0.90 },
    2: { color: 0xff7040, opacity: 0.60 },
    3: { color: 0xff6432, opacity: 0.32 }
  };

  // Great-circle interpolation: fill gaps between distant consecutive points
  // so lines follow the globe surface instead of cutting through the interior
  function interpolateGreatCircle(lat1: number, lon1: number, lat2: number, lon2: number, r: number, maxGapDeg: number): THREE.Vector3[] {
    const dLat = lat2 - lat1, dLon = lon2 - lon1;
    const gap = Math.sqrt(dLat * dLat + dLon * dLon);
    if (gap <= maxGapDeg) return [latLonToVec3(lat2, lon2, r)];
    const steps = Math.ceil(gap / maxGapDeg);
    const pts: THREE.Vector3[] = [];
    for (let s = 1; s <= steps; s++) {
      const t = s / steps;
      pts.push(latLonToVec3(lat1 + dLat * t, lon1 + dLon * t, r));
    }
    return pts;
  }

  (SHIPPING_LANES as any).features.forEach((feat: any) => {
    const style = LANE_STYLES[feat.properties.t as number];
    if (!style) return;
    const mat = new THREE.LineBasicMaterial({ color: style.color, transparent: true, opacity: style.opacity, depthWrite: false });
    feat.geometry.coordinates.forEach((line: number[][]) => {
      const points: THREE.Vector3[] = [];
      for (let i = 0; i < line.length; i++) {
        const lon = line[i][0], lat = line[i][1];
        if (isNaN(lat) || isNaN(lon)) continue;
        if (points.length === 0) {
          points.push(latLonToVec3(lat, lon, LANE_RADIUS));
        } else {
          const prevLon = line[i - 1][0], prevLat = line[i - 1][1];
          const interp = interpolateGreatCircle(prevLat, prevLon, lat, lon, LANE_RADIUS, 5);
          points.push(...interp);
        }
      }
      if (points.length >= 2) {
        trafficGroup.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), mat));
      }
    });
  });

  // ── LAYER TOGGLES ──
  const layerVis: Record<string, boolean> = { zee: true, cables: true, traffic: true };
  document.querySelectorAll('#legend .legend-item[data-layer]').forEach(item => {
    item.addEventListener('click', () => {
      const l = (item as HTMLElement).dataset.layer!;
      layerVis[l] = !layerVis[l];
      item.classList.toggle('disabled', !layerVis[l]);
      if (l === 'zee') zoneGroup.visible = layerVis.zee;
      else if (l === 'cables') cableGroup.visible = layerVis.cables;
      else if (l === 'traffic') trafficGroup.visible = layerVis.traffic;
      const statEl = document.querySelector(`#total-counter .stat-item[data-stat="${l}"]`);
      if (statEl) statEl.classList.toggle('hidden', !layerVis[l]);
    });
  });

  // ── RAYCASTING ──
  const raycaster = new THREE.Raycaster();
  const mouse = new THREE.Vector2(-999, -999);
  let hoveredZone: any = null;
  let isInteracting = false;

  container.addEventListener('pointermove', (e) => {
    const rect = container.getBoundingClientRect();
    mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
    mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
    tooltip.style.left = (e.clientX + 18) + 'px';
    tooltip.style.top = (e.clientY - 10) + 'px';
    const tooltipRect = tooltip.getBoundingClientRect();
    if (tooltipRect.right > window.innerWidth - 10) tooltip.style.left = (e.clientX - tooltipRect.width - 18) + 'px';
    if (tooltipRect.bottom > window.innerHeight - 10) tooltip.style.top = (e.clientY - tooltipRect.height - 10) + 'px';
  });

  container.addEventListener('pointerdown', () => { isInteracting = true; controls.autoRotate = false; });
  container.addEventListener('pointerup', () => {
    isInteracting = false;
    clearTimeout((window as any)._globeResumeTimer);
    (window as any)._globeResumeTimer = setTimeout(() => { if (!isInteracting) controls.autoRotate = true; }, 3000);
  });

  function formatArea(km2: number) {
    if (!km2 || km2 === 0) return '';
    return km2 >= 1000000 ? (km2/1000000).toFixed(1).replace('.', ',') + ' M km\u00B2' : km2.toLocaleString('fr-FR') + ' km\u00B2';
  }

  function highlightZone(zone: any) {
    for (const obj of zoneObjects) {
      if (obj.mesh.userData.zone === zone) {
        (obj.mesh.material as THREE.MeshBasicMaterial).opacity = 0.45;
        (obj.mesh.material as THREE.MeshBasicMaterial).color.set(0x00e8e8);
        if (obj.borderLine) {
          (obj.borderLine.material as THREE.LineBasicMaterial).opacity = 0.9;
          (obj.borderLine.material as THREE.LineBasicMaterial).color.set(0x00ffff);
        }
        break;
      }
    }
  }

  function resetZone(zone: any) {
    for (const obj of zoneObjects) {
      if (obj.mesh.userData.zone === zone) {
        (obj.mesh.material as THREE.MeshBasicMaterial).opacity = 0.22;
        (obj.mesh.material as THREE.MeshBasicMaterial).color.set(0x00b4b4);
        if (obj.borderLine) {
          (obj.borderLine.material as THREE.LineBasicMaterial).opacity = 0.55;
          (obj.borderLine.material as THREE.LineBasicMaterial).color.set(0x00e0e0);
        }
        break;
      }
    }
  }

  // ── ANIMATION ──
  let fc = 0;
  function animate() {
    requestAnimationFrame(animate);
    fc++;
    controls.update();

    if (fc % 2 === 0) {
      const pulse = 0.18 + Math.sin(fc * 0.015) * 0.04;
      for (const obj of zoneObjects) {
        if (obj.mesh.userData.zone !== hoveredZone) (obj.mesh.material as THREE.MeshBasicMaterial).opacity = pulse;
      }
    }

    // Hover check
    raycaster.setFromCamera(mouse, camera);
    const hits = raycaster.intersectObjects(zoneMeshes);
    if (hits.length > 0) {
      const z = hits[0].object.userData.zone;
      if (hoveredZone !== z) { if (hoveredZone) resetZone(hoveredZone); hoveredZone = z; highlightZone(z); }
      tooltipName.textContent = z.name;
      tooltipArea.textContent = formatArea(z.area);
      tooltipDetail.textContent = z.detail;
      tooltip.classList.add('visible');
      container.style.cursor = 'pointer';
    } else {
      if (hoveredZone) { resetZone(hoveredZone); hoveredZone = null; }
      tooltip.classList.remove('visible');
      container.style.cursor = isInteracting ? 'grabbing' : 'grab';
    }

    renderer.render(scene, camera);
  }

  const ro = new ResizeObserver(() => {
    const w = container.clientWidth, h = container.clientHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  });
  ro.observe(container);

  animate();

  // ── DOWNLOAD HANDLER ──
  const dlWrap = document.getElementById('globe-download-wrap');
  const dlBtn = document.getElementById('globe-download-btn');
  const dlPng = document.getElementById('dl-png');
  const dlGif = document.getElementById('dl-gif');

  if (dlBtn && dlWrap) {
    dlBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      dlWrap.classList.toggle('open');
    });
    document.addEventListener('click', () => dlWrap.classList.remove('open'));

    function captureFrame() {
      renderer.render(scene, camera);
      const srcCanvas = renderer.domElement;
      const offscreen = document.createElement('canvas');
      offscreen.width = srcCanvas.width;
      offscreen.height = srcCanvas.height;
      const octx = offscreen.getContext('2d')!;
      octx.drawImage(srcCanvas, 0, 0);
      const scale = srcCanvas.width / container.clientWidth;
      const fontSize = Math.round(12 * scale);
      octx.font = `400 ${fontSize}px Poppins, sans-serif`;
      octx.fillStyle = 'rgba(255,255,255,0.45)';
      octx.textAlign = 'right';
      octx.textBaseline = 'bottom';
      octx.fillText('Conçu par Colomban 🔵', offscreen.width - 20 * scale, offscreen.height - 16 * scale);
      return offscreen;
    }

    // PNG download
    dlPng?.addEventListener('click', (e) => {
      e.stopPropagation();
      dlWrap.classList.remove('open');
      const link = document.createElement('a');
      link.download = 'globe-colomban.png';
      link.href = captureFrame().toDataURL('image/png');
      link.click();
    });

    // GIF download — capture frames during a full rotation
    dlGif?.addEventListener('click', async (e) => {
      e.stopPropagation();
      dlWrap.classList.remove('open');

      // Show progress
      const origText = dlBtn.querySelector('.mono')!;
      const origLabel = origText.textContent;
      origText.textContent = 'Capture 0%...';
      dlBtn.style.pointerEvents = 'none';

      // Pause auto-rotate, save current state
      const savedAutoRotate = controls.autoRotate;
      const savedRotateSpeed = controls.autoRotateSpeed;
      controls.autoRotate = false;

      // Capture at good resolution for quality
      const captureW = 640;
      const captureH = Math.round(captureW * container.clientHeight / container.clientWidth);
      const totalFrames = 48; // 48 frames for smoother rotation
      const frames: HTMLCanvasElement[] = [];

      // Save camera position and rotate manually
      const startAzimuth = controls.getAzimuthalAngle();

      for (let i = 0; i < totalFrames; i++) {
        // Rotate globe by setting azimuthal angle
        const angle = startAzimuth + (i / totalFrames) * Math.PI * 2;
        const polar = controls.getPolarAngle();
        const dist = camera.position.length();
        camera.position.x = dist * Math.sin(polar) * Math.sin(angle);
        camera.position.z = dist * Math.sin(polar) * Math.cos(angle);
        camera.position.y = dist * Math.cos(polar);
        camera.lookAt(0, 0, 0);
        controls.update();

        renderer.render(scene, camera);

        // Capture at reduced resolution
        const frame = document.createElement('canvas');
        frame.width = captureW;
        frame.height = captureH;
        const fctx = frame.getContext('2d')!;
        fctx.drawImage(renderer.domElement, 0, 0, captureW, captureH);

        // Watermark on last frame area
        const fScale = captureW / container.clientWidth;
        const fSize = Math.max(9, Math.round(12 * fScale));
        fctx.font = `400 ${fSize}px Poppins, sans-serif`;
        fctx.fillStyle = 'rgba(255,255,255,0.45)';
        fctx.textAlign = 'right';
        fctx.textBaseline = 'bottom';
        fctx.fillText('Conçu par Colomban 🔵', captureW - 8, captureH - 6);

        frames.push(frame);
        origText.textContent = `Capture ${Math.round((i + 1) / totalFrames * 100)}%...`;

        // Yield to keep UI responsive
        await new Promise(r => setTimeout(r, 0));
      }

      // Restore camera
      const restoreAngle = startAzimuth;
      const polarR = controls.getPolarAngle();
      const distR = camera.position.length();
      camera.position.x = distR * Math.sin(polarR) * Math.sin(restoreAngle);
      camera.position.z = distR * Math.sin(polarR) * Math.cos(restoreAngle);
      camera.position.y = distR * Math.cos(polarR);
      camera.lookAt(0, 0, 0);
      controls.autoRotate = savedAutoRotate;
      controls.autoRotateSpeed = savedRotateSpeed;

      origText.textContent = 'Encodage GIF...';

      // Encode GIF using simple encoder
      await new Promise(r => setTimeout(r, 50));
      const gifBlob = await encodeGif(frames, captureW, captureH, 60);

      const link = document.createElement('a');
      link.download = 'globe-colomban.gif';
      link.href = URL.createObjectURL(gifBlob);
      link.click();
      URL.revokeObjectURL(link.href);

      origText.textContent = origLabel;
      dlBtn.style.pointerEvents = '';
    });
  }

  // ── GIF ENCODER with median-cut quantization + Floyd-Steinberg dithering ──

  // Median-cut color quantization to 256 colors
  function medianCut(pixels: Uint8ClampedArray, pixelCount: number, maxColors: number): number[][] {
    // Sample pixels (max 50k for performance)
    const sampleStep = Math.max(1, Math.floor(pixelCount / 50000));
    const colors: number[][] = [];
    for (let i = 0; i < pixelCount; i += sampleStep) {
      colors.push([pixels[i * 4], pixels[i * 4 + 1], pixels[i * 4 + 2]]);
    }

    type Box = { colors: number[][]; rMin: number; rMax: number; gMin: number; gMax: number; bMin: number; bMax: number };

    function makeBox(cols: number[][]): Box {
      let rMin = 255, rMax = 0, gMin = 255, gMax = 0, bMin = 255, bMax = 0;
      for (const c of cols) {
        if (c[0] < rMin) rMin = c[0]; if (c[0] > rMax) rMax = c[0];
        if (c[1] < gMin) gMin = c[1]; if (c[1] > gMax) gMax = c[1];
        if (c[2] < bMin) bMin = c[2]; if (c[2] > bMax) bMax = c[2];
      }
      return { colors: cols, rMin, rMax, gMin, gMax, bMin, bMax };
    }

    function splitBox(box: Box): [Box, Box] {
      const rRange = box.rMax - box.rMin;
      const gRange = box.gMax - box.gMin;
      const bRange = box.bMax - box.bMin;
      const channel = rRange >= gRange && rRange >= bRange ? 0 : gRange >= bRange ? 1 : 2;
      box.colors.sort((a, b) => a[channel] - b[channel]);
      const mid = Math.floor(box.colors.length / 2);
      return [makeBox(box.colors.slice(0, mid)), makeBox(box.colors.slice(mid))];
    }

    let boxes: Box[] = [makeBox(colors)];
    while (boxes.length < maxColors) {
      // Find largest box by volume * population
      let bestIdx = 0, bestScore = 0;
      for (let i = 0; i < boxes.length; i++) {
        const b = boxes[i];
        if (b.colors.length < 2) continue;
        const vol = (b.rMax - b.rMin + 1) * (b.gMax - b.gMin + 1) * (b.bMax - b.bMin + 1);
        const score = vol * b.colors.length;
        if (score > bestScore) { bestScore = score; bestIdx = i; }
      }
      if (bestScore === 0) break;
      const [a, b] = splitBox(boxes[bestIdx]);
      boxes.splice(bestIdx, 1, a, b);
    }

    // Average each box to get palette color
    return boxes.map(box => {
      let rSum = 0, gSum = 0, bSum = 0;
      for (const c of box.colors) { rSum += c[0]; gSum += c[1]; bSum += c[2]; }
      const n = box.colors.length;
      return [Math.round(rSum / n), Math.round(gSum / n), Math.round(bSum / n)];
    });
  }

  // Find nearest palette color
  function nearestColor(r: number, g: number, b: number, palette: number[][]): number {
    let bestIdx = 0, bestDist = Infinity;
    for (let i = 0; i < palette.length; i++) {
      const dr = r - palette[i][0], dg = g - palette[i][1], db = b - palette[i][2];
      const dist = dr * dr + dg * dg + db * db;
      if (dist < bestDist) { bestDist = dist; bestIdx = i; }
    }
    return bestIdx;
  }

  async function encodeGif(frames: HTMLCanvasElement[], w: number, h: number, delay: number): Promise<Blob> {
    const buf: number[] = [];
    // GIF89a header
    buf.push(0x47, 0x49, 0x46, 0x38, 0x39, 0x61);
    // Logical screen descriptor
    buf.push(w & 0xff, (w >> 8) & 0xff, h & 0xff, (h >> 8) & 0xff);
    buf.push(0x70, 0x00, 0x00); // no GCT, 8-bit color

    // Netscape extension for looping
    buf.push(0x21, 0xff, 0x0b);
    const ns = 'NETSCAPE2.0';
    for (let i = 0; i < 11; i++) buf.push(ns.charCodeAt(i));
    buf.push(0x03, 0x01, 0x00, 0x00, 0x00); // loop forever

    for (const frame of frames) {
      const ctx = frame.getContext('2d')!;
      const imgData = ctx.getImageData(0, 0, w, h);
      const pixels = imgData.data;

      // Build adaptive 256-color palette via median cut
      const palette = medianCut(pixels, w * h, 256);
      while (palette.length < 256) palette.push([0, 0, 0]); // pad to 256

      // Floyd-Steinberg dithering + index mapping
      const indices = new Uint8Array(w * h);
      const errR = new Float32Array(w * h);
      const errG = new Float32Array(w * h);
      const errB = new Float32Array(w * h);

      // Initialize error buffer with pixel values
      for (let i = 0; i < w * h; i++) {
        errR[i] = pixels[i * 4];
        errG[i] = pixels[i * 4 + 1];
        errB[i] = pixels[i * 4 + 2];
      }

      for (let y = 0; y < h; y++) {
        for (let x = 0; x < w; x++) {
          const idx = y * w + x;
          const cr = Math.max(0, Math.min(255, Math.round(errR[idx])));
          const cg = Math.max(0, Math.min(255, Math.round(errG[idx])));
          const cb = Math.max(0, Math.min(255, Math.round(errB[idx])));

          const pi = nearestColor(cr, cg, cb, palette);
          indices[idx] = pi;

          const eR = cr - palette[pi][0];
          const eG = cg - palette[pi][1];
          const eB = cb - palette[pi][2];

          // Distribute error to neighbors
          if (x + 1 < w) {
            errR[idx + 1] += eR * 7 / 16; errG[idx + 1] += eG * 7 / 16; errB[idx + 1] += eB * 7 / 16;
          }
          if (y + 1 < h) {
            if (x > 0) {
              errR[idx + w - 1] += eR * 3 / 16; errG[idx + w - 1] += eG * 3 / 16; errB[idx + w - 1] += eB * 3 / 16;
            }
            errR[idx + w] += eR * 5 / 16; errG[idx + w] += eG * 5 / 16; errB[idx + w] += eB * 5 / 16;
            if (x + 1 < w) {
              errR[idx + w + 1] += eR * 1 / 16; errG[idx + w + 1] += eG * 1 / 16; errB[idx + w + 1] += eB * 1 / 16;
            }
          }
        }
      }

      // Graphic control extension
      buf.push(0x21, 0xf9, 0x04, 0x00);
      buf.push(delay & 0xff, (delay >> 8) & 0xff);
      buf.push(0x00, 0x00);

      // Image descriptor
      buf.push(0x2c, 0x00, 0x00, 0x00, 0x00);
      buf.push(w & 0xff, (w >> 8) & 0xff, h & 0xff, (h >> 8) & 0xff);
      buf.push(0x87); // local color table, 8 bits (256 colors)

      // Local color table
      for (let i = 0; i < 256; i++) {
        buf.push(palette[i][0], palette[i][1], palette[i][2]);
      }

      // LZW compress
      const minCodeSize = 8;
      buf.push(minCodeSize);
      const lzwData = lzwEncode(indices, minCodeSize);

      // Write sub-blocks
      let offset = 0;
      while (offset < lzwData.length) {
        const chunkSize = Math.min(255, lzwData.length - offset);
        buf.push(chunkSize);
        for (let i = 0; i < chunkSize; i++) buf.push(lzwData[offset + i]);
        offset += chunkSize;
      }
      buf.push(0x00); // block terminator
    }

    buf.push(0x3b); // GIF trailer
    return new Blob([new Uint8Array(buf)], { type: 'image/gif' });
  }

  function lzwEncode(indices: Uint8Array, minCodeSize: number): number[] {
    const clearCode = 1 << minCodeSize;
    const eoiCode = clearCode + 1;
    let codeSize = minCodeSize + 1;
    let nextCode = eoiCode + 1;
    const maxCode = 4096;

    // Initialize dictionary
    let dict = new Map<string, number>();
    for (let i = 0; i < clearCode; i++) dict.set(String(i), i);

    const output: number[] = [];
    let bitBuf = 0;
    let bitCount = 0;

    function writeBits(code: number, size: number) {
      bitBuf |= code << bitCount;
      bitCount += size;
      while (bitCount >= 8) {
        output.push(bitBuf & 0xff);
        bitBuf >>= 8;
        bitCount -= 8;
      }
    }

    writeBits(clearCode, codeSize);

    let current = String(indices[0]);
    for (let i = 1; i < indices.length; i++) {
      const next = current + ',' + indices[i];
      if (dict.has(next)) {
        current = next;
      } else {
        writeBits(dict.get(current)!, codeSize);
        if (nextCode < maxCode) {
          dict.set(next, nextCode++);
          if (nextCode > (1 << codeSize) && codeSize < 12) codeSize++;
        } else {
          writeBits(clearCode, codeSize);
          dict = new Map<string, number>();
          for (let j = 0; j < clearCode; j++) dict.set(String(j), j);
          nextCode = eoiCode + 1;
          codeSize = minCodeSize + 1;
        }
        current = String(indices[i]);
      }
    }
    writeBits(dict.get(current)!, codeSize);
    writeBits(eoiCode, codeSize);

    if (bitCount > 0) output.push(bitBuf & 0xff);
    return output;
  }

  } // end of else (container visible)
</script>
