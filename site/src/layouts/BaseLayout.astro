---
import '../styles/global.css';
import { getHrefLangUrls, getLocalizedPath, getAlternateLang, useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  frSlug?: string; // FR route slug for hreflang mapping (e.g. 'a-propos', '' for home)
}

const {
  title,
  description = "Le quartier general digital de la triple transition maritime, porte par Colomban.",
  lang = "fr",
  frSlug = "",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const t = useTranslations(lang);
const hrefLangs = getHrefLangUrls(frSlug);
const altLang = getAlternateLang(lang);
const altPath = getLocalizedPath(altLang, frSlug);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Security -->
  <meta http-equiv="X-Content-Type-Options" content="nosniff" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />

  <!-- Canonical & hreflang -->
  <link rel="canonical" href={`https://colombanatsea.github.io${Astro.url.pathname}`} />
  <link rel="alternate" hreflang="fr" href={hrefLangs.fr} />
  <link rel="alternate" hreflang="en" href={hrefLangs.en} />
  <link rel="alternate" hreflang="x-default" href={hrefLangs.fr} />

  <!-- Sitemap -->
  <link rel="sitemap" href={`${base}/sitemap.xml`} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- JSON-LD Person Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Colomban",
    "alternateName": "Colomban Monnier",
    "jobTitle": "Delegue General du GASPE",
    "url": "https://colombanatsea.com",
    "description": "Le quartier general digital de la triple transition maritime",
    "image": `https://colombanatsea.github.io${base}/og-image.jpg`,
    "sameAs": [
      "https://www.linkedin.com/in/colombanatsea/",
      "https://www.instagram.com/colombanatsea/",
      "https://www.youtube.com/@Colombanatsea",
      "https://www.tiktok.com/@colombanatsea"
    ],
    "knowsAbout": ["Maritime", "Decarbonation", "Digitalisation", "Intelligence Artificielle", "Transition maritime"],
    "affiliation": [
      { "@type": "Organization", "name": "GASPE" },
      { "@type": "Organization", "name": "VAIATA Dynamics" },
      { "@type": "Organization", "name": "Fondation ENSM" }
    ]
  })} />

  <!-- Fonts — non-blocking -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400&display=swap"
    rel="stylesheet"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
  </noscript>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content={lang === "fr" ? "fr_FR" : "en_US"} />
  <meta property="og:url" content={`https://colombanatsea.github.io${Astro.url.pathname}`} />
  <meta property="og:image" content={`https://colombanatsea.github.io${base}/og-image.jpg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Colomban at Sea" />
  <meta name="twitter:image" content={`https://colombanatsea.github.io${base}/og-image.jpg`} />
</head>
<body>
  <nav class="nav" id="nav">
    <div class="nav__inner container">
      <a href={`${base}/`} class="nav__logo" aria-label="Colomban at Sea — Accueil">
        <img class="nav__knot nav__knot--dark" src={`${base}/colomban-logo-normal.svg`} alt="Colomban" width="32" height="32" />
        <img class="nav__knot nav__knot--light" src={`${base}/colomban-logo-original.svg`} alt="Colomban" width="32" height="32" />
        <span class="nav__logo-text">Colomban<span class="nav__logo-accent"> at sea</span></span>
      </a>

      <button class="nav__toggle" id="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

      <ul class="nav__links" id="nav-links">
        <li><a href={getLocalizedPath(lang, '') + '#vision'}>{t('nav.vision')}</a></li>
        <li><a href={getLocalizedPath(lang, 'a-propos')}>{t('nav.about')}</a></li>
        <li><a href={getLocalizedPath(lang, 'engagements')}>{t('nav.engagements')}</a></li>
        <li><a href={getLocalizedPath(lang, 'prises-de-parole')}>{t('nav.speaking')}</a></li>
        <li><a href={getLocalizedPath(lang, 'medias')}>{t('nav.media')}</a></li>
        <li><a href={getLocalizedPath(lang, 'contact')} class="btn btn-primary btn-sm">{t('nav.contact')}</a></li>
        <li><a href={altPath} class="nav__lang" aria-label={`Switch to ${altLang === 'en' ? 'English' : 'Francais'}`}>{altLang.toUpperCase()}</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer section-dark">
    <div class="container footer__inner">
      <div class="footer__brand">
        <div class="footer__logo-row">
          <img class="nav__knot" src={`${base}/colomban-logo-normal.svg`} alt="Colomban" width="32" height="32" />
          <span class="nav__logo-text">Colomban<span class="nav__logo-accent"> at sea</span></span>
        </div>
        <p class="footer__tagline subtitle">Une nation libre regarde la mer.</p>
      </div>

      <div class="footer__links">
        <div class="footer__col">
          <h4>{t('footer.navigation')}</h4>
          <a href={getLocalizedPath(lang, 'a-propos')}>{t('nav.about')}</a>
          <a href={getLocalizedPath(lang, 'engagements')}>{t('nav.engagements')}</a>
          <a href={getLocalizedPath(lang, 'prises-de-parole')}>{t('nav.speaking')}</a>
          <a href={getLocalizedPath(lang, 'medias')}>{t('nav.media')}</a>
        </div>
        <div class="footer__col">
          <h4>{t('footer.follow')}</h4>
          <a href="https://www.linkedin.com/in/colombanatsea/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://www.instagram.com/colombanatsea/" target="_blank" rel="noopener noreferrer">Instagram</a>
          <a href="https://www.youtube.com/@Colombanatsea" target="_blank" rel="noopener noreferrer">YouTube</a>
          <a href="https://www.tiktok.com/@colombanatsea" target="_blank" rel="noopener noreferrer">TikTok</a>
        </div>
        <div class="footer__col">
          <h4>{t('footer.links')}</h4>
          <a href="https://aperitifsdelamer.com" target="_blank" rel="noopener noreferrer">Aperitifs de la Mer</a>
          <a href={getLocalizedPath(lang, 'mentions-legales')}>{t('footer.legal')}</a>
          <a href={getLocalizedPath(lang, 'politique-confidentialite')}>{t('footer.privacy')}</a>
        </div>
      </div>

      <div class="footer__citation">
        <p class="footer__quote" id="footer-quote"></p>
      </div>

      <div class="footer__bottom">
        <p class="mono text-muted">&copy; {new Date().getFullYear()} Colomban — colombanatsea.com</p>
      </div>
    </div>
  </footer>

  <script>
    // Scroll-triggered stagger animations
    const staggerObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          staggerObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.stagger').forEach((el) => staggerObserver.observe(el));
  </script>

  <script>
    // Rotating footer citations
    const quotes = [
      "Le maritime dans le sang depuis 1991.",
      "La transition du maritime en oubliant l\u2019aspect social, c\u2019est de la plaisance particuli\u00e8re.",
      "Une nation libre regarde la mer.",
      "Comme le continent africain n\u2019est pas pass\u00e9 par la t\u00e9l\u00e9phonie fixe, le maritime ne doit pas passer par la num\u00e9risation\u00a0: il doit entrer imm\u00e9diatement dans l\u2019\u00e8re de la digitalisation.",
      "Les r\u00e9volutions environnementale et digitale du maritime sont avant tout une r\u00e9volution culturelle.",
      "Il est plus efficient de suivre 4 donn\u00e9es bien cibl\u00e9es en sachant ce qu\u2019on veut en faire, que d\u00e9penser de l\u2019\u00e9nergie pour suivre des millions de donn\u00e9es sans objectif."
    ];
    const quoteEl = document.getElementById('footer-quote');
    if (quoteEl) {
      quoteEl.textContent = quotes[Math.floor(Math.random() * quotes.length)];
    }
  </script>

  <script>
    // Mobile nav toggle
    const toggle = document.getElementById('nav-toggle');
    const links = document.getElementById('nav-links');
    const nav = document.getElementById('nav');

    toggle?.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      links?.classList.toggle('open');
    });

    // Close mobile nav when a link is clicked
    links?.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        links.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
      });
    });

    // Navbar background on scroll
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      nav?.classList.toggle('nav--scrolled', scrollY > 40);
      lastScroll = scrollY;
    }, { passive: true });
  </script>

  <style>
    /* ── Navigation ── */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      height: var(--nav-height);
      transition: background var(--duration-normal), box-shadow var(--duration-normal);
    }

    .nav--scrolled {
      background: rgba(250, 250, 250, 0.92);
      backdrop-filter: blur(12px);
      box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
    }

    .nav__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 100%;
    }

    .nav__logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .nav__knot {
      flex-shrink: 0;
    }

    .nav__knot--light {
      display: none;
    }

    .nav--scrolled .nav__knot--dark {
      display: none;
    }

    .nav--scrolled .nav__knot--light {
      display: block;
    }

    .nav__logo-text {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1.15rem;
      color: #fff;
      letter-spacing: -0.02em;
      transition: color var(--duration-normal);
    }

    .nav__logo-accent {
      font-family: var(--font-mono);
      font-weight: 400;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: lowercase;
      color: var(--vert);
    }

    .nav--scrolled .nav__logo-accent {
      color: var(--bleu);
    }

    .nav--scrolled .nav__logo-text {
      color: var(--noir);
    }

    .nav__links {
      display: flex;
      align-items: center;
      gap: 2rem;
      list-style: none;
    }

    .nav__links a {
      font-family: var(--font-heading);
      font-size: 0.875rem;
      font-weight: 500;
      color: rgba(255,255,255,0.75);
      transition: color var(--duration-fast);
    }

    .nav--scrolled .nav__links a {
      color: var(--gris-500);
    }

    .nav__links a:hover {
      color: #fff;
    }

    .nav--scrolled .nav__links a:hover {
      color: var(--noir);
    }

    .nav__links .btn-sm {
      font-size: 0.8rem;
      padding: 0.5rem 1.25rem;
      color: white !important;
    }

    .nav__lang {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      padding: 0.25rem 0.5rem;
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 4px;
    }

    .nav--scrolled .nav__lang {
      border-color: var(--gris-200);
    }

    /* Mobile toggle */
    .nav__toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      padding: 4px;
    }

    .nav__toggle span {
      display: block;
      width: 22px;
      height: 2px;
      background: #fff;
      border-radius: 2px;
      transition: all var(--duration-normal);
    }

    .nav--scrolled .nav__toggle span {
      background: var(--noir);
    }

    /* ── Footer ── */
    .footer {
      padding: var(--space-2xl) 0 var(--space-lg);
    }

    .footer__inner {
      display: flex;
      flex-direction: column;
      gap: var(--space-xl);
    }

    .footer__logo-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .footer__brand .nav__logo-text {
      color: var(--blanc);
    }

    .footer__tagline {
      margin-top: var(--space-sm);
      font-style: italic;
      color: var(--gris-400);
    }

    .footer__links {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-xl);
    }

    .footer__col {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .footer__col h4 {
      font-family: var(--font-heading);
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--gris-400);
      margin-bottom: 0.5rem;
    }

    .footer__col a {
      font-size: 0.9rem;
      color: var(--gris-300);
    }

    .footer__col a:hover {
      color: var(--blanc);
    }

    .footer__citation {
      padding: var(--space-lg) 0;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .footer__quote {
      font-style: italic;
      color: var(--gris-400);
      font-size: 0.9rem;
      line-height: 1.6;
      max-width: 600px;
    }

    .footer__bottom {
      padding-top: var(--space-lg);
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    /* ── Mobile ── */
    @media (max-width: 768px) {
      .nav__toggle {
        display: flex;
      }

      .nav__links {
        position: fixed;
        top: var(--nav-height);
        left: 0;
        right: 0;
        flex-direction: column;
        background: rgba(250, 250, 250, 0.98);
        backdrop-filter: blur(20px);
        padding: var(--space-lg);
        gap: var(--space-md);
        transform: translateY(-120%);
        transition: transform var(--duration-normal) var(--ease-out);
      }

      .nav__links.open {
        transform: translateY(0);
      }

      .nav__links a {
        color: var(--gris-500);
      }

      .nav__links a:hover {
        color: var(--noir);
      }

      .footer__links {
        grid-template-columns: 1fr;
        gap: var(--space-lg);
      }
    }
  </style>
</body>
</html>
