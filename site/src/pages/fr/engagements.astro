---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Matrice from '../../components/Matrice.astro';

const engagements = [
  { name: 'GASPE', role: 'Delegue general', axes: ['Socioculturelle'], color: 'var(--rose)', desc: 'Groupement des Armateurs de Service Public Maritime et de Passages d\'Eau — defense du service public maritime.', url: 'https://www.gaspe.fr/' },
  { name: 'VAIATA Dynamics', role: 'Cofondateur', axes: ['Technologique'], color: 'var(--bleu)', desc: 'Intelligence artificielle au service des grandes causes du maritime : sauvetage en mer et cyberdefense.', url: 'https://vaiata-dynamics.com/fr/' },
  { name: 'Opsealog', role: 'Conception initiale & ex-responsable du pole innovation', axes: ['Technologique', 'Environnementale'], color: 'var(--bleu)', desc: 'Plateforme de data analytics pour optimiser la performance et la consommation energetique des navires.', url: 'https://opsealog.com/' },
  { name: 'Fondation ENSM', role: 'President du conseil de gestion', axes: ['Socioculturelle', 'Environnementale'], color: 'var(--vert)', desc: 'Fondation de l\'Ecole Nationale Superieure Maritime, formation des futurs officiers de marine marchande et ingenieurs maritimes.', url: 'https://www.supmaritime.fr/fondation-ensm-don/' },
  { name: 'ENSM', role: 'Enseignant developpement durable', axes: ['Environnementale'], color: 'var(--vert)', desc: 'Enseignement de l\'ecologie et du developpement durable au sein de l\'ENSM.', url: 'https://www.supmaritime.fr/' },
  { name: 'Fed. Nationale du Merite Maritime', role: 'Membre', axes: ['Socioculturelle'], color: 'var(--rose)', desc: 'Federation valorisant les contributions au monde maritime.', url: 'https://www.meritemaritime-fnmm.com/' },
  { name: 'HYDROS Alumni', role: 'Secretaire general adjoint', axes: ['Socioculturelle'], color: 'var(--rose)', desc: 'Animation du reseau des etudiants et anciens etudiants de l\'ENSM.', url: 'https://www.hydros-alumni.org/' },
  { name: 'Propeller Club', role: 'Membre actif', axes: ['Socioculturelle'], color: 'var(--rose)', desc: 'Reseau international de professionnels du secteur maritime et portuaire.', url: 'https://propellerclub.us/' },
  { name: 'Aperitifs de la Mer', role: 'Ambassadeur', axes: ['Socioculturelle'], color: 'var(--rose)', desc: 'Evenements de networking et de reflexion reunissant les acteurs de l\'economie maritime.', url: 'https://aperitifsdelamer.com/' },
  { name: 'Academie de Marine', role: 'Auditeur', axes: ['Socioculturelle'], color: 'var(--rose)', desc: 'Institution seculaire de reflexion et de prospective sur les enjeux maritimes.', url: 'https://www.academiedemarine.fr/' },
  { name: 'COESPC', role: 'Membre du bureau', axes: ['Socioculturelle'], color: 'var(--rose)', desc: 'Engagement local a Annecy-le-Vieux : organisation de la fete villageoise annuelle, a vocation caritative.', url: 'https://coespc.org/' },
];
---

<BaseLayout lang="fr" frSlug="engagements" title="Engagements — Colomban at Sea" description="Les engagements de Colomban au service du maritime de demain : GASPE, VAIATA Dynamics, Fondation ENSM, et plus.">
  <section class="page-hero section-dark">
    <div class="container stagger hero-text">
      <p class="mono text-bleu">Engagements</p>
      <h1>Des engagements multiples<br/>avec un <span class="text-bleu">cap unique</span></h1>
      <p class="subtitle">Chaque engagement s'inscrit dans la triple transformation maritime — technologique, environnementale, socioculturelle.</p>
    </div>
    <div class="hero-matrice">
      <Matrice />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="engagements-grid">
        {engagements.map((e) => (
          <article class="engagement-card">
            <div class="engagement-card__accent" style={`background: ${e.color}`}></div>
            <div class="engagement-card__content">
              <h3>{e.url ? <a href={e.url} target="_blank" rel="noopener noreferrer" class="engagement-card__link">{e.name}</a> : e.name}</h3>
              <p class="engagement-card__role">{e.role}</p>
              <p class="engagement-card__desc">{e.desc}</p>
              <div class="engagement-card__axes">
                {e.axes.map((a) => (
                  <span class={`axis-tag axis-tag--${a.toLowerCase()}`}>{a}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
        <article class="engagement-card engagement-card--coming">
          <div class="engagement-card__accent" style="background: var(--gris-300)"></div>
          <div class="engagement-card__content engagement-card__coming-inner">
            <h3>Et plus &agrave; venir&hellip;</h3>
            <p class="engagement-card__desc">De nouveaux engagements sont en preparation.</p>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    padding: calc(var(--nav-height) + var(--space-3xl)) 0 0;
    overflow: hidden;
  }

  .hero-text {
    position: relative;
    z-index: 2;
  }

  .page-hero .mono { margin-bottom: var(--space-sm); }
  .page-hero h1 { position: relative; z-index: 3; }
  .page-hero .subtitle {
    margin-top: var(--space-md);
    max-width: 600px;
    color: var(--gris-400);
    position: relative;
    z-index: 1;
  }

  .hero-matrice {
    width: 100%;
    height: 55vh;
    min-height: 380px;
    margin-top: calc(-1 * var(--space-2xl));
    position: relative;
    z-index: 1;
    background: radial-gradient(ellipse at center, rgba(255,255,255,0.02) 0%, transparent 100%);
    overflow: hidden;
    mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 92%, transparent 100%);
  }

  .engagements-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .engagement-card {
    position: relative;
    border: 1px solid var(--gris-200);
    border-radius: 16px;
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-out);
    background: white;
  }

  .engagement-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  .engagement-card__accent {
    height: 4px;
  }

  .engagement-card__content {
    padding: var(--space-lg);
  }

  .engagement-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .engagement-card__link {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-normal);
  }

  .engagement-card__link:hover {
    color: var(--bleu);
  }

  .engagement-card__link::after {
    content: ' \2197';
    font-size: 0.8em;
    opacity: 0.4;
    transition: opacity var(--duration-normal);
  }

  .engagement-card:hover .engagement-card__link::after {
    opacity: 1;
  }

  .engagement-card__role {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--gris-400);
    margin-bottom: var(--space-md);
  }

  .engagement-card__desc {
    font-size: 0.9rem;
    color: var(--gris-500);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .engagement-card__axes {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .axis-tag {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    border: 1px solid;
  }

  .axis-tag--technologique { color: var(--bleu); border-color: var(--bleu); }
  .axis-tag--environnementale { color: var(--vert); border-color: var(--vert); }
  .axis-tag--socioculturelle { color: var(--rose); border-color: var(--rose); }

  .engagement-card--coming {
    border-style: dashed;
    border-color: var(--gris-300);
    background: transparent;
  }

  .engagement-card--coming:hover {
    transform: none;
    box-shadow: none;
  }

  .engagement-card__coming-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    min-height: 120px;
  }

  .engagement-card--coming h3 {
    color: var(--gris-400);
    font-style: italic;
  }

  .engagement-card--coming .engagement-card__desc {
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .engagements-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .engagements-grid {
      grid-template-columns: 1fr;
    }

    .hero-matrice {
      height: 40vh;
      min-height: 280px;
      margin-top: calc(-1 * var(--space-xl));
    }

    .engagement-card--coming {
      display: none;
    }
  }
</style>
