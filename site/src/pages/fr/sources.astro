    text-align: left;
    border-bottom: 1px solid var(--gris-200);
  }

  th {
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--gris-500);
  }

  td:first-child {
    font-variant-numeric: tabular-nums;
    color: var(--gris-400);
    width: 2rem;
  }

  .source-ref {
    font-size: 0.85rem;
    color: var(--gris-400);
    margin-top: var(--space-xs);
  }

  .source-ref a {
    color: var(--bleu);
  }

  @media (max-width: 768px) {
    table {
      font-size: 0.8rem;
    }

    th, td {
      padding: var(--space-xs);
    }
  }
</style>
