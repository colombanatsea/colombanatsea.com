---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Globe from '../../components/Globe.astro';
import Matrice from '../../components/Matrice.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Colomban - Océanocratie" lang="fr" frSlug="" description="Oc&eacute;anocratie — Le quartier g&eacute;n&eacute;ral digital de la triple transition maritime. Port&eacute; par Colomban, officier de marine marchande devenu figure de la transformation du maritime.">

  <!-- ═══ HERO ═══ -->
  <section class="hero" id="hero">
    <div class="hero__globe-bg">
      <Globe />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content container stagger">
      <p class="hero__kicker mono">colombanatsea.com</p>
      <h1 class="hero__title">Oc&eacute;anocratie</h1>
      <p class="hero__vision">Une nation libre regarde la mer.</p>
      <div class="hero__cta">
        <a href="#vision" class="btn btn-primary">D&eacute;couvrir la vision</a>
        <a href={`${base}/fr/a-propos`} class="btn btn-outline hero__btn-outline">Qui est Colomban</a>
      </div>
    </div>
    <button class="hero__explore-map" id="hero-explore-map" aria-label="Explorer la carte en plein &eacute;cran">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 3 21 3 21 9" /><polyline points="9 21 3 21 3 15" /><line x1="21" y1="3" x2="14" y2="10" /><line x1="3" y1="21" x2="10" y2="14" />
      </svg>
      <span class="mono">Explorer la carte</span>
    </button>
    <div class="hero__scroll-hint">
      <span class="mono text-muted">Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ═══ CITATION TABARLY ═══ -->
  <section class="tabarly section-dark section" id="tabarly">
    <div class="container">
      <blockquote class="tabarly__quote stagger">
        <p>&laquo;&nbsp;La mer, c'est ce que les Fran&ccedil;ais ont dans le dos quand ils regardent la plage.&nbsp;&raquo;</p>
        <cite>&Eacute;ric Tabarly</cite>
      </blockquote>
      <p class="tabarly__echo stagger">La France est destin&eacute;e &agrave; &ecirc;tre une nation maritime.<br/>Et nous luttons de toute notre force pour nous y soustraire — depuis longtemps.</p>
    </div>
  </section>

  <!-- ═══ LE MERITOIRE FRANÇAIS ═══ -->
  <section class="archipel section" id="globe">
    <div class="container">
      <div class="archipel__header stagger">
        <p class="mono text-bleu">Le MERitoire fran&ccedil;ais</p>
        <h2>La France n'est pas un hexagone<br/>C'est un archipel</h2>
        <p class="subtitle">Nous restons repli&eacute;s sur notre TERRitoire hexagonal &eacute;triqu&eacute;, alors que notre MERitoire fait de la France une nation globale. Un potentiel strat&eacute;gique qui traverse tous les enjeux du si&egrave;cle.</p>
      </div>

      <div class="archipel__grid">
        <div class="archipel__card stagger">
          <span class="archipel__number">2<sup>e</sup></span>
          <span class="archipel__title">ZEE mondiale</span>
          <span class="archipel__desc">11 millions de km&sup2; d'espace maritime, sur tous les oc&eacute;ans du globe</span>
        </div>
        <div class="archipel__card stagger">
          <span class="archipel__number">37</span>
          <span class="archipel__title">Fronti&egrave;res maritimes</span>
          <span class="archipel__desc">Une interface diplomatique unique&nbsp;: <a href={`${base}/fr/sources`} style="color: inherit; text-decoration: underline; text-decoration-color: var(--gris-200); text-underline-offset: 2px;">37 &Eacute;tats et territoires</a> voisins, aucun autre pays au monde</span>
        </div>
        <div class="archipel__card stagger">
          <span class="archipel__number">4</span>
          <span class="archipel__title">Oc&eacute;ans</span>
          <span class="archipel__desc">Atlantique, Pacifique, Indien, Antarctique — une pr&eacute;sence sur tous les oc&eacute;ans</span>
        </div>
        <div class="archipel__card stagger">
          <span class="archipel__number">5</span>
          <span class="archipel__title">Continents</span>
          <span class="archipel__desc">Europe, Am&eacute;riques, Afrique, Oc&eacute;anie, Antarctique — <a href={`${base}/fr/sources`} style="color: inherit; text-decoration: underline; text-decoration-color: var(--gris-200); text-underline-offset: 2px;">seul pays au monde</a></span>
        </div>
        <div class="archipel__card stagger">
          <span class="archipel__number">97%</span>
          <span class="archipel__title">Communications</span>
          <span class="archipel__desc">Des donn&eacute;es num&eacute;riques mondiales transitent par des c&acirc;bles sous-marins — souverainet&eacute; num&eacute;rique</span>
        </div>
        <div class="archipel__card stagger">
          <span class="archipel__number">80%</span>
          <span class="archipel__title">Commerce mondial</span>
          <span class="archipel__desc">Des marchandises mondiales sont transport&eacute;es par voie maritime — interface &eacute;conomique</span>
        </div>
        <div class="archipel__card stagger">
          <span class="archipel__number">EMR</span>
          <span class="archipel__title">&Eacute;nergie</span>
          <span class="archipel__desc">&Eacute;olien offshore, hydrolien, &eacute;nergie thermique des mers&nbsp;: un potentiel &eacute;nerg&eacute;tique consid&eacute;rable</span>
        </div>
        <div class="archipel__card stagger">
          <span class="archipel__number">ADN</span>
          <span class="archipel__title">Culture</span>
          <span class="archipel__desc">De Petit Bateau &agrave; Jean-Paul Gaultier, de Kickers &agrave; Ulysse Nardin&nbsp;: le maritime est ancr&eacute; dans notre identit&eacute;, sans que nous l'embrassions</span>
        </div>
      </div>

      <p class="archipel__note">Explorez le <a href="#" id="explore-zee-link" style="color: var(--bleu); text-decoration: underline; text-underline-offset: 2px;">globe interactif</a> pour visualiser le MERitoire fran&ccedil;ais.</p>
    </div>
  </section>

  <div class="divider-wrap divider-wrap--overlap">
    <img src={`${base}/images/divider.svg`} alt="" class="divider-img" />
  </div>

  <!-- ═══ TOUT PASSE PAR LA MER ═══ -->
  <section class="seamer section-dark section" id="seamer">
    <div class="container">
      <div class="seamer__header stagger">
        <p class="mono text-bleu">L'invisible infrastructure</p>
        <h2>Tout passe par la mer</h2>
      </div>
      <div class="seamer__content">
        <div class="seamer__text stagger">
          <p class="seamer__lead">Ce que vous consommez ce matin est arriv&eacute; par la mer. Ce message que vous lisez transite par un c&acirc;ble au fond de l'oc&eacute;an. L'&eacute;nergie qui alimentera vos enfants na&icirc;tra des vagues et du vent marin.</p>
          <p>Le maritime n'est pas un secteur industriel commun. Il est le pouls de notre soci&eacute;t&eacute;. Sans navires, sans ports, sans c&acirc;bles sous-marins, l'&eacute;conomie se grippe, les communications s'&eacute;teignent, la souverainet&eacute; s'efface.</p>
        </div>
        <div class="seamer__facts">
          <div class="seamer__fact stagger">
            <span class="seamer__fact-number">595 Md&euro;</span>
            <span class="seamer__fact-label">de biens export&eacute;s par la France transitent par la mer</span>
          </div>
          <div class="seamer__fact stagger">
            <span class="seamer__fact-number">50+</span>
            <span class="seamer__fact-label">c&acirc;bles sous-marins — <a href={`${base}/fr/sources#cables-sous-marins`} style="color: var(--bleu); text-decoration: underline; text-underline-offset: 2px;">pays le plus connect&eacute; d'Europe</a></span>
          </div>
          <div class="seamer__fact stagger">
            <span class="seamer__fact-number">45 GW</span>
            <span class="seamer__fact-label">d'&eacute;olien offshore vis&eacute;s en 2050 — 30% de l'&eacute;lectricit&eacute; fran&ccedil;aise</span>
          </div>
          <div class="seamer__fact stagger">
            <span class="seamer__fact-number">25 000</span>
            <span class="seamer__fact-label">mol&eacute;cules marines d&eacute;crites — la pharmacie de demain</span>
          </div>
        </div>
      </div>
      <p class="seamer__source stagger">Tous les chiffres sont r&eacute;f&eacute;renc&eacute;s sur la page <a href={`${base}/fr/sources`}>Sources & donn&eacute;es</a>.</p>
    </div>
  </section>

  <div class="divider-wrap divider-wrap--overlap">
    <img src={`${base}/images/divider.svg`} alt="" class="divider-img" />
  </div>

  <!-- ═══ OCÉANOCRATIE — LE MANIFESTE ═══ -->
  <section class="manifeste section" id="vision">
    <div class="container">
      <div class="manifeste__header stagger">
        <p class="mono text-bleu">Oc&eacute;anocratie</p>
        <h2>Une nation libre<br/>regarde la mer</h2>
        <p class="subtitle">La thalassocratie fondait la puissance sur la domination des mers. L'Oc&eacute;anocratie fonde la r&eacute;silience de la soci&eacute;t&eacute; sur sa relation consciente &agrave; l'oc&eacute;an. Pas le pouvoir <em>sur</em>, mais le pouvoir <em>avec</em>.</p>
      </div>

      <div class="manifeste__pillars">
        <div class="manifeste__pillar stagger">
          <div class="manifeste__pillar-icon" style="--pillar-color: var(--bleu);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
            </svg>
          </div>
          <h3>La curiosit&eacute; contre le repli</h3>
          <p>La mer est l'&eacute;cole de la libert&eacute;. Non pas la libert&eacute; confortable de rester chez soi, mais la libert&eacute; exigeante d'exp&eacute;rimenter, de penser hors du temps, de vivre le pr&eacute;sent. C'est le voyage initiatique par excellence&nbsp;: oser d&eacute;couvrir, remettre en question son propre r&eacute;f&eacute;rentiel, s'ouvrir &agrave; l'Autre.</p>
        </div>

        <div class="manifeste__pillar stagger">
          <div class="manifeste__pillar-icon" style="--pillar-color: var(--vert);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M12 22c5-3 8-7 8-12 0-3-2.5-5-5-5-1.5 0-2.5.5-3 1.5C11.5 5.5 10.5 5 9 5c-2.5 0-5 2-5 5 0 5 3 9 8 12z"/>
            </svg>
          </div>
          <h3>L'humilit&eacute; face &agrave; l'indomptable</h3>
          <p>On laboure la terre, on la cl&ocirc;ture, on la poss&egrave;de, on la ma&icirc;trise. L'oc&eacute;an ne se laisse ni cl&ocirc;turer ni poss&eacute;der. Il rappelle &agrave; l'Homme qu'il n'est pas le ma&icirc;tre. C'est une le&ccedil;on d'humilit&eacute; que la terre ne donne plus qu'en des endroits extr&ecirc;mes&nbsp;: comprendre que nous faisons partie de la nature, pas que nous sommes au-dessus.</p>
        </div>

        <div class="manifeste__pillar stagger">
          <div class="manifeste__pillar-icon" style="--pillar-color: var(--rose);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3>La main tendue par-del&agrave; l'horizon</h3>
          <p>En mer, le droit maritime oblige au sauvetage — quelle que soit la nationalit&eacute;, la culture, la couleur ou la religion. Aucune fronti&egrave;re ne r&eacute;siste bien loin du rivage. L'oc&eacute;an est le plus grand espace commun de l'humanit&eacute;&nbsp;: 37 voisins maritimes pour la France, 37 mains tendues. La mer relie bien plus qu'elle ne s&eacute;pare.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider-wrap divider-wrap--overlap">
    <img src={`${base}/images/divider.svg`} alt="" class="divider-img" />
  </div>

  <!-- ═══ TRIPLE ÉVOLUTION ═══ -->
  <section class="vision section-dark section" id="evolution">
    <div class="container" style="position: relative; z-index: 1;">
      <div class="vision__header stagger">
        <p class="mono text-bleu">La triple &eacute;volution</p>
        <h2>Deux transitions,<br/>une r&eacute;volution</h2>
        <p class="subtitle">Le monde maritime affronte trois transformations sans pr&eacute;c&eacute;dent. Ce ne sont pas des menaces&nbsp;: ce sont des opportunit&eacute;s pour une soci&eacute;t&eacute; plus durable.</p>
      </div>

      <div class="vision__axes">
        <div class="vision__axis" data-axis="techno">
          <div class="vision__axis-icon" style="--axis-color: var(--bleu);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>Transition technologique</h3>
          <p>90% de la population mondiale a la 4G, mais 70% de la flotte mondiale utilise encore des journaux de bord papiers. Le maritime ne doit pas passer par la num&eacute;risation&nbsp;: il doit entrer imm&eacute;diatement dans une &egrave;re digitale, post web.</p>
        </div>

        <div class="vision__axis" data-axis="enviro">
          <div class="vision__axis-icon" style="--axis-color: var(--vert);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M12 22c5-3 8-7 8-12 0-3-2.5-5-5-5-1.5 0-2.5.5-3 1.5C11.5 5.5 10.5 5 9 5c-2.5 0-5 2-5 5 0 5 3 9 8 12z"/>
            </svg>
          </div>
          <h3>Transition &eacute;cologique</h3>
          <p>D&eacute;carbonation, voile, hydrog&egrave;ne, &eacute;olien flottant. Le maritime porte la promesse d'une &eacute;nergie propre — 45 GW d'EMR en 2050 en France — et d'un transport 7 fois moins carbon&eacute; que la route. Si l'enjeu imm&eacute;diat mis en avant est souvent la d&eacute;carbonation, n'oublions pas qu'il y a 9 limites plan&eacute;taires &agrave; pr&eacute;server et que le maritime a sa part dans chacune.</p>
        </div>

        <div class="vision__axis" data-axis="socio">
          <div class="vision__axis-icon" style="--axis-color: var(--rose);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3>R&eacute;volution socioculturelle</h3>
          <p>Les transitions du maritime en oubliant l'aspect social, les marins, c'est de la plaisance. Les acteurs du monde maritime doivent s'approprier les grands enjeux du XXI<sup>e</sup> si&egrave;cle. En s'appuyant sur les valeurs du maritime — temps long, esprit d'&eacute;quipage, esprit pionnier, humilit&eacute; — ils doivent contribuer activement autant &agrave; transformer leur monde qu'&agrave; le faire d&eacute;couvrir pour inspirer la soci&eacute;t&eacute;.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MATRICE ENGAGEMENTS ═══ -->
  <section class="matrice-section section-dark section" id="matrice">
    <div class="container">
      <div class="matrice-section__header stagger">
        <p class="mono text-bleu">Les engagements</p>
        <h2>3 axes d'engagement<br/>Un cap unique</h2>
      </div>
    </div>
    <div class="matrice-section__canvas">
      <Matrice />
    </div>
  </section>

  <!-- ═══ BANDEAU LOGOS ═══ -->
  <section class="logos section" id="logos">
    <div class="container">
      <p class="logos__title mono text-muted">Collaboration, Mentions, prises de Positions</p>
      <div class="logos__track">
        <div class="logos__slide">
          <span class="logos__item">GASPE</span>
          <span class="logos__item">Fondation ENSM</span>
          <span class="logos__item">VAIATA Dynamics</span>
          <span class="logos__item">Propeller Club</span>
          <span class="logos__item">HYDROS Alumni</span>
          <span class="logos__item">Le Monde</span>
          <span class="logos__item">TF1</span>
          <span class="logos__item">Marine & Oceans</span>
          <span class="logos__item">Euromaritime</span>
          <span class="logos__item">ENSM</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TEMOIGNAGES ═══ -->
  <section class="testimonials section" id="temoignages">
    <div class="container">
      <div class="testimonials__header stagger">
        <h2>La confiance, c'est bien<br/>Les t&eacute;moignages, c'est mieux</h2>
      </div>
      <div class="testimonials__grid">
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/simon-bernard.jpg" alt="Simon Bernard" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"J'ai rencontr&eacute; Colomban dans mes premi&egrave;res ann&eacute;es d'&eacute;tudes de Marine Marchande et suivi ses diff&eacute;rents projets avec attention&nbsp;: amateur inconditionnel de la mer, il aime mettre ses id&eacute;es innovantes au service de l'industrie maritime. &Eacute;tant moi-m&ecirc;me porteur de projet, j'ai pu constater son professionnalisme, sa capacit&eacute; &agrave; &ecirc;tre moteur et &agrave; profiter de la technologie sans jamais oublier l'humain."</p>
          <cite>— Simon Bernard</cite>
          <span class="testimonial__role">Cofondateur — Plastic Odyssey</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/bastien-arcas.jpg" alt="Bastien Arcas" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"Colomban est une locomotive qui entra&icirc;ne plusieurs wagons essentiels &agrave; notre communaut&eacute;&nbsp;: la Fondation ENSM, Hydros, et l'Ap&eacute;ritif de la mer."</p>
          <cite>— Bastien Arcas</cite>
          <span class="testimonial__role">Directeur adjoint — GTT Fleet Performance</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/stanislas-oriot.jpg" alt="Stanislas Oriot" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"What an energy! It is sometimes intimidating to have such a guy around because it seems his energy is 200% above mine and his days are 40 hours long."</p>
          <cite>— Stanislas Oriot</cite>
          <span class="testimonial__role">Senior Maritime Analyst — Opsealog</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/khalil-bouzidi.jpg" alt="Khalil Bouzidi" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"Amazing guy! One of the best ethical growth hackers that I have met! Customer-centric, attentive to detail, a massive asset for Rempleo!"</p>
          <cite>— Khalil Bouzidi</cite>
          <span class="testimonial__role">Fondateur — Rempleo</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/anthony-garcia.jpg" alt="Anthony Garcia" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"As long as I have known Colomban, he has always had a strong taste for adventure and innovation."</p>
          <cite>— Anthony Garcia</cite>
          <span class="testimonial__role">COO — Jifmar</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/rodolphe-bouchet.jpg" alt="Rodolphe Bouchet" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"Dynamic and professional, Colomban knows how to boost business development."</p>
          <cite>— Rodolphe Bouchet</cite>
          <span class="testimonial__role">CEO — Bourbon Marine &amp; Logistics</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/andrea-mancuso.jpg" alt="Andrea Mancuso" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"I had the privilege and pleasure to work with Colomban on a CMMS for the maritime industry."</p>
          <cite>— Andrea Mancuso</cite>
          <span class="testimonial__role">Senior Software Engineer</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/matthias-du-verle.jpg" alt="Matthias du Verle" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"I have known Colomban since the time he was a promising cadet officer."</p>
          <cite>— Matthias du Verle</cite>
          <span class="testimonial__role">Cofondateur — Wolfgang</span>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ═══ CTA RESEAUX SOCIAUX ═══ -->
  <section class="cta-social section-dark section" id="cta">
    <div class="container">
      <div class="cta-social__inner stagger">
        <h2>Partageons notre<br/>vision maritime du monde</h2>
        <p class="subtitle">Rejoignez la conversation sur les r&eacute;seaux sociaux.</p>
        <div class="cta-social__links">
          <a href="https://www.linkedin.com/in/colombanatsea/" target="_blank" rel="noopener noreferrer" class="cta-social__link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <span>LinkedIn</span>
          </a>
