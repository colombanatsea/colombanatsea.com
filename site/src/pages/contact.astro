---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Colomban at Sea" description="Contactez Colomban via LinkedIn ou Instagram. Leader d'opinion maritime.">
  <section class="contact-page">
    <div class="container">
      <div class="contact-inner stagger">
        <p class="mono text-bleu">Contact</p>
        <h1>Echangeons</h1>
        <p class="subtitle">La meilleure fa&ccedil;on de me contacter : rejoignez-moi sur les r&eacute;seaux sociaux et envoyez-moi un message directement.</p>

        <div class="contact-links">
          <a href="https://www.linkedin.com/in/colombanatsea/" target="_blank" rel="noopener noreferrer" class="contact-link">
            <div class="contact-link__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <div>
              <h3>LinkedIn</h3>
              <p>~16 000 abonnes — la conversation professionnelle</p>
            </div>
          </a>

          <a href="https://www.instagram.com/colombanatsea/" target="_blank" rel="noopener noreferrer" class="contact-link">
            <div class="contact-link__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            </div>
            <div>
              <h3>Instagram</h3>
              <p>@colombanatsea — les coulisses et la vision</p>
            </div>
          </a>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
  }

  .contact-inner {
    max-width: 600px;
  }

  .contact-inner .mono {
    margin-bottom: var(--space-sm);
  }

  .contact-inner h1 {
    margin-bottom: var(--space-md);
  }

  .contact-inner > .subtitle {
    margin-bottom: var(--space-2xl);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg);
    border: 1px solid var(--gris-200);
    border-radius: 16px;
    transition: all var(--duration-normal) var(--ease-out);
    color: inherit;
  }

  .contact-link:hover {
    border-color: var(--bleu);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(42, 85, 179, 0.1);
    color: inherit;
  }

  .contact-link__icon {
    flex-shrink: 0;
    color: var(--bleu);
  }

  .contact-link h3 {
    font-size: 1rem;
    margin-bottom: 0.15rem;
  }

  .contact-link p {
    font-size: 0.85rem;
    color: var(--gris-500);
  }

  .contact-note {
    font-size: 0.75rem;
  }
</style>
