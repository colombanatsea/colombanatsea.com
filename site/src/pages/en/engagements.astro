---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Matrice from '../../components/Matrice.astro';

const engagements = [
  { name: 'GASPE', role: 'General Delegate', axes: ['Sociocultural'], color: 'var(--rose)', desc: 'Public Maritime Service & Water Crossings Operators Association — defending maritime public service.', url: 'https://www.gaspe.fr/' },
  { name: 'VAIATA Dynamics', role: 'Co-founder', axes: ['Technological'], color: 'var(--bleu)', desc: 'AI at the service of maritime\'s great causes: search and rescue, cyber defence.', url: 'https://vaiata-dynamics.com/fr/' },
  { name: 'Opsealog', role: 'Initial design & former Head of Innovation', axes: ['Technological', 'Environmental'], color: 'var(--bleu)', desc: 'Maritime data analytics platform to optimize vessel performance and energy consumption.', url: 'https://opsealog.com/' },
  { name: 'Fondation ENSM', role: 'Board President', axes: ['Sociocultural', 'Environmental'], color: 'var(--vert)', desc: 'Foundation of the National Maritime Academy, training future merchant navy officers and maritime engineers.', url: 'https://www.supmaritime.fr/fondation-ensm-don/' },
  { name: 'ENSM', role: 'Sustainability Lecturer', axes: ['Environmental'], color: 'var(--vert)', desc: 'Teaching ecology and sustainable development at the National Maritime Academy.', url: 'https://www.supmaritime.fr/' },
  { name: 'Nat. Federation of Maritime Merit', role: 'Member', axes: ['Sociocultural'], color: 'var(--rose)', desc: 'Federation recognizing contributions to the maritime world.', url: 'https://www.meritemaritime-fnmm.com/' },
  { name: 'HYDROS Alumni', role: 'Deputy Secretary General', axes: ['Sociocultural'], color: 'var(--rose)', desc: 'Animation of the ENSM students and alumni network.', url: 'https://www.hydros-alumni.org/' },
  { name: 'Propeller Club', role: 'Active member', axes: ['Sociocultural'], color: 'var(--rose)', desc: 'International network of maritime and port professionals.', url: 'https://propellerclub.us/' },
  { name: 'Ap&eacute;ritifs de la Mer', role: 'Ambassador', axes: ['Sociocultural'], color: 'var(--rose)', desc: 'Networking and thought leadership events gathering maritime economy actors.', url: 'https://aperitifsdelamer.com/' },
  { name: 'Acad&eacute;mie de Marine', role: 'Auditor', axes: ['Sociocultural'], color: 'var(--rose)', desc: 'Centuries-old institution for maritime reflection and foresight.', url: 'https://www.academiedemarine.fr/' },
  { name: 'COESPC', role: 'Board member', axes: ['Sociocultural'], color: 'var(--rose)', desc: 'Local engagement in Annecy-le-Vieux: organizing the annual village festival for charitable purposes.', url: 'https://coespc.org/' },
];
---

<BaseLayout lang="en" frSlug="engagements" title="Engagements — Colomban at Sea" description="Colomban's engagements serving tomorrow's maritime: GASPE, VAIATA Dynamics, Fondation ENSM, and more.">
  <section class="page-hero section-dark">
    <div class="container stagger hero-text">
      <p class="mono text-bleu">Engagements</p>
      <h1>Multiple engagements<br/>with a <span class="text-bleu">single heading</span></h1>
      <p class="subtitle">Each engagement is part of the triple maritime transformation — technological, environmental, sociocultural.</p>
    </div>
    <div class="hero-matrice">
      <Matrice />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="engagements-grid">
        {engagements.map((e) => (
          <article class="engagement-card">
            <div class="engagement-card__accent" style={`background: ${e.color}`}></div>
            <div class="engagement-card__content">
              <h3>{e.url ? <a href={e.url} target="_blank" rel="noopener noreferrer" class="engagement-card__link">{e.name}</a> : e.name}</h3>
              <p class="engagement-card__role">{e.role}</p>
              <p class="engagement-card__desc">{e.desc}</p>
              <div class="engagement-card__axes">
                {e.axes.map((a) => (
                  <span class={`axis-tag axis-tag--${a.toLowerCase()}`}>{a}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
        <article class="engagement-card engagement-card--coming">
          <div class="engagement-card__accent" style="background: var(--gris-300)"></div>
          <div class="engagement-card__content engagement-card__coming-inner">
            <h3>And more to come&hellip;</h3>
            <p class="engagement-card__desc">New engagements are in preparation.</p>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    padding: calc(var(--nav-height) + var(--space-3xl)) 0 0;
    overflow: hidden;
  }

  .hero-text {
    position: relative;
    z-index: 2;
  }

  .page-hero .mono { margin-bottom: var(--space-sm); }
  .page-hero h1 { position: relative; z-index: 3; }
  .page-hero .subtitle {
    margin-top: var(--space-md);
    max-width: 600px;
    color: var(--gris-400);
    position: relative;
    z-index: 1;
  }

  .hero-matrice {
    width: 100%;
    height: 55vh;
    min-height: 380px;
    margin-top: calc(-1 * var(--space-2xl));
    position: relative;
    z-index: 1;
    background: radial-gradient(ellipse at center, rgba(255,255,255,0.02) 0%, transparent 100%);
    overflow: hidden;
    mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 12%, black 92%, transparent 100%);
  }

  .engagements-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .engagement-card {
    position: relative;
    border: 1px solid var(--gris-200);
    border-radius: 16px;
    overflow: hidden;
    transition: all var(--duration-normal) var(--ease-out);
    background: white;
  }

  .engagement-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  .engagement-card__accent {
    height: 4px;
  }

  .engagement-card__content {
    padding: var(--space-lg);
  }

  .engagement-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .engagement-card__link {
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-normal);
  }

  .engagement-card__link:hover {
    color: var(--bleu);
  }

  .engagement-card__link::after {
    content: ' \2197';
    font-size: 0.8em;
    opacity: 0.4;
    transition: opacity var(--duration-normal);
  }

  .engagement-card:hover .engagement-card__link::after {
    opacity: 1;
  }

  .engagement-card__role {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--gris-400);
    margin-bottom: var(--space-md);
  }

  .engagement-card__desc {
    font-size: 0.9rem;
    color: var(--gris-500);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .engagement-card__axes {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .axis-tag {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    border: 1px solid;
  }

  .axis-tag--technological { color: var(--bleu); border-color: var(--bleu); }
  .axis-tag--environmental { color: var(--vert); border-color: var(--vert); }
  .axis-tag--sociocultural { color: var(--rose); border-color: var(--rose); }

  .engagement-card--coming {
    border-style: dashed;
    border-color: var(--gris-300);
    background: transparent;
  }

  .engagement-card--coming:hover {
    transform: none;
    box-shadow: none;
  }

  .engagement-card__coming-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    min-height: 120px;
  }

  .engagement-card--coming h3 {
    color: var(--gris-400);
    font-style: italic;
  }

  .engagement-card--coming .engagement-card__desc {
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .engagements-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .engagements-grid {
      grid-template-columns: 1fr;
    }

    .page-hero .subtitle {
      position: relative;
      z-index: 5;
    }

    .hero-matrice {
      height: auto;
      min-height: 0;
      margin-top: var(--space-md);
      mask-image: none;
      -webkit-mask-image: none;
    }

    .engagement-card--coming {
      display: none;
    }
  }
</style>
