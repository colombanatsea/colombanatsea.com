---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Matrice from '../../components/Matrice.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const engagements = [
  { name: 'GASPE', role: 'General Delegate', desc: 'Public Maritime Service & Water Crossings Operators Association.', color: 'var(--rose)', url: 'https://www.gaspe.fr/' },
  { name: 'VAIATA Dynamics', role: 'Co-founder', desc: 'AI at the service of maritime\'s great causes: search and rescue, cyber defence.', color: 'var(--bleu)', url: 'https://vaiata-dynamics.com/fr/' },
  { name: 'Opsealog', role: 'Initial design & former Head of Innovation', desc: 'Maritime data analytics platform to optimize vessel performance and energy consumption.', color: 'var(--bleu)', url: 'https://opsealog.com/' },
  { name: 'Fondation ENSM', role: 'Board President', desc: 'Foundation of the National Maritime Academy, training future merchant navy officers and maritime engineers.', color: 'var(--rose)', url: 'https://www.supmaritime.fr/fondation-ensm-don/' },
  { name: 'ENSM', role: 'Lecturer', desc: 'Teaching sustainable development and ecological transition.', color: 'var(--vert)', url: 'https://www.supmaritime.fr/' },
  { name: 'FNMM', role: 'Member', desc: 'French National Federation of Maritime Merit.', color: 'var(--rose)', url: 'https://www.meritemaritime-fnmm.com/' },
  { name: 'HYDROS Alumni', role: 'Deputy Secretary General', desc: 'Animation of the ENSM students and alumni network.', color: 'var(--rose)', url: 'https://www.hydros-alumni.org/' },
  { name: 'Propeller Club', role: 'Active member', desc: 'International network of maritime and port professionals.', color: 'var(--rose)', url: 'https://propellerclub.us/' },
  { name: 'Aperitifs de la Mer', role: 'Ambassador', desc: 'Networking and thought leadership events gathering maritime economy actors.', color: 'var(--rose)', url: 'https://aperitifsdelamer.com/' },
  { name: 'Academie de Marine', role: 'Auditor', desc: 'Centuries-old institution for maritime reflection and foresight.', color: 'var(--rose)', url: 'https://www.academiedemarine.fr/' },
  { name: 'COESPC', role: 'Board member', desc: 'Local engagement in Annecy-le-Vieux: organizing the annual village festival for charitable purposes.', color: 'var(--rose)', url: 'https://coespc.org/' },
];
---

<BaseLayout lang="en" frSlug="engagements" title="Engagements — Colomban at Sea" description="Colomban's engagements serving tomorrow's maritime: GASPE, VAIATA Dynamics, Fondation ENSM, and more.">

<section class="section-dark hero-inner" style="min-height: 50vh; display: flex; align-items: flex-end; padding-bottom: 0;">
  <Matrice />
  <div class="container" style="position: relative; z-index: 2; padding-bottom: var(--space-xl);">
    <p class="mono text-accent">Engagements</p>
    <h1>An ecosystem at the service <br/>of maritime<span class="dot-accent">.</span></h1>
  </div>
</section>

<section class="section-light">
  <div class="container">
    <div class="engagement-grid">
      {engagements.map((e) => (
        <div class="engagement-card stagger">
          <div class="engagement-card__dot" style={`background: ${e.color};`}></div>
          <h3>{e.name}</h3>
          <p class="mono text-muted" style="font-size: 0.7rem; margin-bottom: 0.5rem;">{e.role}</p>
          <p style="font-size: 0.9rem; color: var(--gris-500);">{e.desc}</p>
        </div>
      ))}
      <div class="engagement-card engagement-card--coming stagger">
        <p style="color: var(--gris-400); font-style: italic;">And more to come...</p>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
