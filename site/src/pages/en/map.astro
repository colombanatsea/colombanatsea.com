---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Globe from '../../components/Globe.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Interactive Map — Colomban" lang="en" frSlug="carte" description="Interactive globe: French EEZ, submarine cables and global shipping routes.">
  <section class="carte-page">
    <a href={`${base}/en/`} class="carte-page__back" aria-label="Back to homepage">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" />
      </svg>
      <span class="mono">Back</span>
    </a>
    <div class="carte-page__globe">
      <Globe />
    </div>
  </section>
</BaseLayout>

<style>
  .carte-page {
    position: fixed;
    inset: 0;
    background: var(--noir-doux);
    z-index: 1;
  }

  .carte-page__back {
    position: absolute;
    top: calc(var(--nav-height) + 1rem);
    left: 2rem;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 24px;
    padding: 0.5rem 1rem;
    color: rgba(255,255,255,0.7);
    cursor: pointer;
    transition: all 0.3s;
    backdrop-filter: blur(8px);
    text-decoration: none;
  }

  .carte-page__back .mono {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
  }

  .carte-page__back:hover {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.4);
    color: #fff;
  }

  .carte-page__globe {
    width: 100%;
    height: 100vh;
  }

  /* Show legend and stats by default on this page */
  .carte-page__globe :global(#total-counter),
  .carte-page__globe :global(#legend) {
    display: block !important;
  }

  .carte-page__globe :global(.globe-download-wrap) {
    display: block !important;
  }

  .carte-page__globe :global(#globe-container) {
    pointer-events: auto;
  }

  .carte-page__globe :global(canvas) {
    pointer-events: auto;
  }
</style>
