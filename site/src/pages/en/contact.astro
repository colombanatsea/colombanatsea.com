---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout lang="en" frSlug="contact" title="Contact — Colomban at Sea" description="Contact Colomban via LinkedIn or Instagram. Maritime thought leader.">

<section class="section-dark hero-inner">
  <div class="container">
    <p class="mono text-accent">Contact</p>
    <h1>Let's connect<span class="dot-accent">.</span></h1>
    <p class="subtitle">The best way to reach me: join me on social media and send a direct message.</p>
  </div>
</section>

<section class="section-light">
  <div class="container page-content" style="text-align: center; padding: var(--space-2xl) 0;">
    <div class="cta-social__links" style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="https://www.linkedin.com/in/colombanatsea/" target="_blank" rel="noopener noreferrer" class="btn btn-primary">LinkedIn (~16,000 followers)</a>
      <a href="https://www.instagram.com/colombanatsea/" target="_blank" rel="noopener noreferrer" class="btn btn-outline">Instagram @colombanatsea</a>
    </div>
    <div style="margin-top: var(--space-xl);">
      <p class="mono text-muted">Or by email</p>
      <a href="mailto:hello@colombanatsea.com" style="font-size: 1.1rem; color: var(--bleu);">hello@colombanatsea.com</a>
    </div>
  </div>
</section>

</BaseLayout>
