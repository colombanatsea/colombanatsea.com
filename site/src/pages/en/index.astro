---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Globe from '../../components/Globe.astro';
import Matrice from '../../components/Matrice.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Colomban — Oceanocratie" lang="en" frSlug="" description="The maritime world faces three unprecedented transformations. Colomban details his vision for a sustainable maritime world and a source of inspiration for our society.">

  <!-- ═══ HERO ═══ -->
  <section class="hero" id="hero">
    <div class="hero__globe-bg">
      <Globe />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content container stagger">
      <p class="hero__kicker mono">colombanatsea.com</p>
      <h1 class="hero__title">Oceanocracy</h1>
      <p class="hero__vision">A free nation looks to the sea.</p>
      <div class="hero__cta">
        <a href="#vision" class="btn btn-primary">Discover the vision</a>
        <a href={`${base}/en/about`} class="btn btn-outline hero__btn-outline">About Colomban</a>
      </div>
    </div>
    <button class="hero__explore-map" id="hero-explore-map" aria-label="Explore the full-screen map">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 3 21 3 21 9" /><polyline points="9 21 3 21 3 15" /><line x1="21" y1="3" x2="14" y2="10" /><line x1="3" y1="21" x2="10" y2="14" />
      </svg>
      <span class="mono">Explore the map</span>
    </button>
    <div class="hero__scroll-hint">
      <span class="mono text-muted">Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ═══ TABARLY QUOTE ═══ -->
  <section class="tabarly section-dark section" id="tabarly">
    <div class="container">
      <blockquote class="tabarly__quote stagger">
        <p>&ldquo;The sea is what the French have behind them when they look at the beach.&rdquo;</p>
        <cite>&Eacute;ric Tabarly</cite>
      </blockquote>
      <p class="tabarly__echo stagger">France is destined to be a maritime nation.<br/>And we fight with all our strength to escape this fate — for a long time now.</p>
    </div>
  </section>

  <!-- ═══ THE FRENCH MARITORY ═══ -->
  <section class="archipel section" id="globe">
    <div class="container">
      <div class="archipel__header stagger">
        <p class="mono text-bleu">The French MARitory</p>
        <h2>France is not a hexagon<br/>It is an archipelago</h2>
        <p class="subtitle">We remain confined to our narrow hexagonal TERRitory, while our MARitory makes France a global nation. A strategic potential that cuts across every challenge of the century.</p>
      </div>

      <div class="archipel__grid">
        <div class="archipel__card stagger" id="fact-zee">
          <span class="archipel__number">2<sup>nd</sup></span>
          <span class="archipel__title">World's EEZ</span>
          <span class="archipel__desc">11 million km&sup2; of maritime space, across all the world's oceans</span>
        </div>
        <div class="archipel__card stagger" id="fact-37-frontieres">
          <span class="archipel__number">37</span>
          <span class="archipel__title">Maritime borders</span>
          <span class="archipel__desc">A unique diplomatic interface: <a href={`${base}/en/sources`} style="color: inherit; text-decoration: underline; text-decoration-color: var(--gris-200); text-underline-offset: 2px;">37 States and territories</a> as neighbors, no other country in the world</span>
        </div>
        <div class="archipel__card stagger" id="fact-4-oceans">
          <span class="archipel__number">4</span>
          <span class="archipel__title">Oceans</span>
          <span class="archipel__desc">Atlantic, Pacific, Indian, Southern — a presence across all oceans</span>
        </div>
        <div class="archipel__card stagger" id="fact-5-continents">
          <span class="archipel__number">5</span>
          <span class="archipel__title">Continents</span>
          <span class="archipel__desc">Europe, Americas, Africa, Oceania, Antarctica — <a href={`${base}/en/sources`} style="color: inherit; text-decoration: underline; text-decoration-color: var(--gris-200); text-underline-offset: 2px;">only country in the world</a></span>
        </div>
        <div class="archipel__card stagger" id="fact-595-exports">
          <span class="archipel__number">&euro;595bn</span>
          <span class="archipel__title">Maritime exports</span>
          <span class="archipel__desc">Of French goods exports transit by sea</span>
        </div>
        <div class="archipel__card stagger" id="fact-50-cables">
          <span class="archipel__number">50+</span>
          <span class="archipel__title">Submarine cables</span>
          <span class="archipel__desc"><a href={`${base}/en/sources#cables-sous-marins`} style="color: inherit; text-decoration: underline; text-decoration-color: var(--gris-200); text-underline-offset: 2px;">Most connected country in Europe</a></span>
        </div>
        <div class="archipel__card stagger" id="fact-45-eolien">
          <span class="archipel__number">45 GW</span>
          <span class="archipel__title">Offshore wind</span>
          <span class="archipel__desc">Targeted by 2050 — 30% of French electricity</span>
        </div>
        <div class="archipel__card stagger" id="fact-adn-culture">
          <span class="archipel__number">DNA</span>
          <span class="archipel__title">Culture</span>
          <span class="archipel__desc">From Petit Bateau to Jean-Paul Gaultier, from Kickers to Ulysse Nardin: maritime is anchored in our identity, without us embracing it</span>
        </div>
      </div>

      <p class="archipel__note">Explore the <a href="#" id="explore-zee-link" style="color: var(--bleu); text-decoration: underline; text-underline-offset: 2px;">interactive globe</a> to visualize the French MARitory.</p>
    </div>
  </section>

  <div class="divider-wrap divider-wrap--overlap">
    <img src={`${base}/images/divider.svg`} alt="" class="divider-img" />
  </div>

  <!-- ═══ EVERYTHING GOES THROUGH THE SEA ═══ -->
  <section class="seamer section-dark section" id="seamer">
    <div class="container">
      <div class="seamer__header stagger">
        <p class="mono text-bleu">The invisible infrastructure</p>
        <h2>Everything goes through the sea</h2>
      </div>
      <div class="seamer__content">
        <div class="seamer__text stagger">
          <p class="seamer__lead">What you consumed this morning arrived by sea. The message you are reading travels through a cable on the ocean floor. The energy that will power your children will be born from waves and sea wind.</p>
          <p>The maritime sector is not an ordinary industry. It is the pulse of our society. Without ships, without ports, without submarine cables, the economy seizes up, communications go dark, sovereignty fades.</p>
        </div>
        <div class="seamer__facts">
          <div class="seamer__fact stagger" id="fact-97-donnees">
            <span class="seamer__fact-number">97%</span>
            <span class="seamer__fact-label">of global digital data transits through submarine cables — digital sovereignty</span>
          </div>
          <div class="seamer__fact stagger" id="fact-80-commerce">
            <span class="seamer__fact-number">80%</span>
            <span class="seamer__fact-label">of global goods are transported by sea — economic interface</span>
          </div>
          <div class="seamer__fact stagger" id="fact-emr">
            <span class="seamer__fact-number">MRE</span>
            <span class="seamer__fact-label">offshore wind, tidal, ocean thermal energy — a considerable energy potential</span>
          </div>
          <div class="seamer__fact stagger" id="fact-25000-molecules">
            <span class="seamer__fact-number">25,000</span>
            <span class="seamer__fact-label">marine molecules described — tomorrow's pharmacy</span>
          </div>
        </div>
      </div>
      <p class="seamer__source stagger">All figures are referenced on the <a href={`${base}/en/sources`}>Sources & Data</a> page.</p>
    </div>
  </section>

  <div class="divider-wrap divider-wrap--overlap">
    <img src={`${base}/images/divider.svg`} alt="" class="divider-img" />
  </div>

  <!-- ═══ OCEANOCRATIE MANIFESTO ═══ -->
  <section class="manifeste section" id="vision">
    <div class="container">
      <div class="manifeste__header stagger">
        <p class="mono text-bleu">Oceanocracy</p>
        <h2>A free nation<br/>looks to the sea</h2>
        <p class="subtitle">Thalassocracy built power on domination of the seas. Oceanocracy builds society's resilience on a conscious relationship with the ocean. Not power <em>over</em>, but power <em>with</em>.</p>
      </div>

      <div class="manifeste__pillars">
        <div class="manifeste__pillar stagger">
          <div class="manifeste__pillar-icon" style="--pillar-color: var(--bleu);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
            </svg>
          </div>
          <h3>Curiosity against withdrawal</h3>
          <p>The sea is the school of freedom. Not the comfortable freedom of staying home, but the demanding freedom to experiment, to think beyond time, to live in the present. It is the ultimate journey: daring to discover, questioning one's own frame of reference, opening up to the Other.</p>
        </div>

        <div class="manifeste__pillar stagger">
          <div class="manifeste__pillar-icon" style="--pillar-color: var(--vert);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M12 22c5-3 8-7 8-12 0-3-2.5-5-5-5-1.5 0-2.5.5-3 1.5C11.5 5.5 10.5 5 9 5c-2.5 0-5 2-5 5 0 5 3 9 8 12z"/>
            </svg>
          </div>
          <h3>Humility before the untameable</h3>
          <p>We plough the land, fence it, own it, master it. The ocean cannot be fenced or owned. It reminds us that we are not the masters. This is a lesson in humility that the land only teaches in extreme places: understanding that we are part of nature, not above it.</p>
        </div>

        <div class="manifeste__pillar stagger">
          <div class="manifeste__pillar-icon" style="--pillar-color: var(--rose);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3>A hand reached beyond the horizon</h3>
          <p>At sea, maritime law mandates rescue — regardless of nationality, culture, color, or religion. No border holds far from shore. The ocean is humanity's largest shared space: 37 maritime neighbors for France, 37 outstretched hands. The sea connects far more than it separates.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider-wrap divider-wrap--overlap">
    <img src={`${base}/images/divider.svg`} alt="" class="divider-img" />
  </div>

  <!-- ═══ TRIPLE EVOLUTION ═══ -->
  <section class="vision section-dark section" id="evolution">
    <div class="container" style="position: relative; z-index: 1;">
      <div class="vision__header stagger">
        <p class="mono text-bleu">The triple maritime evolution</p>
        <h2>Two transitions,<br/>one revolution</h2>
        <p class="subtitle">The maritime world faces three unprecedented transformations. These are not threats — they are opportunities for a more sustainable society.</p>
      </div>

      <div class="vision__axes">
        <div class="vision__axis" data-axis="techno">
          <div class="vision__axis-icon" style="--axis-color: var(--bleu);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>Technological transition</h3>
          <p>90% of the world has 4G, but 70% of the global fleet still uses paper logbooks. Maritime must not merely digitize — it must leap straight into a post-web digital era.</p>
        </div>

        <div class="vision__axis" data-axis="enviro">
          <div class="vision__axis-icon" style="--axis-color: var(--vert);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M12 22c5-3 8-7 8-12 0-3-2.5-5-5-5-1.5 0-2.5.5-3 1.5C11.5 5.5 10.5 5 9 5c-2.5 0-5 2-5 5 0 5 3 9 8 12z"/>
            </svg>
          </div>
          <h3>Ecological transition</h3>
          <p>Decarbonization, sail, hydrogen, floating wind. Maritime carries the promise of clean energy — 45 GW of offshore renewables by 2050 in France — and transport 7 times less carbon-intensive than road. While decarbonization is often the immediate focus, let us not forget there are 9 planetary boundaries to preserve, and maritime plays a role in each.</p>
        </div>

        <div class="vision__axis" data-axis="socio">
          <div class="vision__axis-icon" style="--axis-color: var(--rose);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3>Sociocultural revolution</h3>
          <p>Maritime transition without the social dimension — without the seafarers — is just recreational boating. Maritime stakeholders must take ownership of the 21st century's challenges. Drawing on maritime values — long-term thinking, crew spirit, pioneering spirit, humility — they must actively transform their world and share it to inspire society.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MATRICE ENGAGEMENTS ═══ -->
  <section class="matrice-section section-dark section" id="matrice">
    <div class="container">
      <div class="matrice-section__header stagger">
        <p class="mono text-bleu">Engagements</p>
        <h2>3 engagement axes for Colomban<br/>One single heading</h2>
      </div>
    </div>
    <div class="matrice-section__canvas">
      <Matrice />
    </div>
  </section>

  <!-- ═══ LOGOS ═══ -->
  <section class="logos section" id="logos">
    <div class="container">
      <p class="logos__title mono text-muted">Collaborations, Mentions, Positions</p>
      <div class="logos__track">
        <div class="logos__slide">
          <span class="logos__item">GASPE</span>
          <span class="logos__item">Fondation ENSM</span>
          <span class="logos__item">VAIATA Dynamics</span>
          <span class="logos__item">Propeller Club</span>
          <span class="logos__item">HYDROS Alumni</span>
          <span class="logos__item">Le Monde</span>
          <span class="logos__item">TF1</span>
          <span class="logos__item">Marine & Oceans</span>
          <span class="logos__item">Euromaritime</span>
          <span class="logos__item">ENSM</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="testimonials section" id="temoignages">
    <div class="container">
      <div class="testimonials__header stagger">
        <h2>Trust is good<br/>Testimonials are better</h2>
      </div>
      <div class="testimonials__grid">
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/simon-bernard.jpg" alt="Simon Bernard" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"I met Colomban during my early years at the Merchant Marine Academy and followed his various projects closely: an unconditional lover of the sea, he enjoys putting his innovative ideas at the service of the maritime industry. As a project leader myself, I witnessed his professionalism, his ability to drive things forward, and his use of technology without ever forgetting the human element."</p>
          <cite>— Simon Bernard</cite>
          <span class="testimonial__role">Co-founder — Plastic Odyssey</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/bastien-arcas.jpg" alt="Bastien Arcas" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"Colomban is a locomotive pulling several wagons essential to our community: the ENSM Foundation, Hydros, and the Ap&eacute;ritif de la mer."</p>
          <cite>— Bastien Arcas</cite>
          <span class="testimonial__role">Deputy Director — GTT Fleet Performance</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/stanislas-oriot.jpg" alt="Stanislas Oriot" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"What an energy! It is sometimes intimidating to have such a guy around because it seems his energy is 200% above mine and his days are 40 hours long."</p>
          <cite>— Stanislas Oriot</cite>
          <span class="testimonial__role">Senior Maritime Analyst — Opsealog</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/khalil-bouzidi.jpg" alt="Khalil Bouzidi" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"Amazing guy! One of the best ethical growth hackers that I have met! Customer-centric, attentive to detail, a massive asset for Rempleo!"</p>
          <cite>— Khalil Bouzidi</cite>
          <span class="testimonial__role">Founder — Rempleo</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/anthony-garcia.jpg" alt="Anthony Garcia" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"As long as I have known Colomban, he has always had a strong taste for adventure and innovation."</p>
          <cite>— Anthony Garcia</cite>
          <span class="testimonial__role">COO — Jifmar</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/rodolphe-bouchet.jpg" alt="Rodolphe Bouchet" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"Dynamic and professional, Colomban knows how to boost business development."</p>
          <cite>— Rodolphe Bouchet</cite>
          <span class="testimonial__role">CEO — Bourbon Marine &amp; Logistics</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/andrea-mancuso.jpg" alt="Andrea Mancuso" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"I had the privilege and pleasure to work with Colomban on a CMMS for the maritime industry."</p>
          <cite>— Andrea Mancuso</cite>
          <span class="testimonial__role">Senior Software Engineer</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/matthias-du-verle.jpg" alt="Matthias du Verle" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"I have known Colomban since the time he was a promising cadet officer."</p>
          <cite>— Matthias du Verle</cite>
          <span class="testimonial__role">Co-founder — Wolfgang</span>
        </blockquote>
        <blockquote class="testimonial">
          <img src="/colombanatsea.com/assets/testimonials/luna-menendez.jpg" alt="Luna Menendez" class="testimonial__photo" width="64" height="64" loading="lazy" />
          <p>"Colomban is one of the most curious people I have ever met. In his 30-hour long days, he manages to read all the most interesting and diverse articles, magazines, and publications about the maritime industry. And he still finds time to be a truly inspiring manager. He is always willing to help you out and share his knowledge, always organized, and constantly pushing us forward with a team spirit that is hard to find these days."</p>
          <cite>— Luna Menendez</cite>
          <span class="testimonial__role">Project Manager, Opsealog</span>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ═══ CTA SOCIAL ═══ -->
  <section class="cta-social section-dark section" id="cta">
    <div class="container">
      <div class="cta-social__inner stagger">
        <h2>Share our maritime<br/>vision of the world</h2>
        <p class="subtitle">Join the conversation on social media.</p>
        <div class="cta-social__links">
          <a href="https://www.linkedin.com/in/colombanatsea/" target="_blank" rel="noopener noreferrer" class="cta-social__link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <span>LinkedIn</span>
          </a>
          <a href="https://www.instagram.com/colombanatsea/" target="_blank" rel="noopener noreferrer" class="cta-social__link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            <span>Instagram</span>
          </a>
          <a href="https://www.youtube.com/@Colombanatsea" target="_blank" rel="noopener noreferrer" class="cta-social__link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <span>YouTube</span>
          </a>
          <a href="https://www.tiktok.com/@colombanatsea" target="_blank" rel="noopener noreferrer" class="cta-social__link">
