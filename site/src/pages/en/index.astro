<script>
  // Hero scroll = dezoom (scale down globe + overlay instead of scrolling away)
  const hero = document.getElementById('hero');
  const heroContent = hero?.querySelector('.hero__content') as HTMLElement | null;
  const heroOverlay = hero?.querySelector('.hero__overlay') as HTMLElement | null;
  const heroGlobe = hero?.querySelector('.hero__globe-bg') as HTMLElement | null;

  let heroRafPending = false;
  function handleHeroScroll() {
    if (heroRafPending) return;
    heroRafPending = true;
    requestAnimationFrame(() => {
      heroRafPending = false;
      if (!hero || !heroContent) return;
      const heroH = hero.offsetHeight;
      const scrollY = window.scrollY;
      if (scrollY < heroH) {
        const progress = scrollY / heroH;
        const scale = 1 - progress * 0.25;
        const opacity = 1 - progress * 1.5;
        if (heroGlobe) heroGlobe.style.transform = `scale(${scale})`;
        if (heroContent) heroContent.style.opacity = String(Math.max(0, opacity));
        if (heroOverlay) heroOverlay.style.opacity = String(Math.max(0.15, 1 - progress));
      } else {
        if (heroGlobe) heroGlobe.style.transform = '';
        if (heroContent) heroContent.style.opacity = '0';
      }
    });
  }

  window.addEventListener('scroll', handleHeroScroll, { passive: true });

  // Block wheel events on the globe when NOT in fullmap (so page scrolls normally)
  const globeContainer = hero?.querySelector('.hero__globe-bg');
  globeContainer?.addEventListener('wheel', (e) => {
    if (!hero?.classList.contains('hero--fullmap')) {
      // Let the event propagate to the page for normal scrolling
    }
  }, { passive: true });

  // Disable globe zoom in hero mode via a MutationObserver on the class
  function setGlobeZoom(enabled: boolean) {
    const canvas = hero?.querySelector('canvas');
    if (canvas) {
      canvas.style.pointerEvents = enabled ? 'auto' : 'none';
    }
    const container = hero?.querySelector('#globe-container') as HTMLElement | null;
    if (container) {
      container.style.pointerEvents = enabled ? 'auto' : 'none';
    }
  }

  // Start with zoom disabled (hero mode)
  setTimeout(() => setGlobeZoom(false), 100);

  // Fullmap toggle
  const exploreBtn = document.getElementById('hero-explore-map');
  exploreBtn?.addEventListener('click', () => {
    hero?.classList.toggle('hero--fullmap');
    const isFullmap = hero?.classList.contains('hero--fullmap');
    if (exploreBtn) {
      const label = exploreBtn.querySelector('.mono');
      if (label) label.textContent = isFullmap ? 'Close the map' : 'Explore the map';
    }
    document.body.style.overflow = isFullmap ? 'hidden' : '';
    setGlobeZoom(!!isFullmap);
  });

  // Close fullmap on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && hero?.classList.contains('hero--fullmap')) {
      hero.classList.remove('hero--fullmap');
      document.body.style.overflow = '';
      const label = exploreBtn?.querySelector('.mono');
      if (label) label.textContent = 'Explore the map';
      setGlobeZoom(false);
    }
  });

  // ZEE-only globe link
  const zeeLink = document.getElementById('explore-zee-link');
  zeeLink?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
    setTimeout(() => {
      if (!hero?.classList.contains('hero--fullmap')) {
        exploreBtn?.click();
      }
      document.querySelectorAll('#legend .legend-item[data-layer]').forEach(item => {
        const layer = (item as HTMLElement).dataset.layer;
        if (layer === 'cables' || layer === 'traffic') {
          if (!item.classList.contains('disabled')) {
            (item as HTMLElement).click();
          }
        }
      });
    }, 600);
  });

  // Track outbound social link clicks as conversions
  document.querySelectorAll('.cta-social__link').forEach(link => {
    link.addEventListener('click', () => {
      if (typeof gtag === 'function') {
        const platform = new URL(link.href).hostname.replace('www.', '').split('.')[0];
        gtag('event', 'click', { event_category: 'outbound', event_label: platform, transport_type: 'beacon' });
      }
    });
  });
</script>

