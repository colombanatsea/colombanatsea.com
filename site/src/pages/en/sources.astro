<style>
  .sources {
    max-width: 900px;
  }

  .sources h2 {
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-sm);
    font-size: 1.25rem;
  }

  .sources h2:first-child {
    margin-top: 0;
  }

  .sources > p {
    margin-bottom: var(--space-md);
    color: var(--gris-500);
    line-height: 1.8;
  }

  .table-wrapper {
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  thead {
    background: var(--gris-100);
  }

  th, td {
    padding: var(--space-xs) var(--space-sm);
    text-align: left;
    border-bottom: 1px solid var(--gris-200);
  }

  th {
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--gris-500);
  }

  td:first-child {
    font-variant-numeric: tabular-nums;
    color: var(--gris-400);
    width: 2rem;
  }

  .source-ref {
    font-size: 0.85rem;
    color: var(--gris-400);
    margin-top: var(--space-xs);
  }

  .source-ref a {
    color: var(--bleu);
  }

  @media (max-width: 768px) {
    table {
      font-size: 0.8rem;
    }

    th, td {
      padding: var(--space-xs);
    }
  }
</style>
