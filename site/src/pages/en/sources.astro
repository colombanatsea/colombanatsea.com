            <tr><td>SEA-ME-WE 4</td><td>Marseille</td><td>Singapore — Marseille</td></tr>
            <tr><td>SEA-ME-WE 5</td><td>Marseille, Toulon</td><td>Singapore — France</td></tr>
            <tr><td>SEA-ME-WE 6</td><td>Marseille</td><td>Singapore — France (2025)</td></tr>
            <tr><td>IMEWE</td><td>Marseille</td><td>India — Middle East — Europe</td></tr>
            <tr><td>AAE-1</td><td>Marseille</td><td>Asia — Africa — Europe</td></tr>
            <tr><td>2Africa / PEACE</td><td>Marseille</td><td>Around Africa — Europe</td></tr>
            <tr><td>Med Cable</td><td>Marseille</td><td>Algeria — France</td></tr>
            <tr><td>ORVAL / ALVAL</td><td>Marseille</td><td>Algeria — Spain — France</td></tr>
            <tr><td>FLAG Europe-Asia (FEA)</td><td>Marseille</td><td>Japan — UK via Mediterranean</td></tr>
            <tr><td>TGN-Eurasia / TGN-WEA</td><td>Marseille</td><td>Mumbai — Marseille</td></tr>
            <tr><td>EllaLink</td><td>Marseille</td><td>Brazil — Portugal — France</td></tr>
            <tr><td>Dunant</td><td>Saint-Hilaire-de-Riez</td><td>USA (Virginia Beach) — France</td></tr>
