            <tr><td>Apollo</td><td>Lannion</td><td>USA — UK — France</td></tr>
            <tr><td>TAT-14</td><td>Saint-Valery-en-Caux</td><td>USA — UK — France — Netherlands — Germany — Denmark</td></tr>
