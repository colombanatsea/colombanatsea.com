---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout lang="en" frSlug="medias" title="Media & Press — Colomban at Sea" description="28+ press articles and mentions — Le Monde, TF1, Conflits, Marine & Oceans. Downloadable media kit.">

<section class="section-dark hero-inner">
  <div class="container">
    <p class="mono text-accent">Media</p>
    <h1>Press coverage <br/>&amp; media kit<span class="dot-accent">.</span></h1>
    <p class="subtitle">28+ articles and mentions in major French media.</p>
  </div>
</section>

<section class="section-light">
  <div class="container page-content">
    <h2>Media Kit<span class="dot-accent">.</span></h2>
    <div class="kit-grid">
      <div class="kit-card stagger">
        <h3>Full Bio</h3>
        <p>Complete biography for press use.</p>
        <a href={`${base}/kit-media/bio-colomban.txt`} download class="btn btn-outline" style="margin-top: 1rem;">Download .txt</a>
      </div>
      <div class="kit-card stagger">
        <h3>Key Figures</h3>
        <p>Career milestones, metrics and impact numbers.</p>
        <a href={`${base}/kit-media/chiffres-cles.txt`} download class="btn btn-outline" style="margin-top: 1rem;">Download .txt</a>
      </div>
      <div class="kit-card stagger">
        <h3>Contact Card</h3>
        <p>VCard with contact details and social profiles.</p>
        <a href={`${base}/kit-media/colomban.vcf`} download class="btn btn-outline" style="margin-top: 1rem;">Download .vcf</a>
      </div>
      <div class="kit-card stagger">
        <h3>HD Photos</h3>
        <p>Professional portraits for editorial use.</p>
        <a href="mailto:hello@colombanatsea.com?subject=HD%20Photos%20Request" class="btn btn-outline" style="margin-top: 1rem;">Request by email</a>
      </div>
    </div>

    <h2>Press Coverage<span class="dot-accent">.</span></h2>
    <p>For the full press coverage timeline, see the <a href={`${base}/fr/medias`}>French version</a> of this page.</p>
  </div>
</section>

</BaseLayout>
